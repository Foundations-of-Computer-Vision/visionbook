  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Interactive Gradient Squares</title>\n<style>\n  html, body { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #fff; }\n  svg { display: block; }\n  .tooltip { \n    position: fixed; background: rgba(0, 0, 0, 0.55); color: #fff; \n    font: 11px/1.4 sans-serif; padding: 3px 8px; border-radius: 4px; \n    pointer-events: none; z-index: 100; white-space: nowrap; display: none;\n  }\n</style>\n</head>\n<body>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 600\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <linearGradient id=\"gradDarkToLight\" x1=\"0\" x2=\"0\" y1=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stop-color=\"#000\"/>\n      <stop offset=\"100%\" stop-color=\"#666\"/>\n    </linearGradient>\n  </defs>\n  <g id=\"squares\">\n    <rect x=\"50\" y=\"50\" width=\"500\" height=\"500\" fill=\"url(#gradDarkToLight)\" opacity=\"0.1\"/>\n    <rect x=\"90\" y=\"90\" width=\"420\" height=\"420\" fill=\"url(#gradDarkToLight)\" opacity=\"0.2\"/>\n    <rect x=\"130\" y=\"130\" width=\"340\" height=\"340\" fill=\"url(#gradDarkToLight)\" opacity=\"0.3\"/>\n    <rect x=\"170\" y=\"170\" width=\"260\" height=\"260\" fill=\"url(#gradDarkToLight)\" opacity=\"0.4\"/>\n    <rect x=\"210\" y=\"210\" width=\"180\" height=\"180\" fill=\"url(#gradDarkToLight)\" opacity=\"0.5\"/>\n    <rect x=\"250\" y=\"250\" width=\"100\" height=\"100\" fill=\"url(#gradDarkToLight)\" opacity=\"0.6\"/>\n  </g>\n</svg>\n<div class=\"tooltip\" id=\"tooltip\"></div>\n<script>\n  const tooltip = document.getElementById('tooltip');\n  const squares = document.getElementById('squares');\n\n  squares.addEventListener('mousemove', e => {\n    if (e.target.tagName === 'rect') {\n      tooltip.style.display = 'block';\n      tooltip.style.left = (e.clientX + 12) + 'px';\n      tooltip.style.top = (e.clientY - 28) + 'px';\n      tooltip.innerText = 'Gradient Square';\n    }\n  });\n\n  squares.addEventListener('mouseout', () => {\n    tooltip.style.display = 'none';\n  });\n\n  document.addEventListener('click', () => {\n    showPopup('Gradient Squares', 'This visual depicts a series of concentric squares with gradient fills.');\n  });\n\n  function showPopup(title, body) {\n    window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n  }\n\n  function hidePopup() {\n    window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n  }\n\n  document.addEventListener('keydown', e => {\n    if (e.key === 'Escape') hidePopup();\n  });\n\n  document.querySelector('svg').addEventListener('click', e => {\n    if (e.target.tagName !== 'rect') hidePopup();\n  });\n</script>\n</body>\n</html>",
