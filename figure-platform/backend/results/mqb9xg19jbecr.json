  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .node:hover { stroke-width: 3; }\n        .edge:hover { stroke-width: 3; }\n        .tooltip { \n            position: fixed; background: rgba(0, 0, 0, 0.55); color: #fff; \n            font: 11px/1.4 sans-serif; padding: 3px 8px; border-radius: 4px; \n            pointer-events: none; z-index: 100; white-space: nowrap; \n            display: none; \n        }\n    </style>\n</head>\n<body>\n    <svg viewBox=\"0 0 200 100\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n            </marker>\n        </defs>\n        <circle class=\"node\" cx=\"40\" cy=\"50\" r=\"18\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\" data-name=\"X1\"/>\n        <circle class=\"node\" cx=\"160\" cy=\"50\" r=\"18\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\" data-name=\"X2\"/>\n        <line class=\"edge\" x1=\"58\" y1=\"50\" x2=\"142\" y2=\"50\" stroke=\"#000\" stroke-width=\"1.5\" data-name=\"Edge\" />\n        <text x=\"30\" y=\"85\" font-size=\"12\" font-family=\"sans-serif\">X₁</text>\n        <text x=\"150\" y=\"85\" font-size=\"12\" font-family=\"sans-serif\">X₂</text>\n    </svg>\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n\n    <script>\n        document.addEventListener('DOMContentLoaded', function() {\n            const svg = document.querySelector('svg');\n            const tooltip = document.getElementById('tooltip');\n\n            function showTooltip(evt, text) {\n                tooltip.textContent = text;\n                tooltip.style.display = 'block';\n                tooltip.style.left = (evt.clientX + 12) + 'px';\n                tooltip.style.top = (evt.clientY - 28) + 'px';\n            }\n\n            function hideTooltip() {\n                tooltip.style.display = 'none';\n            }\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('mousemove', function(e) {\n                const element = document.elementFromPoint(e.clientX, e.clientY);\n                if (element && element.dataset.name) {\n                    showTooltip(e, element.dataset.name);\n                } else {\n                    hideTooltip();\n                }\n            });\n\n            svg.addEventListener('click', function(e) {\n                if (e.target && e.target.dataset.name) {\n                    showPopup(e.target.dataset.name, \"This is a conceptual element representing a component in the diagram.\");\n                } else {\n                    hidePopup();\n                }\n            });\n\n            document.addEventListener('keydown', function(e) {\n                if (e.key === 'Escape') hidePopup();\n            });\n        });\n    </script>\n</body>\n</html>",
