  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip {\n            position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif;\n            padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 150\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <text x=\"90\" y=\"90\" font-size=\"32\" font-family=\"serif\" font-weight=\"bold\" fill=\"#333\">g<sub>k</sub></text>\n        <text x=\"270\" y=\"90\" font-size=\"32\" font-family=\"serif\" font-weight=\"bold\" fill=\"#333\">G<sub>k</sub></text>\n        <rect x=\"215\" y=\"50\" width=\"100\" height=\"50\" stroke=\"#333\" fill=\"none\" stroke-width=\"1.5\"></rect>\n        <text x=\"450\" y=\"90\" font-size=\"32\" font-family=\"serif\" font-weight=\"bold\" fill=\"#333\">g<sub>k+1</sub></text>\n        <line x1=\"128\" y1=\"75\" x2=\"215\" y2=\"75\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"315\" y1=\"75\" x2=\"400\" y2=\"75\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    </svg>\n\n    <div id=\"tooltip\"></div>\n\n    <script>\n        document.addEventListener('mousemove', e => {\n            const tt = document.getElementById('tooltip');\n            tt.style.left = (e.clientX + 12) + 'px';\n            tt.style.top = (e.clientY - 28) + 'px';\n        });\n\n        const elements = document.querySelectorAll('text, rect, line');\n        elements.forEach(el => {\n            el.addEventListener('mouseenter', function() {\n                this.style.strokeWidth = '3px';\n                const tt = document.getElementById('tooltip');\n                switch(this.nodeName) {\n                    case 'rect':\n                        tt.textContent = \"Gk: Transformation block\";\n                        break;\n                    case 'line':\n                        if (this.getAttribute('x2') === '215') {\n                            tt.textContent = \"Input arrow: Transmits gk\";\n                        } else {\n                            tt.textContent = \"Output arrow: Transmits gk+1\";\n                        }\n                        break;\n                    case 'text':\n                        if (this.textContent.includes('gk')) {\n                            tt.textContent = \"gk: Initial signal\";\n                        } else {\n                            tt.textContent = \"gk+1: Resulting signal\";\n                        }\n                        break;\n                }\n                tt.style.display = 'block';\n            });\n\n            el.addEventListener('mouseleave', function() {\n                this.style.strokeWidth = '1.5px';\n                document.getElementById('tooltip').style.display = 'none';\n            });\n\n            el.addEventListener('click', function() {\n                let title = \"\", body = \"\";\n                if (this.nodeName === 'rect') {\n                    title = \"Transformation Block Gk\";\n                    body = \"This block represents the transformation function Gk that processes the input gk to produce the output gk+1.\";\n                } else if (this.nodeName === 'text') {\n                    if (this.textContent.includes('gk')) {\n                        title = \"Initial Signal gk\";\n                        body = \"gk represents the initial state or input into the transformation process handled by Gk.\";\n                    } else {\n                        title = \"Resulting Signal gk+1\";\n                        body = \"gk+1 is the output of the transformation process undertaken by Gk, showing the next state.\";\n                    }\n                }\n                showPopup(title, body);\n            });\n        });\n\n        function showPopup(title, body) { \n            window.parent.postMessage({ type:'alex-popup', title, body }, '*'); \n        }\n        function hidePopup() { \n            window.parent.postMessage({ type:'alex-popup', title:null }, '*'); \n        }\n        document.addEventListener('keydown', e => { \n            if(e.key==='Escape') hidePopup(); \n        });\n        document.querySelector('svg').addEventListener('click', e => { \n            if(e.target===e.currentTarget) hidePopup(); \n        });\n    </script>\n</body>\n</html>",
