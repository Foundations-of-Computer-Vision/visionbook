  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  .tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; }\n</style>\n</head>\n<body>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 636\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n    </marker>\n  </defs>\n  <text x=\"300\" y=\"50\" font-size=\"24\" font-family=\"sans-serif\" text-anchor=\"middle\">attn layer</text>\n  <text x=\"80\" y=\"225\" font-size=\"20\" font-family=\"sans-serif\" text-anchor=\"end\">t<sub>in</sub></text>\n  <text x=\"80\" y=\"125\" font-size=\"20\" font-family=\"sans-serif\" text-anchor=\"end\">t<sub>out</sub></text>\n  <text x=\"510\" y=\"300\" font-size=\"20\" font-family=\"sans-serif\" text-anchor=\"start\">f</text>\n  \n  <rect x=\"120\" y=\"100\" width=\"60\" height=\"80\" stroke=\"#333\" fill=\"none\" id=\"rect1\"/>\n  <rect x=\"240\" y=\"100\" width=\"60\" height=\"80\" stroke=\"#333\" fill=\"none\" id=\"rect2\"/>\n  <rect x=\"180\" y=\"350\" width=\"60\" height=\"80\" stroke=\"#333\" fill=\"none\" id=\"rect4\"/>\n  <rect x=\"300\" y=\"350\" width=\"60\" height=\"80\" stroke=\"#333\" fill=\"none\" id=\"rect5\"/>\n  \n  <rect x=\"180\" y=\"230\" width=\"120\" height=\"80\" stroke=\"#333\" fill=\"none\" id=\"attn\">\n    <title>A</title>\n  </rect>\n  <text x=\"240\" y=\"275\" font-size=\"40\" font-family=\"sans-serif\" text-anchor=\"middle\" fill=\"#f00\">A</text>\n  \n  <line x1=\"150\" y1=\"180\" x2=\"190\" y2=\"230\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"line1\"/>\n  <line x1=\"150\" y1=\"180\" x2=\"250\" y2=\"230\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"line2\"/>\n  <line x1=\"270\" y1=\"180\" x2=\"250\" y2=\"230\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"line3\"/>\n  <line x1=\"270\" y1=\"180\" x2=\"310\" y2=\"230\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"line4\"/>\n  \n  <line x1=\"250\" y1=\"310\" x2=\"210\" y2=\"350\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"line5\"/>\n  <line x1=\"250\" y1=\"310\" x2=\"330\" y2=\"350\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"line6\"/>\n  <line x1=\"250\" y1=\"310\" x2=\"250\" y2=\"350\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"line7\"/>\n  <line x1=\"250\" y1=\"310\" x2=\"290\" y2=\"350\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"line8\"/>\n  \n  <path d=\"M300,360 Q360,360 400,300 Q440,240 400,180\" stroke=\"#333\" fill=\"none\" marker-end=\"url(#arr)\"/>\n</svg>\n<div id=\"tooltip\" class=\"tooltip\" style=\"display:none;\"></div>\n<script>\n  try {\n    const svg = document.querySelector('svg');\n    const tooltip = document.getElementById('tooltip');\n\n    const elements = [\n      { id: 'rect1', name: 't<sub>out1</sub>', desc: 'Output node 1.' },\n      { id: 'rect2', name: 't<sub>out2</sub>', desc: 'Output node 2.' },\n      { id: 'rect4', name: 't<sub>in1</sub>', desc: 'Input node 1.' },\n      { id: 'rect5', name: 't<sub>in2</sub>', desc: 'Input node 2.' },\n      { id: 'attn', name: 'Attention Layer', desc: 'Processes input to output.' },\n    ];\n\n    elements.forEach(el => {\n      const elem = document.getElementById(el.id);\n      elem.addEventListener('mouseover', function() {\n        tooltip.innerHTML = `<strong>${el.name}</strong>: ${el.desc}`;\n        tooltip.style.display = 'block';\n      });\n      elem.addEventListener('mouseout', function() {\n        tooltip.style.display = 'none';\n      });\n      elem.addEventListener('click', function() {\n        showPopup(el.name, el.desc);\n      });\n    });\n\n    document.addEventListener('mousemove', function(e) {\n      tooltip.style.left = (e.clientX + 12) + 'px';\n      tooltip.style.top = (e.clientY - 28) + 'px';\n    });\n\n    let active = false;\n    svg.addEventListener('click', function() {\n      const lines = ['line1', 'line2', 'line3', 'line4', 'line5', 'line6', 'line7', 'line8'].map(id => document.getElementById(id));\n      active = !active;\n      lines.forEach((line, i) => {\n        line.style.transition = \"stroke 0.35s ease\";\n        line.style.stroke = active ? '#c8e0ff' : '#333';\n      });\n    });\n\n    function showPopup(title, body) {\n      window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n    }\n    function hidePopup() {\n      window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n    }\n    document.addEventListener('keydown', function(e) {\n      if (e.key === 'Escape') hidePopup();\n    });\n  } catch (e) {\n    console.error(e);\n  }\n</script>\n</body>\n</html>",
