  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Interactive Diagram</title>\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  svg { width:100%; height:100%; }\n  .hoverable { cursor: pointer; }\n  .tooltip { position: fixed; background: rgba(0,0,0,0.55); color: #fff; font: 11px/1.4 sans-serif; padding: 3px 8px; border-radius: 4px; pointer-events: none; z-index: 100; white-space: nowrap; }\n</style>\n</head>\n<body>\n\n<svg viewBox=\"0 0 600 438\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n    </marker>\n  </defs>\n\n  <!-- Node and Labels -->\n  <text x=\"30\" y=\"50\" font-size=\"11\" font-family=\"sans-serif\">gₖ</text>\n  <rect x=\"100\" y=\"35\" width=\"50\" height=\"30\" stroke=\"#000\" fill=\"none\"/>\n  <text x=\"115\" y=\"55\" font-size=\"11\" font-family=\"sans-serif\">B₀</text>\n  <text x=\"200\" y=\"50\" font-size=\"11\" font-family=\"sans-serif\">bₖ,₀</text>\n  \n  <rect x=\"100\" y=\"105\" width=\"50\" height=\"30\" stroke=\"#000\" fill=\"none\"/>\n  <text x=\"115\" y=\"125\" font-size=\"11\" font-family=\"sans-serif\">B₁</text>\n  <text x=\"200\" y=\"120\" font-size=\"11\" font-family=\"sans-serif\">bₖ,₁</text>\n  \n  <rect x=\"100\" y=\"205\" width=\"50\" height=\"30\" stroke=\"#000\" fill=\"none\"/>\n  <text x=\"115\" y=\"225\" font-size=\"11\" font-family=\"sans-serif\">Bₙ</text>\n  <text x=\"200\" y=\"220\" font-size=\"11\" font-family=\"sans-serif\">bₖ,ₙ</text>\n  \n  <rect x=\"100\" y=\"305\" width=\"50\" height=\"30\" stroke=\"#000\" fill=\"none\"/>\n  <text x=\"115\" y=\"325\" font-size=\"11\" font-family=\"sans-serif\">L</text>\n  \n  <rect x=\"180\" y=\"305\" width=\"50\" height=\"30\" stroke=\"#000\" fill=\"none\"/>\n  <text x=\"195\" y=\"325\" font-size=\"11\" font-family=\"sans-serif\">D</text>\n  <text x=\"280\" y=\"320\" font-size=\"11\" font-family=\"sans-serif\">gₖ+₁</text>\n\n  <!-- Lines and Arrows -->\n  <line x1=\"50\" y1=\"50\" x2=\"100\" y2=\"50\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  <line x1=\"150\" y1=\"50\" x2=\"180\" y2=\"50\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  \n  <line x1=\"50\" y1=\"120\" x2=\"100\" y2=\"120\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  <line x1=\"150\" y1=\"120\" x2=\"180\" y2=\"120\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  \n  <line x1=\"50\" y1=\"220\" x2=\"100\" y2=\"220\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  <line x1=\"150\" y1=\"220\" x2=\"180\" y2=\"220\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  \n  <line x1=\"50\" y1=\"320\" x2=\"100\" y2=\"320\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  <line x1=\"150\" y1=\"320\" x2=\"180\" y2=\"320\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  <line x1=\"230\" y1=\"320\" x2=\"260\" y2=\"320\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n\n  <!-- Vertical Connecting Line -->\n  <line x1=\"50\" y1=\"50\" x2=\"50\" y2=\"320\" stroke=\"#333\" stroke-width=\"1.5\"/>\n</svg>\n\n<div id=\"tooltip\" class=\"tooltip\" style=\"display:none;\"></div>\n\n<script>\n  try {\n    const svg = document.querySelector('svg');\n    const tooltip = document.getElementById('tooltip');\n\n    function showPopup(title, body) {\n      window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n    }\n\n    function hidePopup() {\n      window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n    }\n\n    document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n    svg.addEventListener('click', e => { if (e.target === svg || e.target.tagName === 'svg') hidePopup(); });\n    \n    const nodes = document.querySelectorAll('rect, text');\n    nodes.forEach((node) => {\n      node.addEventListener('mouseenter', () => {\n        node.style.strokeWidth = '3';\n        tooltip.innerHTML = `Element: ${node.textContent || node.tagName}<br/>Role: Click for more info`;\n        tooltip.style.display = 'block';\n      });\n\n      node.addEventListener('mouseleave', () => {\n        node.style.strokeWidth = '1.5';\n        tooltip.style.display = 'none';\n      });\n\n      node.addEventListener('click', () => {\n        showPopup('Element Info', `This is the ${node.textContent} node. It plays a role in the sequence shown.`);\n      });\n    });\n\n    document.addEventListener('mousemove', (e) => {\n      tooltip.style.left = (e.clientX + 12) + 'px';\n      tooltip.style.top = (e.clientY - 28) + 'px';\n    });\n  } catch (error) {\n    console.error(error);\n  }\n</script>\n\n</body>\n</html>",
