  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Reconstructed Figure</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip { \n            position: fixed; \n            background: rgba(0, 0, 0, 0.55); \n            color: #fff; \n            font: 11px/1.4 sans-serif; \n            padding: 3px 8px; \n            border-radius: 4px; \n            pointer-events: none; \n            z-index: 100; \n            white-space: nowrap; \n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\"></div>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 350\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <line x1=\"50\" y1=\"300\" x2=\"550\" y2=\"300\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"300\" y1=\"320\" x2=\"300\" y2=\"50\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n\n        <g id=\"bars\" fill=\"none\" stroke=\"blue\" stroke-width=\"2\">\n            <line x1=\"110\" y1=\"300\" x2=\"110\" y2=\"300\"/>\n            <line x1=\"170\" y1=\"300\" x2=\"170\" y2=\"260\"/>\n            <line x1=\"230\" y1=\"300\" x2=\"230\" y2=\"240\"/>\n            <line x1=\"290\" y1=\"300\" x2=\"290\" y2=\"220\"/>\n            <line x1=\"350\" y1=\"300\" x2=\"350\" y2=\"260\"/>\n            <line x1=\"410\" y1=\"300\" x2=\"410\" y2=\"180\"/>\n        </g>\n\n        <g id=\"nodes\" fill=\"blue\">\n            <circle cx=\"110\" cy=\"300\" r=\"10\"/>\n            <circle cx=\"170\" cy=\"260\" r=\"10\"/>\n            <circle cx=\"230\" cy=\"240\" r=\"10\"/>\n            <circle cx=\"290\" cy=\"220\" r=\"10\"/>\n            <circle cx=\"350\" cy=\"260\" r=\"10\"/>\n            <circle cx=\"410\" cy=\"180\" r=\"10\"/>\n        </g>\n\n        <text x=\"325\" y=\"40\" font-size=\"14\" font-family=\"sans-serif\" fill=\"#000\">&#8467; [n-2]</text>\n        <text x=\"540\" y=\"310\" font-size=\"14\" font-family=\"sans-serif\" fill=\"#000\">n</text>\n\n        <text x=\"285\" y=\"295\" font-size=\"10\" font-family=\"sans-serif\" fill=\"#000\">0</text>\n        <text x=\"390\" y=\"295\" font-size=\"10\" font-family=\"sans-serif\" fill=\"#000\">5</text>\n        <line x1=\"300\" y1=\"260\" x2=\"310\" y2=\"260\" stroke=\"#333\" stroke-width=\"1\"/>\n        <line x1=\"300\" y1=\"220\" x2=\"310\" y2=\"220\" stroke=\"#333\" stroke-width=\"1\"/>\n        <line x1=\"300\" y1=\"180\" x2=\"310\" y2=\"180\" stroke=\"#333\" stroke-width=\"1\"/>\n        <text x=\"275\" y=\"264\" font-size=\"10\" font-family=\"sans-serif\" fill=\"#000\">2</text>\n        <text x=\"275\" y=\"224\" font-size=\"10\" font-family=\"sans-serif\" fill=\"#000\">4</text>\n    </svg>\n    <script>\n        const tooltip = document.getElementById('tooltip');\n        document.addEventListener('mousemove', e => {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n        });\n\n        document.querySelectorAll('#nodes circle').forEach(node => {\n            node.addEventListener('mouseenter', function() {\n                this.style.opacity = 1;\n                tooltip.style.display = 'block';\n                tooltip.textContent = 'Data point: n = ' + ((this.cx.baseVal.value - 110) / 60);\n            });\n            node.addEventListener('mouseleave', function() {\n                this.style.opacity = 0.7;\n                tooltip.style.display = 'none';\n            });\n            node.addEventListener('click', function() {\n                let val = ((this.cx.baseVal.value - 110) / 60);\n                showPopup('Data Point', `This data point represents n = ${val}.`);\n            });\n        });\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n        document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n    </script>\n</body>\n</html>",
