  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0,0,0,0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 285\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <text x=\"300\" y=\"40\" font-size=\"18\" font-family=\"serif\" text-anchor=\"middle\" font-weight=\"bold\">forward</text>\n\n        <rect x=\"225\" y=\"90\" width=\"150\" height=\"105\" fill=\"#e0c080\" stroke=\"#333\" stroke-width=\"1.5\"></rect>\n        <text x=\"300\" y=\"160\" font-size=\"20\" font-family=\"serif\" text-anchor=\"middle\">f(x<sub>in</sub>, θ)</text>\n\n        <text x=\"120\" y=\"140\" font-size=\"20\" font-family=\"serif\" text-anchor=\"end\">X<sub>in</sub></text>\n        <line x1=\"125\" y1=\"140\" x2=\"225\" y2=\"140\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"></line>\n\n        <text x=\"120\" y=\"180\" font-size=\"20\" font-family=\"serif\" text-anchor=\"end\">θ</text>\n        <line x1=\"125\" y1=\"180\" x2=\"225\" y2=\"165\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"></line>\n\n        <text x=\"480\" y=\"140\" font-size=\"20\" font-family=\"serif\" text-anchor=\"start\">X<sub>out</sub></text>\n        <line x1=\"375\" y1=\"140\" x2=\"470\" y2=\"140\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"></line>\n    </svg>\n    \n    <div class=\"tooltip\" id=\"tooltip\"></div>\n\n    <script>\n        try {\n            const svg = document.querySelector('svg');\n            const tooltip = document.getElementById('tooltip');\n\n            const elements = [\n                {selector: 'rect', title: 'Function Block', body: 'Represents the function f applied to input x_in and parameters θ.'},\n                {selector: 'line:nth-of-type(1)', title: 'Input X_in', body: 'The input to the function.'},\n                {selector: 'line:nth-of-type(2)', title: 'Parameter θ', body: 'The parameter θ used in the function.'},\n                {selector: 'line:nth-of-type(3)', title: 'Output X_out', body: 'The output of the function.'}\n            ];\n\n            function showPopup(title, body) {\n                window.parent.postMessage({type: 'alex-popup', title, body}, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({type: 'alex-popup', title: null}, '*');\n            }\n\n            document.addEventListener('click', e => {\n                if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n            });\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') hidePopup();\n            });\n\n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            elements.forEach(elem => {\n                const el = document.querySelector(elem.selector);\n                el.style.transition = 'stroke 0.35s ease';\n\n                el.addEventListener('mouseenter', () => {\n                    el.style.strokeWidth = '3';\n                    tooltip.textContent = elem.title;\n                    tooltip.style.display = 'block';\n                });\n\n                el.addEventListener('mouseleave', () => {\n                    el.style.strokeWidth = '1.5';\n                    tooltip.style.display = 'none';\n                });\n\n                el.addEventListener('click', () => {\n                    showPopup(elem.title, elem.body);\n                });\n            });\n        } catch (e) {\n            console.error(e);\n        }\n    </script>\n</body>\n</html>",
