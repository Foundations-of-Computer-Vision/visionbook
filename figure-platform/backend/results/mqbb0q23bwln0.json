  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Lens Diagram</title>\n    <style>\n        html, body { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #fff; }\n        svg { width: 100%; height: 100%; }\n        .hover-effect:hover { stroke-width: 3; }\n        #tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\"></div>\n    <svg viewBox=\"0 0 600 400\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#9370DB\"/>\n            </marker>\n        </defs>\n        <!-- Lens -->\n        <path d=\"M275,50 Q285,200 275,350 Q265,200 275,50\" fill=\"none\" stroke=\"black\" stroke-width=\"3\"/>\n        \n        <!-- Principal axis -->\n        <line x1=\"50\" y1=\"200\" x2=\"550\" y2=\"200\" stroke=\"#4169E1\" stroke-width=\"2\"/>\n        \n        <!-- Rays -->\n        <line class=\"hover-effect\" x1=\"150\" y1=\"150\" x2=\"275\" y2=\"200\" stroke=\"#9370DB\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n        <line class=\"hover-effect\" x1=\"275\" y1=\"200\" x2=\"450\" y2=\"350\" stroke=\"#9370DB\" stroke-width=\"2\"/>\n        \n        <line class=\"hover-effect\" x1=\"150\" y1=\"250\" x2=\"275\" y2=\"200\" stroke=\"#9370DB\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n        <line class=\"hover-effect\" x1=\"275\" y1=\"200\" x2=\"450\" y2=\"50\" stroke=\"#9370DB\" stroke-width=\"2\"/>\n        \n        <line class=\"hover-effect\" x1=\"150\" y1=\"150\" x2=\"375\" y2=\"100\" stroke=\"#9370DB\" stroke-width=\"2\"/>\n        \n        <!-- Dashed lines -->\n        <line class=\"hover-effect\" x1=\"375\" y1=\"100\" x2=\"275\" y2=\"200\" stroke=\"#9370DB\" stroke-width=\"2\" stroke-dasharray=\"5,5\"/>\n\n        <!-- Intersection point -->\n        <circle cx=\"275\" cy=\"200\" r=\"5\" fill=\"#4169E1\"/>\n    </svg>\n\n    <script>\n        const svg = document.querySelector('svg');\n        const tooltip = document.getElementById('tooltip');\n\n        document.addEventListener('mousemove', (e) => {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n        });\n\n        svg.addEventListener('mouseover', function(e) {\n            if (e.target.classList.contains('hover-effect')) {\n                tooltip.style.display = 'block';\n                tooltip.textContent = 'Ray path showing reflection/refraction';\n            }\n        });\n\n        svg.addEventListener('mouseout', function(e) {\n            if (e.target.classList.contains('hover-effect')) {\n                tooltip.style.display = 'none';\n            }\n        });\n\n        svg.addEventListener('click', function(e) {\n            if (e.target.classList.contains('hover-effect')) {\n                showPopup('Lens Interaction', 'This diagram illustrates the behavior of light rays passing through a lens, demonstrating key optics principles.');\n            }\n        });\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.addEventListener('keydown', (e) => {\n            if (e.key === 'Escape') hidePopup();\n        });\n\n        svg.addEventListener('click', (e) => {\n            if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n        });\n    </script>\n</body>\n</html>",
