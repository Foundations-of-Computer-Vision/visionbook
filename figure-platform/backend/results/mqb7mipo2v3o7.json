  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        .tooltip {\n            position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif;\n            padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap;\n            display:none;\n        }\n        svg text { font-family: sans-serif; font-size: 11; }\n        .hoverable:hover { stroke-width: 3; }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\" class=\"tooltip\"></div>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 100\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"red\"/>\n            </marker>\n        </defs>\n\n        <!-- Draw nodes and arrows -->\n        <rect x=\"70\" y=\"30\" width=\"40\" height=\"40\" fill=\"#eed9b9\" stroke=\"#000\" stroke-width=\"1.5\" class=\"hoverable\" id=\"f1\"/>\n        <rect x=\"190\" y=\"30\" width=\"40\" height=\"40\" fill=\"#eed9b9\" stroke=\"#000\" stroke-width=\"1.5\" class=\"hoverable\" id=\"f2\"/>\n        <rect x=\"310\" y=\"30\" width=\"40\" height=\"40\" fill=\"#eed9b9\" stroke=\"#000\" stroke-width=\"1.5\" class=\"hoverable\" id=\"fL1\"/>\n        <rect x=\"430\" y=\"30\" width=\"40\" height=\"40\" fill=\"#eed9b9\" stroke=\"#000\" stroke-width=\"1.5\" class=\"hoverable\" id=\"fL\"/>\n        <rect x=\"550\" y=\"30\" width=\"40\" height=\"40\" fill=\"#e68a6b\" stroke=\"#000\" stroke-width=\"1.5\" class=\"hoverable\" id=\"L\"/>\n\n        <!-- Forward arrows -->\n        <line x1=\"110\" y1=\"50\" x2=\"150\" y2=\"50\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <line x1=\"230\" y1=\"50\" x2=\"270\" y2=\"50\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <line x1=\"350\" y1=\"50\" x2=\"390\" y2=\"50\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <line x1=\"470\" y1=\"50\" x2=\"510\" y2=\"50\" stroke=\"#333\" stroke-width=\"1.5\"/>\n\n        <!-- Backward arrows -->\n        <line x1=\"150\" y1=\"60\" x2=\"110\" y2=\"60\" stroke=\"red\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"270\" y1=\"60\" x2=\"230\" y2=\"60\" stroke=\"red\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"390\" y1=\"60\" x2=\"350\" y2=\"60\" stroke=\"red\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"510\" y1=\"60\" x2=\"470\" y2=\"60\" stroke=\"red\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"590\" y1=\"60\" x2=\"550\" y2=\"60\" stroke=\"red\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n\n        <!-- Labels -->\n        <text x=\"60\" y=\"45\" fill=\"#333\" text-anchor=\"end\" alignment-baseline=\"middle\" class=\"hoverable\" id=\"g0\">g₀</text>\n        <text x=\"130\" y=\"45\" fill=\"#333\" text-anchor=\"middle\" alignment-baseline=\"middle\" class=\"hoverable\">f′₁</text>\n        <text x=\"180\" y=\"70\" fill=\"red\" text-anchor=\"middle\" alignment-baseline=\"middle\" class=\"hoverable\">∂J/∂θ₁</text>\n        <text x=\"250\" y=\"45\" fill=\"#333\" text-anchor=\"middle\" alignment-baseline=\"middle\" class=\"hoverable\" id=\"g1\">g₁</text>\n        <text x=\"310\" y=\"70\" fill=\"red\" text-anchor=\"middle\" alignment-baseline=\"middle\" class=\"hoverable\">∂J/∂θ₂</text>\n        <text x=\"370\" y=\"45\" fill=\"#333\" text-anchor=\"middle\" alignment-baseline=\"middle\" class=\"hoverable\">⋯</text>\n        <text x=\"370\" y=\"70\" fill=\"red\" text-anchor=\"middle\" alignment-baseline=\"middle\" class=\"hoverable\">∂J/∂θₗ₋₁</text>\n        <text x=\"430\" y=\"45\" fill=\"#333\" text-anchor=\"middle\" alignment-baseline=\"middle\" class=\"hoverable\" id=\"gL1\">gₗ₋₁</text>\n        <text x=\"490\" y=\"70\" fill=\"red\" text-anchor=\"middle\" alignment-baseline=\"middle\" class=\"hoverable\">∂J/∂θₗ</text>\n        <text x=\"550\" y=\"45\" fill=\"#333\" text-anchor=\"middle\" alignment-baseline=\"middle\" class=\"hoverable\" id=\"gL\">gₗ</text>\n        <text x=\"590\" y=\"45\" fill=\"#333\" text-anchor=\"start\" alignment-baseline=\"middle\" class=\"hoverable\">1</text>\n        <text x=\"570\" y=\"45\" fill=\"#333\" text-anchor=\"middle\" alignment-baseline=\"middle\" class=\"hoverable\">L′</text>\n    </svg>\n\n    <script>\n        try {\n            const tooltip = document.getElementById('tooltip');\n            const showPopup = (title, body) => window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            const hidePopup = () => window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n            document.querySelectorAll('.hoverable').forEach(el => {\n                el.addEventListener('mouseover', e => {\n                    const messages = {\n                        \"f1\": \"Layer f′₁: First layer in forward pass.\",\n                        \"f2\": \"Layer f′₂: Second layer in forward pass.\",\n                        \"fL1\": \"Layer f′ₗ₋₁: Intermediate layer.\",\n                        \"fL\": \"Layer f′ₗ: Last layer before the final output.\",\n                        \"L\": \"L′: Loss function.\"\n                    };\n                    tooltip.textContent = messages[el.id];\n                    tooltip.style.display = 'block';\n                });\n                el.addEventListener('mouseout', () => tooltip.style.display = 'none');\n                el.addEventListener('click', () => {\n                    const popups = {\n                        \"f1\": \"Layer f′₁ represents the first transformation layer in the network's forward pass.\",\n                        \"f2\": \"Layer f′₂ shows the second transformation in this sequence.\",\n                        \"fL1\": \"Layer f′ₗ₋₁ accounts for any transformation near the final stages of computation.\",\n                        \"fL\": \"Layer f′ₗ is critical for making the final adjustments or transformations before output.\",\n                        \"L\": \"L′ is the loss layer, determining the final output discrepancy to guide updates.\"\n                    };\n                    const popupContent = popups[el.id];\n                    if (popupContent) showPopup(el.id, popupContent);\n                    else hidePopup();\n                });\n            });\n            document.addEventListener('keydown', e => { if(e.key==='Escape') hidePopup(); });\n            document.querySelector('svg').addEventListener('click', e => { if(e.target.tagName==='svg') hidePopup(); });\n        } catch (e) { console.error(e); }\n    </script>\n</body>\n</html>",
