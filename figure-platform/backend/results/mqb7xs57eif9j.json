  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .hoverable:hover { stroke-width: 3; opacity: 1; }\n        .tooltip {\n            position: fixed; background: rgba(0,0,0,0.55); color: #fff; font: 11px/1.4 sans-serif;\n            padding: 3px 8px; border-radius: 4px; pointer-events: none; z-index: 100; white-space: nowrap;\n        }\n    </style>\n</head>\n<body>\n    <svg viewBox=\"0 0 600 400\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n\n        <!-- Arrow -->\n        <line x1=\"300\" y1=\"350\" x2=\"300\" y2=\"50\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n\n        <!-- Curve -->\n        <path d=\"M 100,350 C 200,250 400,250 500,350\" fill=\"none\" stroke=\"#000\"/>\n\n        <!-- Vertical Lines -->\n        <!-- Note: x positions are spaced by 80 for simplicity -->\n        <line x1=\"100\" y1=\"350\" x2=\"100\" y2=\"330\" stroke=\"#00F\" stroke-width=\"1\" class=\"hoverable\"/>\n        <line x1=\"180\" y1=\"350\" x2=\"180\" y2=\"270\" stroke=\"#00F\" stroke-width=\"1\" class=\"hoverable\"/>\n        <line x1=\"260\" y1=\"350\" x2=\"260\" y2=\"180\" stroke=\"#00F\" stroke-width=\"1\" class=\"hoverable\"/>\n        <line x1=\"340\" y1=\"350\" x2=\"340\" y2=\"270\" stroke=\"#00F\" stroke-width=\"1\" class=\"hoverable\"/>\n        <line x1=\"420\" y1=\"350\" x2=\"420\" y2=\"330\" stroke=\"#00F\" stroke-width=\"1\" class=\"hoverable\"/>\n\n        <!-- Nodes -->\n        <circle cx=\"100\" cy=\"330\" r=\"6\" fill=\"#00F\" class=\"hoverable\"/>\n        <circle cx=\"180\" cy=\"270\" r=\"6\" fill=\"#00F\" class=\"hoverable\"/>\n        <circle cx=\"260\" cy=\"180\" r=\"6\" fill=\"#00F\" class=\"hoverable\"/>\n        <circle cx=\"340\" cy=\"270\" r=\"6\" fill=\"#00F\" class=\"hoverable\"/>\n        <circle cx=\"420\" cy=\"330\" r=\"6\" fill=\"#00F\" class=\"hoverable\"/>\n\n        <!-- Text -->\n        <text x=\"300\" y=\"40\" font-size=\"12\" font-family=\"sans-serif\" text-anchor=\"middle\">g[n]</text>\n        <text x=\"260\" y=\"170\" font-size=\"12\" font-family=\"sans-serif\" text-anchor=\"middle\">1</text>\n\n        <text x=\"100\" y=\"370\" font-size=\"12\" font-family=\"sans-serif\" text-anchor=\"middle\">-4</text>\n        <text x=\"180\" y=\"370\" font-size=\"12\" font-family=\"sans-serif\" text-anchor=\"middle\">-2</text>\n        <text x=\"260\" y=\"370\" font-size=\"12\" font-family=\"sans-serif\" text-anchor=\"middle\">0</text>\n        <text x=\"340\" y=\"370\" font-size=\"12\" font-family=\"sans-serif\" text-anchor=\"middle\">2</text>\n        <text x=\"420\" y=\"370\" font-size=\"12\" font-family=\"sans-serif\" text-anchor=\"middle\">4</text>\n        <text x=\"540\" y=\"370\" font-size=\"12\" font-family=\"sans-serif\" text-anchor=\"middle\">n</text>\n    </svg>\n\n    <div id=\"tooltip\" class=\"tooltip\" style=\"display:none;\"></div>\n\n    <script>\n        const svg = document.querySelector('svg');\n        const tooltip = document.getElementById('tooltip');\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        svg.addEventListener('click', (e) => {\n            if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n        });\n\n        document.addEventListener('mousemove', (e) => {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n        });\n\n        document.querySelectorAll('.hoverable').forEach(el => {\n            el.addEventListener('mouseenter', () => {\n                tooltip.textContent = `Point ${el.tagName.toLowerCase()}`;\n                tooltip.style.display = 'block';\n            });\n            el.addEventListener('mouseleave', () => {\n                tooltip.style.display = 'none';\n            });\n            el.addEventListener('click', () => {\n                showPopup('Point Information', `This point represents the data point on the curve.`);\n            });\n        });\n    </script>\n</body>\n</html>",
