  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Interactive Figure</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .hoverable:hover { stroke-width:3px; opacity:1; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            visibility: hidden;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\" class=\"tooltip\"></div>\n    <svg viewBox=\"0 0 600 400\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <path id=\"blobby\" class=\"hoverable\" d=\"M300,200 q50,-100 150,-50 t100,150 q-150,50 -250,0 t-150,-100 q50,-100 150,-50 z\" fill=\"#888\" stroke=\"#666\" stroke-width=\"1.5\"/>\n        <polygon id=\"star\" class=\"hoverable\" points=\"300,100 350,180 420,200 350,220 300,300 250,220 180,200 250,180\" fill=\"#ccc\" stroke=\"#999\" stroke-width=\"1.5\"/>\n    </svg>\n    <script>\n        const tooltip = document.getElementById('tooltip');\n\n        document.querySelectorAll('.hoverable').forEach(element => {\n            element.addEventListener('mouseenter', () => {\n                tooltip.style.visibility = 'visible';\n                tooltip.textContent = element.id === 'blobby' ? 'Blobby shape - Represents flexibility' : 'Star shape - Represents focus';\n            });\n            element.addEventListener('mouseleave', () => {\n                tooltip.style.visibility = 'hidden';\n            });\n        });\n\n        document.addEventListener('mousemove', e => {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n        });\n\n        function showPopup(title, body) { \n            window.parent.postMessage({ type:'alex-popup', title, body }, '*'); \n        }\n        function hidePopup() { \n            window.parent.postMessage({ type:'alex-popup', title:null  }, '*'); \n        }\n\n        document.addEventListener('keydown', e => { \n            if(e.key === 'Escape') hidePopup(); \n        });\n\n        document.querySelectorAll('.hoverable').forEach(element => {\n            element.addEventListener('click', () => {\n                const message = element.id === 'blobby' ?\n                    \"This blobby shape illustrates fluidity and adaptability in complex systems.\" :\n                    \"This star shape signifies the idea of focus and direction in learning.\";\n                showPopup('Shape Explanation', message);\n            });\n        });\n\n        const svg = document.querySelector('svg');\n        svg.addEventListener('click', e => { \n            if(e.target === svg || e.target.tagName === 'svg') hidePopup(); \n        });\n    </script>\n</body>\n</html>",
