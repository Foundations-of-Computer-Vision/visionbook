  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        .tooltip {\n            position: fixed; \n            background: rgba(0, 0, 0, 0.55); \n            color: #fff; \n            font: 11px/1.4 sans-serif; \n            padding: 3px 8px; \n            border-radius: 4px; \n            pointer-events: none; \n            z-index: 100; \n            white-space: nowrap; \n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 600\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arrow\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"blue\"/>\n            </marker>\n        </defs>\n        \n        <!-- Edges -->\n        <line x1=\"150\" y1=\"150\" x2=\"300\" y2=\"150\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <line x1=\"300\" y1=\"150\" x2=\"450\" y2=\"150\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <line x1=\"300\" y1=\"150\" x2=\"300\" y2=\"300\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <line x1=\"300\" y1=\"300\" x2=\"150\" y2=\"450\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <line x1=\"300\" y1=\"300\" x2=\"450\" y2=\"450\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        \n        <!-- Arrows -->\n        <line x1=\"225\" y1=\"150\" x2=\"275\" y2=\"150\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arrow)\"/>\n        <line x1=\"375\" y1=\"150\" x2=\"325\" y2=\"150\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arrow)\"/>\n        <line x1=\"300\" y1=\"200\" x2=\"300\" y2=\"280\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arrow)\"/>\n        \n        <!-- Nodes -->\n        <circle cx=\"150\" cy=\"150\" r=\"27\" fill=\"#fff\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <circle cx=\"300\" cy=\"150\" r=\"27\" fill=\"#fff\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <circle cx=\"450\" cy=\"150\" r=\"27\" fill=\"#fff\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <circle cx=\"300\" cy=\"300\" r=\"27\" fill=\"#fff\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <circle cx=\"150\" cy=\"450\" r=\"27\" fill=\"#fff\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <circle cx=\"450\" cy=\"450\" r=\"27\" fill=\"#fff\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    </svg>\n    \n    <div class=\"tooltip\" id=\"tooltip\"></div>\n    \n    <script>\n        try {\n            const svg = document.querySelector('svg');\n            const tt = document.getElementById('tooltip');\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => { \n                if (e.key === 'Escape') hidePopup();\n            });\n\n            svg.addEventListener('click', e => { \n                if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n            });\n\n            document.querySelectorAll('circle').forEach(node => {\n                node.addEventListener('mouseover', function() {\n                    this.style.strokeWidth = '3';\n                    tt.textContent = 'Node: Part of the network structure';\n                    tt.style.display = 'block';\n                });\n\n                node.addEventListener('mouseout', function() {\n                    this.style.strokeWidth = '1.5';\n                    tt.style.display = 'none';\n                });\n\n                node.addEventListener('click', () => {\n                    showPopup('Node', 'This node is part of the network, allowing for data flow.');\n                });\n            });\n\n            document.querySelectorAll('line').forEach(edge => {\n                edge.addEventListener('mouseover', function() {\n                    this.style.strokeWidth = '3';\n                    tt.textContent = 'Edge: Connects nodes, representing pathways';\n                    tt.style.display = 'block';\n                });\n\n                edge.addEventListener('mouseout', function() {\n                    this.style.strokeWidth = '1.5';\n                    tt.style.display = 'none';\n                });\n\n                edge.addEventListener('click', () => {\n                    showPopup('Edge', 'The edge connects nodes, representing a potential data path.');\n                });\n            });\n\n            document.addEventListener('mousemove', function(e) {\n                tt.style.left = (e.clientX + 12) + 'px';\n                tt.style.top = (e.clientY - 28) + 'px';\n            });\n        } catch (error) {\n            console.error('Error in interactive SVG:', error);\n        }\n    </script>\n</body>\n</html>",
