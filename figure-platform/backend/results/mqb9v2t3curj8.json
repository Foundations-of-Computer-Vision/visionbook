  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .node:hover { stroke-width:3; }\n        .edge:hover { stroke-width:3; }\n        #tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.7);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            visibility: hidden;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\"></div>\n    <svg viewBox=\"0 0 600 620\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"blue\"/>\n            </marker>\n        </defs>\n        <!-- Nodes -->\n        <circle class=\"node\" cx=\"300\" cy=\"100\" r=\"27\" fill=\"white\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <circle class=\"node\" cx=\"150\" cy=\"100\" r=\"27\" fill=\"white\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <circle class=\"node\" cx=\"450\" cy=\"100\" r=\"27\" fill=\"white\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <circle class=\"node\" cx=\"300\" cy=\"240\" r=\"27\" fill=\"white\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <circle class=\"node\" cx=\"200\" cy=\"430\" r=\"27\" fill=\"white\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <circle class=\"node\" cx=\"400\" cy=\"430\" r=\"27\" fill=\"white\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <!-- Edges -->\n        <line class=\"edge\" x1=\"177\" y1=\"100\" x2=\"273\" y2=\"100\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <line class=\"edge\" x1=\"327\" y1=\"100\" x2=\"423\" y2=\"100\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <line class=\"edge\" x1=\"300\" y1=\"127\" x2=\"300\" y2=\"213\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <line class=\"edge\" x1=\"273\" y1=\"267\" x2=\"227\" y2=\"403\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <line class=\"edge\" x1=\"327\" y1=\"267\" x2=\"373\" y2=\"403\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <!-- Arrows -->\n        <line x1=\"177\" y1=\"100\" x2=\"273\" y2=\"100\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n        <line x1=\"423\" y1=\"100\" x2=\"327\" y2=\"100\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n        <line x1=\"227\" y1=\"403\" x2=\"273\" y2=\"267\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n        <line x1=\"373\" y1=\"403\" x2=\"327\" y2=\"267\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n        <!-- Text -->\n        <text font-size=\"15\" font-family=\"sans-serif\" x=\"285\" y=\"90\" text-anchor=\"middle\">root</text>\n    </svg>\n    <script>\n        document.addEventListener('mousemove', e => {\n            const tt = document.getElementById('tooltip');\n            tt.style.left = (e.clientX + 12) + 'px';\n            tt.style.top = (e.clientY - 28) + 'px';\n        });\n\n        const nodes = document.querySelectorAll('.node');\n        nodes.forEach(node => {\n            node.addEventListener('mouseover', () => {\n                const tt = document.getElementById('tooltip');\n                tt.textContent = 'Node: part of the structure';\n                tt.style.visibility = 'visible';\n            });\n            node.addEventListener('mouseout', () => {\n                const tt = document.getElementById('tooltip');\n                tt.style.visibility = 'hidden';\n            });\n            node.addEventListener('click', () => {\n                showPopup('Node', 'A node is an essential part of a network structure.');\n            });\n        });\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.addEventListener('keydown', e => {\n            if (e.key === 'Escape') hidePopup();\n        });\n        svg.addEventListener('click', e => {\n            if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n        });\n    </script>\n</body>\n</html>",
