  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none; }\n</style>\n</head>\n<body>\n<div id=\"tooltip\"></div>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 600\" preserveAspectRatio=\"xMidYMid meet\">\n  <rect x=\"30\" y=\"30\" width=\"450\" height=\"450\" stroke=\"#000\" fill=\"none\" stroke-width=\"3\"/>\n  <path d=\"M470,470 Q460,480 450,470\" stroke=\"#000\" fill=\"none\" stroke-width=\"3\"/>\n</svg>\n<script>\n  (function() {\n    const svg = document.querySelector('svg');\n    const tooltip = document.getElementById('tooltip');\n    \n    svg.addEventListener('mousemove', function(e) {\n      if (e.target.tagName === 'rect') {\n        tooltip.style.left = (e.clientX + 12) + 'px';\n        tooltip.style.top = (e.clientY - 28) + 'px';\n        tooltip.textContent = 'Rectangle: Represents the main area';\n        tooltip.style.display = 'block';\n      } else if (e.target.tagName === 'path') {\n        tooltip.style.left = (e.clientX + 12) + 'px';\n        tooltip.style.top = (e.clientY - 28) + 'px';\n        tooltip.textContent = 'Path: Represents the comma decoration';\n        tooltip.style.display = 'block';\n      } else {\n        tooltip.style.display = 'none';\n      }\n    });\n\n    svg.addEventListener('click', function(e) {\n      if (e.target.tagName === 'rect') {\n        showPopup('Rectangle', 'This is the main area in the figure.');\n      } else if (e.target.tagName === 'path') {\n        showPopup('Comma Decoration', 'This represents a comma, used for decoration.');\n      }\n    });\n\n    function showPopup(title, body) {\n      window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n    }\n\n    function hidePopup() {\n      window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n    }\n\n    document.addEventListener('keydown', function(e) {\n      if (e.key === 'Escape') hidePopup();\n    });\n\n    svg.addEventListener('click', function(e) {\n      if(e.target === svg || e.target.tagName === 'svg') hidePopup();\n    });\n  })();\n</script>\n</body>\n</html>",
