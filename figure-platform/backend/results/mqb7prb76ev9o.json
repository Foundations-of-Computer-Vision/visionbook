  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  .tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif;\n             padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; }\n</style>\n</head>\n<body>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 90\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"limegreen\"/>\n    </marker>\n  </defs>\n  <rect x=\"70\" y=\"20\" width=\"60\" height=\"50\" fill=\"#d9b384\" stroke=\"#000\" stroke-width=\"1.5\"/>\n  <rect x=\"210\" y=\"20\" width=\"60\" height=\"50\" fill=\"#d9b384\" stroke=\"#000\" stroke-width=\"1.5\"/>\n  <rect x=\"350\" y=\"20\" width=\"60\" height=\"50\" fill=\"#d9b384\" stroke=\"#000\" stroke-width=\"1.5\"/>\n  <rect x=\"490\" y=\"20\" width=\"60\" height=\"50\" fill=\"#d98080\" stroke=\"#000\" stroke-width=\"1.5\"/>\n  <text x=\"95\" y=\"50\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">f₁</text>\n  <text x=\"235\" y=\"50\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">f₂</text>\n  <text x=\"375\" y=\"50\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">f<sub>L</sub>−1</text>\n  <text x=\"510\" y=\"50\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">L</text>\n  <text x=\"30\" y=\"38\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">x₀</text>\n  <text x=\"145\" y=\"38\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">x₁</text>\n  <text x=\"285\" y=\"38\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">...</text>\n  <text x=\"425\" y=\"38\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">x<sub>L</sub>−1</text>\n  <text x=\"540\" y=\"38\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">x<sub>L</sub></text>\n  <text x=\"30\" y=\"58\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">θ₁</text>\n  <text x=\"145\" y=\"58\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">θ₂</text>\n  <text x=\"285\" y=\"58\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">...</text>\n  <text x=\"425\" y=\"58\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">θ<sub>L</sub>−1</text>\n  <text x=\"540\" y=\"58\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">θ<sub>L</sub></text>\n  <line x1=\"40\" y1=\"38\" x2=\"70\" y2=\"38\" stroke=\"limegreen\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n  <line x1=\"40\" y1=\"58\" x2=\"70\" y2=\"58\" stroke=\"limegreen\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n  <line x1=\"130\" y1=\"38\" x2=\"210\" y2=\"38\" stroke=\"limegreen\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n  <line x1=\"130\" y1=\"58\" x2=\"210\" y2=\"58\" stroke=\"limegreen\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n  <line x1=\"270\" y1=\"38\" x2=\"350\" y2=\"38\" stroke=\"limegreen\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n  <line x1=\"270\" y1=\"58\" x2=\"350\" y2=\"58\" stroke=\"limegreen\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n  <line x1=\"410\" y1=\"38\" x2=\"490\" y2=\"38\" stroke=\"limegreen\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n  <line x1=\"410\" y1=\"58\" x2=\"490\" y2=\"58\" stroke=\"limegreen\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n</svg>\n<div class=\"tooltip\" id=\"tooltip\" style=\"display:none;\"></div>\n<script>\n  try {\n    const svg = document.querySelector('svg');\n    const tooltip = document.getElementById('tooltip');\n    const elements = [\n      { selector: 'rect', name: 'Function Block', description: 'Processes input x<sub>i</sub> and parameter θ<sub>i</sub>.', color: '#c8f0c8' },\n      { selector: 'line', name: 'Connection', description: 'Transfers output from one function to the next.', color: '#c8e0ff' },\n    ];\n\n    function showPopup(title, body) { window.parent.postMessage({ type: 'alex-popup', title, body }, '*'); }\n    function hidePopup() { window.parent.postMessage({ type: 'alex-popup', title: null }, '*'); }\n    document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n    svg.addEventListener('click', e => { if (e.target === svg || e.target.tagName === 'svg') hidePopup(); });\n\n    document.addEventListener('mousemove', e => {\n      tooltip.style.left = (e.clientX + 12) + 'px';\n      tooltip.style.top = (e.clientY - 28) + 'px';\n    });\n\n    elements.forEach(({ selector, name, description, color }, index) => {\n      svg.querySelectorAll(selector).forEach(el => {\n        el.addEventListener('mouseenter', () => {\n          el.style.strokeWidth = 3;\n          el.style.stroke = color;\n          tooltip.style.display = 'block';\n          tooltip.innerHTML = `<strong>${name}</strong><br>${description}`;\n        });\n        el.addEventListener('mouseleave', () => {\n          el.style.strokeWidth = 1.5;\n          el.style.stroke = '#000';\n          tooltip.style.display = 'none';\n        });\n        el.addEventListener('click', () => {\n          showPopup(name, description);\n        });\n      });\n    });\n  } catch (e) { console.error(e); }\n</script>\n</body>\n</html>",
