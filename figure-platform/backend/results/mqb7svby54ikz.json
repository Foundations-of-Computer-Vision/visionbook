  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  .tooltip {\n    position: fixed;\n    background: rgba(0, 0, 0, 0.75);\n    color: #fff;\n    font: 11px sans-serif;\n    padding: 3px 8px;\n    border-radius: 4px;\n    pointer-events: none;\n    z-index: 100;\n    white-space: nowrap;\n    visibility: hidden;\n  }\n</style>\n</head>\n<body>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 400\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n    </marker>\n  </defs>\n  <!-- Derivative Matrix -->\n  <rect x=\"100\" y=\"150\" width=\"90\" height=\"120\" fill=\"#ffd75d\" stroke=\"#333\" stroke-width=\"3\"/>\n  <!-- Input Vector -->\n  <rect x=\"300\" y=\"130\" width=\"30\" height=\"120\" fill=\"#8add78\" stroke=\"#333\" stroke-width=\"3\"/>\n  <!-- Output Gradient Vector -->\n  <rect x=\"350\" y=\"130\" width=\"120\" height=\"30\" fill=\"#f06767\" stroke=\"#333\" stroke-width=\"3\"/>\n  \n  <!-- Labels -->\n  <text x=\"130\" y=\"100\" font-size=\"20\" font-family=\"serif\" text-anchor=\"middle\">∂J</text>\n  <text x=\"135\" y=\"120\" font-size=\"20\" font-family=\"serif\" text-anchor=\"middle\">∂W</text>\n  <text x=\"240\" y=\"190\" font-size=\"20\" font-family=\"serif\" text-anchor=\"middle\">=</text>\n  <text x=\"320\" y=\"100\" font-size=\"20\" font-family=\"serif\" font-weight=\"bold\" text-anchor=\"middle\">x</text>\n  <text x=\"324\" y=\"120\" font-size=\"12\" font-family=\"serif\" font-weight=\"bold\" text-anchor=\"middle\">in</text>\n  <text x=\"420\" y=\"100\" font-size=\"20\" font-family=\"serif\" font-weight=\"bold\" text-anchor=\"middle\">g</text>\n  <text x=\"424\" y=\"120\" font-size=\"12\" font-family=\"serif\" font-weight=\"bold\" text-anchor=\"middle\">out</text>\n</svg>\n<div class=\"tooltip\" id=\"tooltip\"></div>\n<script>\n  const svg = document.querySelector('svg');\n  const tooltip = document.getElementById('tooltip');\n  const elements = [\n    {selector: 'rect:nth-of-type(1)', title: '∂J/∂W', desc: 'Represents the derivative matrix ∂J/∂W.'},\n    {selector: 'rect:nth-of-type(2)', title: 'x_in', desc: 'This is the input vector, x_in.'},\n    {selector: 'rect:nth-of-type(3)', title: 'g_out', desc: 'This represents the output gradient vector, g_out.'}\n  ];\n\n  elements.forEach(el => {\n    const element = svg.querySelector(el.selector);\n    element.addEventListener('mouseenter', () => {\n      tooltip.textContent = el.title;\n      tooltip.style.visibility = 'visible';\n      element.style.strokeWidth = '4.5';\n    });\n\n    element.addEventListener('mouseleave', () => {\n      tooltip.style.visibility = 'hidden';\n      element.style.strokeWidth = '3';\n    });\n    \n    element.addEventListener('mousemove', e => {\n      tooltip.style.left = (e.clientX + 12) + 'px';\n      tooltip.style.top = (e.clientY - 28) + 'px';\n    });\n\n    element.addEventListener('click', () => showPopup(el.title, el.desc));\n  });\n\n  function showPopup(title, body) {\n    window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n  }\n  \n  function hidePopup() {\n    window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n  }\n\n  document.addEventListener('keydown', e => {\n    if (e.key === 'Escape') hidePopup();\n  });\n\n  svg.addEventListener('click', e => {\n    if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n  });\n</script>\n</body>\n</html>",
