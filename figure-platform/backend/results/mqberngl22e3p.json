  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #fff; }\n        #tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n<div id=\"tooltip\"></div>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 150\" preserveAspectRatio=\"xMidYMid meet\">\n    <defs>\n        <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n            <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n        </marker>\n    </defs>\n    <rect x=\"180\" y=\"35\" width=\"240\" height=\"80\" fill=\"#ccc\" stroke=\"#000\" stroke-width=\"1.5\"></rect>\n    <text x=\"210\" y=\"77\" font-size=\"21\" font-family=\"sans-serif\" font-weight=\"bold\" fill=\"#000\">Learning from a teacher</text>\n    <text x=\"20\" y=\"77\" font-size=\"21\" font-family=\"serif\" font-style=\"italic\" fill=\"#000\">&#123;x<sup>(i)</sup>&#125;<sup>N</sup><sub>i=1</sub></text>\n    <text x=\"50\" y=\"105\" font-size=\"21\" font-family=\"serif\" font-style=\"italic\" fill=\"#000\">t: &#120;</text>\n    <text x=\"80\" y=\"105\" font-size=\"21\" font-family=\"Arial\" font-style=\"italic\" fill=\"#000\">&#8594;</text>\n    <text x=\"110\" y=\"105\" font-size=\"21\" font-family=\"serif\" font-style=\"italic\" fill=\"#000\">&#120;</text>\n    <line x1=\"160\" y1=\"75\" x2=\"180\" y2=\"75\" stroke=\"#000\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    <line x1=\"420\" y1=\"75\" x2=\"440\" y2=\"75\" stroke=\"#000\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    <text x=\"460\" y=\"77\" font-size=\"21\" font-family=\"serif\" font-style=\"italic\" fill=\"#000\">f<sub>&#952;</sub></text>\n</svg>\n<script>\n    document.querySelector('svg').addEventListener('mousemove', function(e) {\n        let target = e.target;\n        let tooltip = document.getElementById('tooltip');\n\n        if (target.nodeName === 'rect') {\n            tooltip.textContent = \"Teaching process\";\n            tooltip.style.display = 'block';\n        } else if (target.nodeName === 'text' && target.textContent.includes('Learning')) {\n            tooltip.textContent = \"Central learning component\";\n            tooltip.style.display = 'block';\n        } else {\n            tooltip.style.display = 'none';\n        }\n        tooltip.style.left = (e.clientX + 12) + 'px';\n        tooltip.style.top = (e.clientY - 28) + 'px';\n    });\n\n    document.querySelector('svg').addEventListener('click', function(e) {\n        let target = e.target;\n        \n        try {\n            if (target.nodeName === 'rect') {\n                showPopup(\"Teaching Component\", \"This represents the process of learning from a teacher which maps inputs to outputs.\");\n            } else if (target.nodeName === 'text' && target.textContent.includes('f')) {\n                showPopup(\"Function Output\", \"This represents the learned function, the result of the teaching process.\");\n            }\n        } catch (error) {\n            console.error(\"Error in popup logic: \", error);\n        }\n    });\n\n    function showPopup(title, body) {\n        window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n    }\n    \n    function hidePopup() {\n        window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n    }\n\n    document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n    document.querySelector('svg').addEventListener('click', e => { if (e.target === svg || e.target.tagName === 'svg') hidePopup(); });\n</script>\n</body>\n</html>",
