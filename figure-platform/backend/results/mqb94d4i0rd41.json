  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .hoverable:hover { stroke-width:3; cursor:pointer; }\n        .tooltip {\n            position:fixed;\n            background:rgba(0,0,0,0.55);\n            color:#fff;\n            font:11px/1.4 sans-serif;\n            padding:3px 8px;\n            border-radius:4px;\n            pointer-events:none;\n            z-index:100;\n            white-space:nowrap;\n            display:none;\n        }\n        .active { fill:#c8e0ff; }\n    </style>\n</head>\n<body>\n    <svg viewBox=\"0 0 600 150\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n\n        <!-- Nodes and Labels -->\n        <text x=\"70\" y=\"75\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">ℓ(x, y)</text>\n        <rect x=\"150\" y=\"30\" width=\"120\" height=\"90\" fill=\"none\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <text x=\"210\" y=\"75\" font-size=\"18\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\" pointer-events=\"none\">(∂/∂x, ∂/∂y)</text>\n        <text x=\"470\" y=\"75\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" dominant-baseline=\"middle\">(ℓ<sub>x</sub>(x, y), ℓ<sub>y</sub>(x, y))</text>\n\n        <!-- Edges and Arrows -->\n        <line x1=\"100\" y1=\"75\" x2=\"150\" y2=\"75\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"hoverable\"/>\n        <line x1=\"270\" y1=\"75\" x2=\"420\" y2=\"75\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"hoverable\"/>\n\n    </svg>\n\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n\n    <script>\n        try {\n            const tooltip = document.getElementById('tooltip');\n            \n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            document.querySelectorAll('.hoverable').forEach(el => {\n                el.addEventListener('mouseover', () => {\n                    tooltip.textContent = \"Edge: represents a transformation\";\n                    tooltip.style.display = 'block';\n                });\n                el.addEventListener('mouseout', () => {\n                    tooltip.style.display = 'none';\n                });\n                el.addEventListener('click', () => {\n                    showPopup(\"Edge Transformation\", \"This edge represents the application of derivatives to transform the initial function.\");\n                });\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') hidePopup();\n            });\n\n            document.querySelector('svg').addEventListener('click', e => {\n                if (e.target === e.currentTarget) hidePopup();\n            });\n        } catch (e) {\n            console.error(e);\n        }\n    </script>\n</body>\n</html>",
