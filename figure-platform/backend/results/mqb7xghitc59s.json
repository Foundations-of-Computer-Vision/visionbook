  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Graph</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n        .point:hover { opacity: 0.7; }\n    </style>\n</head>\n<body>\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n    <svg viewBox=\"0 0 600 350\" preserveAspectRatio=\"xMidYMid meet\">\n        <line x1=\"50\" y1=\"250\" x2=\"550\" y2=\"250\" stroke=\"black\" stroke-width=\"1.5\"/>\n        <line x1=\"300\" y1=\"50\" x2=\"300\" y2=\"250\" stroke=\"black\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <text x=\"280\" y=\"40\" font-size=\"16\" font-family=\"serif\">&#9474;Box&#8321; [u]&#9474;</text>\n        <text x=\"560\" y=\"255\" font-size=\"16\" font-family=\"serif\">u</text>\n        <text x=\"40\" y=\"255\" font-size=\"16\" font-family=\"serif\">-10</text>\n        <text x=\"540\" y=\"255\" font-size=\"16\" font-family=\"serif\">10</text>\n        <text x=\"310\" y=\"160\" font-size=\"12\" font-family=\"serif\">1</text>\n        <text x=\"310\" y=\"110\" font-size=\"12\" font-family=\"serif\">2</text>\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <g fill=\"blue\" stroke=\"blue\" stroke-width=\"1.5\">\n            <!-- Dots and Bars -->\n            ${[-10, -8, -6, -4, -2, 0, 2, 4, 6, 8, 10].map((x, i) => {\n                const height = [0, 1.5, 2.6, 3.2, 3.9, 4.5, 3.9, 3.2, 2.6, 1.5, 0][i] * 40;\n                return `\n                <line x1=\"${x * 25 + 300}\" y1=\"250\" x2=\"${x * 25 + 300}\" y2=\"${250 - height}\" stroke=\"#00f\" />\n                <circle class=\"point\" cx=\"${x * 25 + 300}\" cy=\"${250 - height}\" r=\"6\" data-value=\"${height}\"/>\n                `;\n            }).join('')}\n        </g>\n    </svg>\n    <script>\n        const tooltip = document.getElementById('tooltip');\n        document.querySelectorAll('.point').forEach(point => {\n            point.addEventListener('mouseenter', (e) => {\n                tooltip.style.display = 'block';\n                tooltip.textContent = 'Value: ' + e.target.dataset.value;\n            });\n            point.addEventListener('mouseleave', () => {\n                tooltip.style.display = 'none';\n            });\n        });\n\n        document.addEventListener('mousemove', (e) => {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n        });\n\n        try {\n            document.querySelectorAll('.point').forEach(point => {\n                point.addEventListener('click', (e) => {\n                    showPopup(\"Point Value\", \"This point represents a value of \" + e.target.dataset.value);\n                });\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', (e) => {\n                if (e.key === 'Escape') hidePopup();\n            });\n\n            const svg = document.querySelector('svg');\n            svg.addEventListener('click', (e) => {\n                if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n            });\n        } catch (err) {\n            console.error(err);\n        }\n    </script>\n</body>\n</html>",
