  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Delta Function</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip {\n            position: fixed;\n            background: rgba(0,0,0,0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\"></div>\n    <svg id=\"svg\" width=\"100%\" height=\"100%\" viewBox=\"0 0 600 400\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <line x1=\"50\" y1=\"200\" x2=\"550\" y2=\"200\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"300\" y1=\"350\" x2=\"300\" y2=\"50\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        \n        <line x1=\"300\" y1=\"200\" x2=\"300\" y2=\"100\" stroke=\"blue\" stroke-width=\"5\"/>\n\n        <text x=\"290\" y=\"90\" font-size=\"14\" font-family=\"sans-serif\" fill=\"#333\">&#948;[n]</text>\n        <text x=\"315\" y=\"60\" font-size=\"14\" font-family=\"sans-serif\" fill=\"#333\" transform=\"rotate(-90 315,60)\">n</text>\n        \n        <circle cx=\"150\" cy=\"200\" r=\"6\" fill=\"blue\"/>\n        <circle cx=\"210\" cy=\"200\" r=\"6\" fill=\"blue\"/>\n        <circle cx=\"270\" cy=\"200\" r=\"6\" fill=\"blue\"/>\n        <circle cx=\"300\" cy=\"100\" r=\"6\" fill=\"blue\"/>\n        <circle cx=\"330\" cy=\"200\" r=\"6\" fill=\"blue\"/>\n        <circle cx=\"390\" cy=\"200\" r=\"6\" fill=\"blue\"/>\n        <circle cx=\"450\" cy=\"200\" r=\"6\" fill=\"blue\"/>\n\n        <text x=\"145\" y=\"220\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">−4</text>\n        <text x=\"205\" y=\"220\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">−2</text>\n        <text x=\"270\" y=\"180\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">1</text>\n        <text x=\"265\" y=\"210\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">0.5</text>\n        <text x=\"295\" y=\"220\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">0</text>\n        <text x=\"205\" y=\"235\" font-size=\"11\" font-family=\"sans-serif\" fill=\"#333\">n</text>\n        <text x=\"325\" y=\"220\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">2</text>\n        <text x=\"385\" y=\"220\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">4</text>\n\n    </svg>\n    <script>\n        try {\n            const svg = document.getElementById('svg');\n            const tooltip = document.getElementById('tooltip');\n\n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY + 12) + 'px';\n            });\n\n            svg.querySelectorAll('circle').forEach(circle => {\n                circle.addEventListener('mouseenter', e => {\n                    tooltip.innerHTML = `Position ${e.target.cx.baseVal.value - 300}`;\n                    tooltip.style.display = 'block';\n                    e.target.style.opacity = '0.7';\n                });\n\n                circle.addEventListener('mouseleave', e => {\n                    tooltip.style.display = 'none';\n                    e.target.style.opacity = '1';\n                });\n\n                circle.addEventListener('click', e => {\n                    showPopup('Delta Function', 'The delta function, shown as δ[n], is only non-zero at n = 0, and has a value of 1 at that point.');\n                });\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') hidePopup();\n            });\n\n            svg.addEventListener('click', e => {\n                if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n            });\n\n        } catch (e) {\n            console.error(e);\n        }\n    </script>\n</body>\n</html>",
