  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #fff; }\n        svg { width: 100%; height: 100%; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            visibility: hidden;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\" class=\"tooltip\"></div>\n    <svg viewBox=\"0 0 600 200\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n            </marker>\n        </defs>\n        <text x=\"50\" y=\"100\" font-size=\"16\" font-family=\"sans-serif\" text-anchor=\"middle\">\n            Small dataset\n        </text>\n        <text x=\"550\" y=\"100\" font-size=\"16\" font-family=\"sans-serif\" text-anchor=\"middle\">\n            Big dataset\n        </text>\n        <text x=\"150\" y=\"80\" font-size=\"14\" font-family=\"sans-serif\" text-anchor=\"middle\">\n            {<tspan x=\"150\" dy=\"1.2em\">x<sup>i</sup>, y<sup>i</sup></tspan>}<tspan dy=\"-1.2em\" dx=\"10\">{<tspan font-size=\"9\" baseline-shift=\"super\">N</tspan>}<tspan dx=\"-24\">i=1</tspan>\n        </text>\n        <text x=\"450\" y=\"80\" font-size=\"14\" font-family=\"sans-serif\" text-anchor=\"middle\">\n            {<tspan x=\"450\" dy=\"1.2em\">x<sup>i</sup>, y<sup>i</sup></tspan>}<tspan dy=\"-1.2em\" dx=\"10\">{<tspan font-size=\"9\" baseline-shift=\"super\">MN</tspan>}<tspan dx=\"-20\">i=1</tspan>\n        </text>\n        <rect x=\"240\" y=\"55\" width=\"120\" height=\"90\" stroke=\"#000\" fill=\"lightgrey\"/>\n        <text x=\"300\" y=\"110\" font-size=\"14\" font-family=\"sans-serif\" text-anchor=\"middle\">\n            Data augmentation\n        </text>\n        <line x1=\"180\" y1=\"100\" x2=\"240\" y2=\"100\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"360\" y1=\"100\" x2=\"420\" y2=\"100\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    </svg>\n    <script>\n        try {\n            const tooltip = document.getElementById('tooltip');\n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            document.querySelectorAll('text, line').forEach(el => {\n                el.addEventListener('mouseenter', () => {\n                    if (el.tagName === 'text') {\n                        tooltip.textContent = el.textContent.trim() + ' (Explanation)';\n                    } else {\n                        tooltip.textContent = 'Arrow (Direction of data flow)';\n                    }\n                    tooltip.style.visibility = 'visible';\n                    el.style.strokeWidth = '3';\n                });\n                \n                el.addEventListener('mouseleave', () => {\n                    tooltip.style.visibility = 'hidden';\n                    el.style.strokeWidth = '1.5';\n                });\n\n                el.addEventListener('click', () => {\n                    showPopup(el.textContent.trim(), 'This element represents a key concept in data augmentation.');\n                });\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n            document.querySelector('svg').addEventListener('click', e => {\n                if (e.target.tagName === 'svg') hidePopup();\n            });\n        } catch (e) {\n            console.error(\"Error in interactivity script:\", e);\n        }\n    </script>\n</body>\n</html>",
