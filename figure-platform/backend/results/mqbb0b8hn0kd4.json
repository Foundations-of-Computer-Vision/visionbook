  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff;}\n        svg { width:100%; height:100%; }\n        .hover { transition: stroke-width 0.2s ease; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.7);\n            color: white;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            font: 11px sans-serif;\n            white-space: nowrap;\n            z-index: 100;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\" class=\"tooltip\"></div>\n    <svg viewBox=\"0 0 600 400\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arrow\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n            </marker>\n        </defs>\n        \n        <!-- Lens -->\n        <path d=\"M290,150 Q300,100 310,150 Q300,200 290,150\" fill=\"none\" stroke=\"#000\" stroke-width=\"2\" />\n\n        <!-- Light Rays -->\n        <line x1=\"0\" y1=\"160\" x2=\"290\" y2=\"160\" stroke=\"blue\" stroke-width=\"2\" />\n        <line x1=\"290\" y1=\"160\" x2=\"600\" y2=\"220\" stroke=\"blue\" stroke-width=\"2\" />\n        <line x1=\"0\" y1=\"200\" x2=\"600\" y2=\"200\" stroke=\"blue\" stroke-width=\"2\" />\n\n        <!-- Dashed Rays -->\n        <line x1=\"290\" y1=\"160\" x2=\"270\" y2=\"180\" stroke=\"blue\" stroke-width=\"2\" stroke-dasharray=\"8\" />\n        <line x1=\"270\" y1=\"180\" x2=\"270\" y2=\"200\" stroke=\"blue\" stroke-width=\"2\" stroke-dasharray=\"8\" />\n\n        <!-- Point -->\n        <circle cx=\"270\" cy=\"180\" r=\"5\" fill=\"blue\" />\n\n    </svg>\n\n    <script>\n        const svg = document.querySelector('svg');\n        const tooltip = document.getElementById('tooltip');\n        \n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.addEventListener('mousemove', e => {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n            tooltip.style.display = 'none';\n        });\n\n        document.querySelectorAll('line, circle').forEach(el => {\n            el.addEventListener('mouseenter', () => {\n                tooltip.textContent = el.tagName === 'circle' ? 'Focal Point: Light converges here.' : 'Light Ray: Path of light through the lens.';\n                tooltip.style.display = 'block';\n                el.classList.add('hover');\n            });\n            el.addEventListener('mouseleave', () => {\n                tooltip.style.display = 'none';\n                el.classList.remove('hover');\n            });\n            el.addEventListener('click', () => {\n                showPopup('Optics Diagram', 'This diagram shows how light behaves through a concave lens. The dashed lines represent the virtual rays diverged from the lens.');\n            });\n        });\n\n        document.addEventListener('keydown', e => {\n            if (e.key === 'Escape') hidePopup();\n        });\n\n        svg.addEventListener('click', e => {\n            if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n        });\n    </script>\n</body>\n</html>",
