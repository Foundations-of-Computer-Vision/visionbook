  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; }\n    </style>\n</head>\n<body>\n<div id=\"tooltip\" style=\"display:none;\"></div>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 200\" preserveAspectRatio=\"xMidYMid meet\">\n    <defs>\n        <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n            <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n        </marker>\n    </defs>\n    <line id=\"edge1\" x1=\"150\" y1=\"100\" x2=\"250\" y2=\"100\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    <rect id=\"node1\" x=\"250\" y=\"50\" width=\"100\" height=\"100\" fill=\"none\" stroke=\"#333\" stroke-width=\"1.5\"/>\n    <line id=\"edge2\" x1=\"350\" y1=\"100\" x2=\"450\" y2=\"100\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    <text x=\"120\" y=\"105\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">ℓ</text>\n    <text x=\"295\" y=\"105\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">↓</text>\n    <text x=\"307\" y=\"105\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">k</text>\n    <text x=\"470\" y=\"105\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">ℓ</text>\n    <text x=\"485\" y=\"105\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">↓</text>\n    <text x=\"497\" y=\"105\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#333\">k</text>\n</svg>\n<script>\n    const tooltip = document.getElementById('tooltip');\n\n    function showPopup(title, body) {\n        window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n    }\n\n    function hidePopup() {\n        window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n    }\n\n    document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n\n    document.querySelector('svg').addEventListener('click', e => {\n        if (e.target.tagName === 'svg') hidePopup();\n    });\n\n    document.querySelectorAll('#edge1, #edge2, #node1').forEach(el => {\n        el.addEventListener('mouseenter', () => {\n            tooltip.style.display = 'block';\n            tooltip.textContent = el.id === 'node1' ? 'Node: Performs operation k' : 'Edge: Transfers signal ℓ';\n        });\n        el.addEventListener('mouseleave', () => {\n            tooltip.style.display = 'none';\n        });\n        el.addEventListener('click', () => {\n            if (el.id === 'node1') {\n                showPopup('Node Information', 'This node represents the operation k, which transforms input signal ℓ into output.');\n            } else {\n                showPopup('Edge Information', 'This edge transfers the signal ℓ between nodes.');\n            }\n        });\n    });\n\n    document.addEventListener('mousemove', e => {\n        tooltip.style.left = (e.clientX + 12) + 'px';\n        tooltip.style.top = (e.clientY - 28) + 'px';\n    });\n</script>\n</body>\n</html>",
