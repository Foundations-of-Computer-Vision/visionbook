  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  svg { width:100%; height:100%; }\n  #tooltip {\n    position: fixed;\n    background: rgba(0, 0, 0, 0.55);\n    color: #fff;\n    font: 11px/1.4 sans-serif;\n    padding: 3px 8px;\n    border-radius: 4px;\n    pointer-events: none;\n    z-index: 100;\n    white-space: nowrap;\n    display: none;\n  }\n</style>\n</head>\n<body>\n<div id=\"tooltip\"></div>\n<svg viewBox=\"0 0 600 120\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n    </marker>\n  </defs>\n\n  <!-- Input Signal -->\n  <text x=\"70\" y=\"65\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#000\" text-anchor=\"middle\">δ[n]</text>\n  <line x1=\"90\" y1=\"60\" x2=\"140\" y2=\"60\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n\n  <!-- System Block -->\n  <rect x=\"140\" y=\"30\" width=\"100\" height=\"60\" fill=\"none\" stroke=\"#333\" stroke-width=\"1.5\"/>\n  <text x=\"190\" y=\"65\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#000\" text-anchor=\"middle\">h[n]</text>\n\n  <!-- Output Signal -->\n  <line x1=\"240\" y1=\"60\" x2=\"290\" y2=\"60\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n  <text x=\"310\" y=\"65\" font-size=\"12\" font-family=\"sans-serif\" fill=\"#000\" text-anchor=\"middle\">h[n]</text>\n</svg>\n\n<script>\n  const svg = document.querySelector('svg');\n  const tt = document.getElementById('tooltip');\n\n  function showTooltip(evt, text) {\n    tt.textContent = text;\n    tt.style.left = (evt.clientX + 12) + 'px';\n    tt.style.top = (evt.clientY - 28) + 'px';\n    tt.style.display = 'block';\n  }\n\n  function hideTooltip() {\n    tt.style.display = 'none';\n  }\n\n  function showPopup(title, body) {\n    window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n  }\n\n  function hidePopup() {\n    window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n  }\n\n  document.addEventListener('keydown', e => {\n    if (e.key === 'Escape') hidePopup();\n  });\n\n  svg.addEventListener('click', e => {\n    if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n  });\n\n  svg.querySelectorAll('line').forEach(line => {\n    line.addEventListener('mouseenter', e => showTooltip(e, 'Signal Flow'));\n    line.addEventListener('mouseleave', hideTooltip);\n    line.addEventListener('click', () => showPopup('Signal Flow', 'This line represents the flow of the signal through the system.'));\n  });\n\n  svg.querySelector('rect').addEventListener('mouseenter', e => showTooltip(e, 'System Block: h[n]'));\n  svg.querySelector('rect').addEventListener('mouseleave', hideTooltip);\n  svg.querySelector('rect').addEventListener('click', () => showPopup('System Block', 'This block represents the system h[n] which processes the input signal.'));\n</script>\n</body>\n</html>",
