  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Interactive Figure</title>\n    <style>\n        html, body { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #fff; }\n        svg { width: 100%; height: 100%; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\" class=\"tooltip\"></div>\n    <svg viewBox=\"0 0 600 194\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arrow\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n            </marker>\n        </defs>\n        <rect x=\"100\" y=\"36\" width=\"400\" height=\"122\" fill=\"#deb887\" stroke=\"#000\" stroke-width=\"1.5\"></rect>\n        <text x=\"300\" y=\"24\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\">pixel2ray</text>\n        <text x=\"300\" y=\"76\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\">\n            O = O<sub>cam</sub>\n        </text>\n        <text x=\"300\" y=\"106\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\">\n            Ṽ = K<sup>-1</sup><sub>cam</sub> * [n, m, 1]<sup>T</sup> - O<sub>cam</sub>\n        </text>\n        <text x=\"300\" y=\"136\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\">\n            D = Ṽ / &#8741;Ṽ&#8741;<sub>2</sub>\n        </text>\n        <text x=\"60\" y=\"98\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" id=\"nmLabel\">n, m</text>\n        <line x1=\"75\" y1=\"98\" x2=\"100\" y2=\"98\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arrow)\"></line>\n        <text x=\"540\" y=\"98\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" id=\"odLabel\">O, D</text>\n        <line x1=\"500\" y1=\"98\" x2=\"525\" y2=\"98\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arrow)\"></line>\n    </svg>\n    <script>\n        const tooltip = document.getElementById('tooltip');\n        const nmLabel = document.getElementById('nmLabel');\n        const odLabel = document.getElementById('odLabel');\n        const svg = document.querySelector('svg');\n\n        function showTooltip(text, event) {\n            tooltip.textContent = text;\n            tooltip.style.display = 'block';\n            tooltip.style.left = (event.clientX + 12) + 'px';\n            tooltip.style.top = (event.clientY - 28) + 'px';\n        }\n\n        function hideTooltip() {\n            tooltip.style.display = 'none';\n        }\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        nmLabel.addEventListener('mouseenter', (e) => showTooltip('Input pixel coordinates (n, m)', e));\n        nmLabel.addEventListener('mouseleave', hideTooltip);\n        odLabel.addEventListener('mouseenter', (e) => showTooltip('Output origin O and direction D', e));\n        odLabel.addEventListener('mouseleave', hideTooltip);\n\n        nmLabel.addEventListener('click', () => showPopup('Input n, m', 'These are the pixel coordinates used as the input for the pixel2ray computation.'));\n        odLabel.addEventListener('click', () => showPopup('Output O, D', 'These are the resulting origin and normalized direction vector from the pixel2ray computation.'));\n\n        svg.addEventListener('click', (e) => { if (e.target === svg || e.target.tagName === 'svg') hidePopup(); });\n\n        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') hidePopup(); });\n    </script>\n</body>\n</html>",
