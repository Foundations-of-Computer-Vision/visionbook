  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  svg { width:100%; height:100%; }\n  .tooltip {\n    position: fixed;\n    background: rgba(0, 0, 0, 0.55);\n    color: #fff;\n    font: 11px/1.4 sans-serif;\n    padding: 3px 8px;\n    border-radius: 4px;\n    pointer-events: none;\n    z-index: 100;\n    white-space: nowrap;\n    display: none;\n  }\n</style>\n</head>\n<body>\n<div class=\"tooltip\" id=\"tooltip\"></div>\n<svg viewBox=\"0 0 600 350\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#000\"/>\n    </marker>\n  </defs>\n  <!-- Axes -->\n  <line x1=\"50\" y1=\"300\" x2=\"550\" y2=\"300\" stroke=\"#000\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n  <line x1=\"300\" y1=\"330\" x2=\"300\" y2=\"20\" stroke=\"#000\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n  \n  <!-- Stem Plot Lines and Points -->\n  <line x1=\"120\" y1=\"300\" x2=\"120\" y2=\"240\" stroke=\"blue\" stroke-width=\"1.5\"/>\n  <circle cx=\"120\" cy=\"240\" r=\"5\" fill=\"blue\" class=\"stem\" data-info=\"Value: 3\"/>\n  <line x1=\"180\" y1=\"300\" x2=\"180\" y2=\"260\" stroke=\"blue\" stroke-width=\"1.5\"/>\n  <circle cx=\"180\" cy=\"260\" r=\"5\" fill=\"blue\" class=\"stem\" data-info=\"Value: 2\"/>\n  <line x1=\"240\" y1=\"300\" x2=\"240\" y2=\"280\" stroke=\"blue\" stroke-width=\"1.5\"/>\n  <circle cx=\"240\" cy=\"280\" r=\"5\" fill=\"blue\" class=\"stem\" data-info=\"Value: 1\"/>\n  <line x1=\"300\" y1=\"300\" x2=\"300\" y2=\"220\" stroke=\"blue\" stroke-width=\"1.5\"/>\n  <circle cx=\"300\" cy=\"220\" r=\"5\" fill=\"blue\" class=\"stem\" data-info=\"Value: 4\"/>\n  <line x1=\"360\" y1=\"300\" x2=\"360\" y2=\"300\" stroke=\"blue\" stroke-width=\"1.5\"/>\n  <circle cx=\"360\" cy=\"300\" r=\"5\" fill=\"blue\" class=\"stem\" data-info=\"Value: 0\"/>\n  <line x1=\"420\" y1=\"300\" x2=\"420\" y2=\"280\" stroke=\"blue\" stroke-width=\"1.5\"/>\n  <circle cx=\"420\" cy=\"280\" r=\"5\" fill=\"blue\" class=\"stem\" data-info=\"Value: 1\"/>\n  <line x1=\"480\" y1=\"300\" x2=\"480\" y2=\"220\" stroke=\"blue\" stroke-width=\"1.5\"/>\n  <circle cx=\"480\" cy=\"220\" r=\"5\" fill=\"blue\" class=\"stem\" data-info=\"Value: 4\"/>\n  <line x1=\"540\" y1=\"300\" x2=\"540\" y2=\"300\" stroke=\"blue\" stroke-width=\"1.5\"/>\n  <circle cx=\"540\" cy=\"300\" r=\"5\" fill=\"blue\" class=\"stem\" data-info=\"Value: 0\"/>\n\n  <!-- Labels -->\n  <text x=\"580\" y=\"315\" font-size=\"12\" font-family=\"sans-serif\">n</text>\n  <text x=\"310\" y=\"30\" font-size=\"12\" font-family=\"sans-serif\" transform=\"rotate(-90 300,30)\">ℓ[n]</text>\n  \n  <!-- Tick Marks and Values -->\n  <line x1=\"295\" y1=\"220\" x2=\"305\" y2=\"220\" stroke=\"#000\" stroke-width=\"1.5\"/>\n  <text x=\"310\" y=\"225\" font-size=\"12\" font-family=\"sans-serif\">4</text>\n  <line x1=\"295\" y1=\"260\" x2=\"305\" y2=\"260\" stroke=\"#000\" stroke-width=\"1.5\"/>\n  <text x=\"310\" y=\"265\" font-size=\"12\" font-family=\"sans-serif\">2</text>\n  \n</svg>\n\n<script>\n  const tooltip = document.getElementById('tooltip');\n\n  document.querySelectorAll('.stem').forEach(elem => {\n    elem.addEventListener('mouseenter', (e) => {\n      const info = e.target.getAttribute('data-info');\n      tooltip.textContent = info;\n      tooltip.style.display = 'block';\n    });\n    \n    elem.addEventListener('mouseleave', () => {\n      tooltip.style.display = 'none';\n    });\n\n    elem.addEventListener('click', (e) => {\n      const info = e.target.getAttribute('data-info');\n      showPopup('Stem Value', `This point represents a value of ${info.split(':')[1].trim()}.`);\n    });\n  });\n\n  document.addEventListener('mousemove', (e) => {\n    tooltip.style.left = (e.clientX + 12) + 'px';\n    tooltip.style.top = (e.clientY - 28) + 'px';\n  });\n\n  function showPopup(title, body) {\n    window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n  }\n\n  function hidePopup() {\n    window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n  }\n\n  document.addEventListener('keydown', (e) => {\n    if (e.key === 'Escape') hidePopup();\n  });\n\n  document.querySelector('svg').addEventListener('click', (e) => {\n    if (e.target === e.currentTarget || e.target.tagName === 'svg') hidePopup();\n  });\n</script>\n</body>\n</html>",
