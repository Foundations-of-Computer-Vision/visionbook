  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 348\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n\n        <!-- Draw the main rectangle -->\n        <rect x=\"105\" y=\"87\" width=\"330\" height=\"174\" fill=\"#d7b383\" stroke=\"#333\" stroke-width=\"1.5\"></rect>\n\n        <!-- Text labels inside the rectangle -->\n        <text x=\"120\" y=\"112\" font-size=\"14\" font-family=\"serif\" font-weight=\"bold\" fill=\"#333\">L = f′(x<sub>in</sub>, θ)</text>\n        <text x=\"120\" y=\"162\" font-size=\"14\" font-family=\"serif\" font-weight=\"bold\" fill=\"#333\">g<sub>in</sub> = g<sub>out</sub>L<sup>x</sup></text>\n        <text x=\"120\" y=\"212\" font-size=\"14\" font-family=\"serif\" font-weight=\"bold\" fill=\"#333\">∂J/∂θ = g<sub>out</sub>L<sup>θ</sup></text>\n\n        <!-- External inputs -->\n        <text x=\"10\" y=\"120\" font-size=\"14\" font-family=\"serif\" font-weight=\"bold\">x<sub>in</sub>, θ</text>\n        <text x=\"10\" y=\"171\" font-size=\"14\" font-family=\"serif\" font-weight=\"bold\">g<sub>in</sub></text>\n        <text x=\"475\" y=\"171\" font-size=\"14\" font-family=\"serif\" font-weight=\"bold\">g<sub>out</sub></text>\n\n        <!-- External output -->\n        <rect x=\"55\" y=\"220\" width=\"45\" height=\"45\" fill=\"#ffe37f\" stroke=\"#333\" stroke-width=\"1.5\"></rect>\n        <text x=\"61\" y=\"250\" font-size=\"14\" font-family=\"serif\" font-weight=\"bold\">∂J/∂θ</text>\n\n        <!-- Arrows -->\n        <line x1=\"75\" y1=\"120\" x2=\"105\" y2=\"120\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"arrow\"/>\n        <line x1=\"75\" y1=\"171\" x2=\"105\" y2=\"171\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"arrow\"/>\n        <line x1=\"435\" y1=\"171\" x2=\"470\" y2=\"171\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"arrow\"/>\n        <line x1=\"75\" y1=\"171\" x2=\"75\" y2=\"220\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"arrow\"/>\n\n        <!-- Backward text label -->\n        <text x=\"240\" y=\"60\" font-size=\"20\" font-family=\"serif\" font-weight=\"bold\" fill=\"#333\">backward</text>\n    </svg>\n\n    <script>\n        try {\n            const tooltip = document.getElementById('tooltip');\n            const svg = document.querySelector('svg');\n\n            svg.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            svg.querySelectorAll('line, rect').forEach(element => {\n                element.addEventListener('mouseenter', () => {\n                    tooltip.style.display = 'block';\n                    element.setAttribute('stroke-width', '3');\n                });\n                element.addEventListener('mouseleave', () => {\n                    tooltip.style.display = 'none';\n                    element.setAttribute('stroke-width', '1.5');\n                });\n\n                element.addEventListener('click', () => {\n                    let title = '';\n                    let body = '';\n                    if (element.tagName === 'line') {\n                        title = 'Arrow Explanation';\n                        body = 'This arrow indicates data flow direction.';\n                    } else if (element.tagName === 'rect' && element.hasAttribute('fill')) {\n                        title = 'Parameter Update';\n                        body = 'The output represents the gradient of J with respect to θ.';\n                    }\n                    showPopup(title, body);\n                });\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') hidePopup();\n            });\n\n            svg.addEventListener('click', e => {\n                if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n            });\n        } catch (error) {\n            console.error('Error running script', error);\n        }\n    </script>\n</body>\n</html>",
