  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .arrow { stroke:#00f; stroke-width:1.5; fill:none; }\n        .triangle { fill:#00f; }\n        .axis { stroke:#000; stroke-width:1.5; }\n        .text { font-size:11; font-family:sans-serif; }\n        #tooltip {\n            position:fixed;\n            background:rgba(0,0,0,0.55);\n            color:#fff;\n            font:11px/1.4 sans-serif;\n            padding:3px 8px;\n            border-radius:4px;\n            pointer-events:none;\n            z-index:100;\n            white-space:nowrap;\n            display:none;\n        }\n    </style>\n</head>\n<body>\n    <svg viewBox=\"0 0 600 200\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <line x1=\"50\" y1=\"150\" x2=\"550\" y2=\"150\" class=\"axis\" marker-end=\"url(#arr)\"/>\n        <line x1=\"50\" y1=\"170\" x2=\"50\" y2=\"150\" class=\"axis\"/>\n        \n        <g class=\"pulse\" data-tooltip=\"Pulse at t=0\" data-popup=\"Unit pulse at t=0. Part of delta train.\">\n            <line x1=\"100\" y1=\"150\" x2=\"100\" y2=\"50\" class=\"arrow\"/>\n            <path d=\"M97,50 L103,50 L100,40 z\" class=\"triangle\"/>\n        </g>\n\n        <g class=\"pulse\" data-tooltip=\"Pulse at t=Ts\" data-popup=\"Unit pulse at t=Ts. Part of delta train.\">\n            <line x1=\"200\" y1=\"150\" x2=\"200\" y2=\"70\" class=\"arrow\"/>\n            <path d=\"M197,70 L203,70 L200,60 z\" class=\"triangle\"/>\n        </g>\n\n        <g class=\"pulse\" data-tooltip=\"Pulse at t=2Ts\" data-popup=\"Unit pulse at t=2Ts. Part of delta train.\">\n            <line x1=\"300\" y1=\"150\" x2=\"300\" y2=\"70\" class=\"arrow\"/>\n            <path d=\"M297,70 L303,70 L300,60 z\" class=\"triangle\"/>\n        </g>\n\n        <g class=\"pulse\" data-tooltip=\"Pulse at t=3Ts\" data-popup=\"Unit pulse at t=3Ts. Part of delta train.\">\n            <line x1=\"400\" y1=\"150\" x2=\"400\" y2=\"70\" class=\"arrow\"/>\n            <path d=\"M397,70 L403,70 L400,60 z\" class=\"triangle\"/>\n        </g>\n\n        <g class=\"pulse\" data-tooltip=\"Pulse at t=4Ts\" data-popup=\"Unit pulse at t=4Ts. Part of delta train.\">\n            <line x1=\"500\" y1=\"150\" x2=\"500\" y2=\"70\" class=\"arrow\"/>\n            <path d=\"M497,70 L503,70 L500,60 z\" class=\"triangle\"/>\n        </g>\n\n        <text x=\"110\" y=\"80\" class=\"text\">δ<sub>T<sub>s</sub></sub>(t)</text>\n        <text x=\"190\" y=\"160\" class=\"text\">T<sub>s</sub></text>\n        <text x=\"290\" y=\"160\" class=\"text\">2T<sub>s</sub></text>\n        <text x=\"560\" y=\"155\" class=\"text\">t</text>\n        <text x=\"95\" y=\"90\" class=\"text\">1</text>\n    </svg>\n\n    <div id=\"tooltip\"></div>\n\n    <script>\n        (function() {\n            const svg = document.querySelector('svg');\n            const tooltip = document.getElementById('tooltip');\n\n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            svg.addEventListener('mouseover', e => {\n                if (e.target.closest('.pulse')) {\n                    tooltip.textContent = e.target.closest('.pulse').getAttribute('data-tooltip');\n                    tooltip.style.display = 'block';\n                    e.target.closest('.pulse').querySelector('.arrow').style.strokeWidth = 3;\n                }\n            });\n\n            svg.addEventListener('mouseout', e => {\n                if (e.target.closest('.pulse')) {\n                    tooltip.style.display = 'none';\n                    e.target.closest('.pulse').querySelector('.arrow').style.strokeWidth = 1.5;\n                }\n            });\n\n            svg.addEventListener('click', e => {\n                if (e.target.closest('.pulse')) {\n                    showPopup('Pulse Information', e.target.closest('.pulse').getAttribute('data-popup'));\n                }\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') hidePopup();\n            });\n\n            svg.addEventListener('click', e => {\n                if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n            });\n\n        })();\n    </script>\n</body>\n</html>",
