  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Interactive Diagram</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n<div class=\"tooltip\" id=\"tooltip\"></div>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 200\" preserveAspectRatio=\"xMidYMid meet\">\n    <defs>\n        <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n            <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n        </marker>\n    </defs>\n    <!-- Input Text -->\n    <text x=\"80\" y=\"100\" font-size=\"14\" text-anchor=\"middle\" font-family=\"serif\" fill=\"#000\">\n        <tspan font-style=\"italic\">X, Y, Z, ψ, φ</tspan>\n    </text>\n    <path d=\"M50,110 Q80,70 110,110\" fill=\"none\" stroke=\"#000\"/>\n    <text x=\"80\" y=\"65\" font-size=\"12\" text-anchor=\"middle\" font-family=\"serif\" fill=\"#000\">ℝ</text>\n\n    <!-- Rectangle -->\n    <rect x=\"200\" y=\"50\" width=\"100\" height=\"100\" fill=\"#f4c582\" stroke=\"#000\" stroke-width=\"1.5\" rx=\"10\"/>\n\n    <!-- Rectangle Label -->\n    <text x=\"250\" y=\"110\" font-size=\"14\" font-family=\"serif\" font-style=\"italic\" text-anchor=\"middle\" fill=\"#000\">L₀</text>\n\n    <!-- Output Text -->\n    <text x=\"480\" y=\"100\" font-size=\"14\" text-anchor=\"middle\" font-family=\"serif\" fill=\"#000\">\n        <tspan font-style=\"italic\">r, g, b, σ</tspan>\n    </text>\n\n    <!-- Arrows -->\n    <line x1=\"150\" y1=\"100\" x2=\"200\" y2=\"100\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    <line x1=\"300\" y1=\"100\" x2=\"430\" y2=\"100\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n\n</svg>\n<script>\n    const tooltip = document.getElementById('tooltip');\n    const svg = document.querySelector('svg');\n\n    function showTooltip(evt, text) {\n        tooltip.style.display = 'block';\n        tooltip.textContent = text;\n        tooltip.style.left = (evt.clientX + 12) + 'px';\n        tooltip.style.top = (evt.clientY - 28) + 'px';\n    }\n\n    function hideTooltip() {\n        tooltip.style.display = 'none';\n    }\n\n    svg.addEventListener('mousemove', (e) => {\n        if (e.target.closest('line')) {\n            showTooltip(e, 'Data Flow');\n        } else if (e.target.closest('rect')) {\n            showTooltip(e, 'Transformation Lθ');\n        } else {\n            hideTooltip();\n        }\n    });\n\n    svg.addEventListener('click', e => {\n        if(e.target.closest('line')) {\n            showPopup('Data Flow', 'This represents the flow of data through the process.');\n        } else if(e.target.closest('rect')) {\n            showPopup('Transformation Lθ', 'Lθ is a function transforming input data to output results.');\n        }\n    });\n\n    function showPopup(title, body) {\n        window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n    }\n\n    function hidePopup() {\n        window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n    }\n\n    document.addEventListener('keydown', e => {\n        if (e.key === 'Escape') hidePopup();\n    });\n\n    try {\n        // JavaScript code for animations and interactions goes here\n    } catch (e) {\n        console.error(e);\n    }\n</script>\n</body>\n</html>",
