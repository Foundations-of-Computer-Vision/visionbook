  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Delta Function</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; display:block; }\n        #tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\"></div>\n    <svg viewBox=\"0 0 600 300\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"10\" refX=\"5\" refY=\"5\" orient=\"auto\">\n                <path d=\"M0,0 L0,10 L10,5 Z\" fill=\"#333\"/>\n            </marker>\n            <marker id=\"bluearrowhead\" markerWidth=\"10\" markerHeight=\"10\" refX=\"5\" refY=\"5\" orient=\"auto\">\n                <path d=\"M0,5 L10,0 L10,10 Z\" fill=\"blue\"/>\n            </marker>\n        </defs>\n        <line x1=\"50\" y1=\"250\" x2=\"550\" y2=\"250\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arrowhead)\"/>\n        <line x1=\"50\" y1=\"250\" x2=\"50\" y2=\"50\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arrowhead)\"/>\n        <line x1=\"300\" y1=\"250\" x2=\"300\" y2=\"150\" stroke=\"blue\" stroke-width=\"1.5\" marker-end=\"url(#bluearrowhead)\"/>\n        <text x=\"320\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\" fill=\"black\">a</text>\n        <text x=\"20\" y=\"50\" font-size=\"11\" font-family=\"sans-serif\" fill=\"black\">δ(t−a)</text>\n        <text x=\"30\" y=\"175\" font-size=\"11\" font-family=\"sans-serif\" fill=\"black\">1</text>\n        <text x=\"550\" y=\"265\" font-size=\"11\" font-family=\"sans-serif\" fill=\"black\">t</text>\n    </svg>\n    <script>\n        try {\n            const svg = document.querySelector('svg');\n            const tooltip = document.getElementById('tooltip');\n\n            svg.addEventListener('mousemove', e => {\n                if (e.target.closest('line[stroke=\"blue\"]')) {\n                    tooltip.style.left = (e.clientX + 12) + 'px';\n                    tooltip.style.top = (e.clientY - 28) + 'px';\n                    tooltip.style.display = 'block';\n                    tooltip.textContent = 'Impulse at t = a';\n                } else {\n                    tooltip.style.display = 'none';\n                }\n            });\n\n            svg.addEventListener('click', e => {\n                if (e.target.closest('line[stroke=\"blue\"]')) {\n                    showPopup(\"Dirac Delta Function\", \"This represents an impulse occurring at time t = a, often \" +\n                               \"used in analysis of linear systems to model instantaneous events.\");\n                }\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') \n                    hidePopup();\n            });\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n        } catch (e) {\n            console.error(e);\n        }\n    </script>\n</body>\n</html>",
