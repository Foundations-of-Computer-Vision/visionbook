>\n    <circle cx=\"75\" cy=\"218\" r=\"5\" />\n    <circle cx=\"100\" cy=\"218\" r=\"5\" />\n    <circle cx=\"125\" cy=\"218\" r=\"5\" />\n    <circle cx=\"150\" cy=\"218\" r=\"5\" />\n    <circle cx=\"175\" cy=\"218\" r=\"5\" />\n    <circle cx=\"200\" cy=\"218\" r=\"5\" />\n    <circle cx=\"225\" cy=\"218\" r=\"5\" />\n    <circle cx=\"250\" cy=\"218\" r=\"5\" />\n    <circle cx=\"275\" cy=\"218\" r=\"5\" />\n    <circle cx=\"300\" cy=\"218\" r=\"5\" />\n    <circle cx=\"325\" cy=\"218\" r=\"5\" />\n    <circle cx=\"350\" cy=\"218\" r=\"5\" />\n    <circle cx=\"375\" cy=\"218\" r=\"5\" />\n    <circle cx=\"400\" cy=\"218\" r=\"5\" />\n    <circle cx=\"425\" cy=\"218\" r=\"5\" />\n    <circle cx=\"450\" cy=\"218\" r=\"5\" />\n    <circle cx=\"475\" cy=\"218\" r=\"5\" />\n    <circle cx=\"500\" cy=\"218\" r=\"5\" />\n    <circle cx=\"525\" cy=\"218\" r=\"5\" />\n  </g>\n\n</svg>\n<div id=\"tooltip\"></div>\n<script>\n  const circles = document.querySelectorAll('circle');\n  const tooltip = document.getElementById('tooltip');\n\n  circles.forEach(circle => {\n    circle.addEventListener('mousemove', (e) => {\n      tooltip.style.left = (e.clientX + 12) + 'px';\n      tooltip.style.top = (e.clientY - 28) + 'px';\n      tooltip.style.display = 'block';\n      tooltip.textContent = 'Height: ' + ((circle.getAttribute('cy') == '105') ? '2' : '1');\n      circle.setAttribute('r', 6.5);\n    });\n    circle.addEventListener('mouseout', () => {\n      tooltip.style.display = 'none';\n      circle.setAttribute('r', 5);\n    });\n    circle.addEventListener('click', () => {\n      const height = (circle.getAttribute('cy') == '105') ? '2' : '1';\n      let title = `Value: ${height}`;\n      let body = `This point represents the signal amplitude of ${height} at n=0.`;\n      showPopup(title, body);\n    });\n  });\n\n  function showPopup(title, body) {\n    window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n  }\n\n  function hidePopup() {\n    window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n  }\n\n  document.addEventListener('keydown', e => {\n    if (e.key === 'Escape') hidePopup();\n  });\n\n  document.querySelector('svg').addEventListener('click', e => {\n    if (e.target === document.querySelector('svg')) hidePopup();\n  });\n</script>\n</body>\n</html>",
