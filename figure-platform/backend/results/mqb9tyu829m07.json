  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <style>\n    html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n    svg { width:100%; height:100%; }\n    .tooltip {\n      position:fixed;\n      background:rgba(0,0,0,0.55);\n      color:#fff;\n      font:11px/1.4 sans-serif;\n      padding:3px 8px;\n      border-radius:4px;\n      pointer-events:none;\n      z-index:100;\n      white-space:nowrap;\n      visibility:hidden;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"tooltip\" id=\"tooltip\"></div>\n  <svg viewBox=\"0 0 600 530\" preserveAspectRatio=\"xMidYMid meet\">\n    <defs>\n      <marker id=\"arrow\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n        <path d=\"M0,0 L0,6 L6,3 z\" fill=\"blue\"/>\n      </marker>\n    </defs>\n    <circle cx=\"300\" cy=\"150\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <circle cx=\"150\" cy=\"150\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <circle cx=\"450\" cy=\"150\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <circle cx=\"300\" cy=\"300\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <circle cx=\"225\" cy=\"450\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <circle cx=\"375\" cy=\"450\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <line x1=\"273\" y1=\"150\" x2=\"177\" y2=\"150\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <line x1=\"327\" y1=\"150\" x2=\"423\" y2=\"150\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <line x1=\"300\" y1=\"177\" x2=\"300\" y2=\"273\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <line x1=\"300\" y1=\"327\" x2=\"237\" y2=\"423\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <line x1=\"300\" y1=\"327\" x2=\"363\" y2=\"423\" stroke=\"#000\" stroke-width=\"1.5\"/>\n    <line x1=\"300\" y1=\"225\" x2=\"300\" y2=\"150\" stroke=\"blue\" stroke-width=\"1.5\" marker-end=\"url(#arrow)\"/>\n    <line x1=\"300\" y1=\"225\" x2=\"300\" y2=\"300\" stroke=\"blue\" stroke-width=\"1.5\" marker-end=\"url(#arrow)\"/>\n  </svg>\n  <script>\n    try {\n      const svg = document.querySelector('svg');\n      const tooltip = document.getElementById('tooltip');\n      \n      const elements = document.querySelectorAll('circle, line');\n\n      elements.forEach(el => {\n        el.addEventListener('mouseover', e => {\n          e.target.style.strokeWidth = '3';\n          tooltip.style.left = (e.clientX + 12) + 'px';\n          tooltip.style.top = (e.clientY - 28) + 'px';\n          tooltip.textContent = getTooltipText(e.target);\n          tooltip.style.visibility = 'visible';\n        });\n\n        el.addEventListener('mouseout', e => {\n          e.target.style.strokeWidth = '1.5';\n          tooltip.style.visibility = 'hidden';\n        });\n\n        el.addEventListener('click', e => {\n          const text = getPopupText(e.target);\n          if (text) showPopup(\"Node Information\", text);\n        });\n      });\n\n      document.addEventListener('keydown', e => {\n        if (e.key === 'Escape') hidePopup();\n      });\n\n      svg.addEventListener('click', e => {\n        if (e.target.tagName === 'svg') hidePopup();\n      });\n\n      function getTooltipText(element) {\n        const tag = element.tagName;\n        if (tag === 'circle') return \"Node: Central processing point\";\n        if (tag === 'line') return \"Connection: Data flow direction\";\n        return '';\n      }\n\n      function getPopupText(element) {\n        const tag = element.tagName;\n        if (tag === 'circle') return \"This circle represents a node in the network. Nodes process or exchange data.\";\n        if (tag === 'line') return \"This line indicates a data flow between nodes, showing direction with arrows.\";\n        return '';\n      }\n\n      function showPopup(title, body) {\n        window.parent.postMessage({ type:'alex-popup', title, body }, '*');\n      }\n      \n      function hidePopup() {\n        window.parent.postMessage({ type:'alex-popup', title: null }, '*');\n      }\n    } catch (error) {\n      console.error(error);\n    }\n  </script>\n</body>\n</html>",
