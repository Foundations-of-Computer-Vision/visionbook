  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Diagram</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 200\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n            </marker>\n        </defs>\n        <circle id=\"node1\" cx=\"100\" cy=\"100\" r=\"20\" stroke=\"#333\" stroke-width=\"1.5\" fill=\"none\" />\n        <circle id=\"node2\" cx=\"300\" cy=\"100\" r=\"20\" stroke=\"#333\" stroke-width=\"1.5\" fill=\"none\" />\n        <circle id=\"node3\" cx=\"500\" cy=\"100\" r=\"20\" stroke=\"#333\" stroke-width=\"1.5\" fill=\"none\" />\n        <line x1=\"120\" y1=\"100\" x2=\"280\" y2=\"100\" stroke=\"#333\" stroke-width=\"1.5\" />\n        <line x1=\"320\" y1=\"100\" x2=\"480\" y2=\"100\" stroke=\"#333\" stroke-width=\"1.5\" />\n        <text x=\"90\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\">X₁</text>\n        <text x=\"290\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\">X₂</text>\n        <text x=\"490\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\">X₃</text>\n    </svg>\n    <div id=\"tooltip\"></div>\n    <script>\n        try {\n            const tooltip = document.getElementById('tooltip');\n            const svg = document.querySelector('svg');\n\n            function showTooltip(evt, text) {\n                tooltip.style.left = (evt.clientX + 12) + 'px';\n                tooltip.style.top = (evt.clientY - 28) + 'px';\n                tooltip.innerHTML = text;\n                tooltip.style.display = 'block';\n            }\n\n            function hideTooltip() {\n                tooltip.style.display = 'none';\n            }\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n            svg.addEventListener('click', e => { if (e.target === svg || e.target.tagName === 'svg') hidePopup(); });\n\n            const nodes = [\n                { id: 'node1', label: 'X₁', cx: 100, cy: 100 },\n                { id: 'node2', label: 'X₂', cx: 300, cy: 100 },\n                { id: 'node3', label: 'X₃', cx: 500, cy: 100 }\n            ];\n\n            nodes.forEach(({ id, label }) => {\n                const node = document.getElementById(id);\n                \n                node.addEventListener('mouseover', evt => {\n                    node.style.strokeWidth = '3';\n                    showTooltip(evt, `${label}: First node`);\n                });\n\n                node.addEventListener('mouseout', () => {\n                    node.style.strokeWidth = '1.5';\n                    hideTooltip();\n                });\n\n                node.addEventListener('click', () => {\n                    showPopup(label, 'This node is part of a linear sequence connecting three variables.');\n                });\n            });\n\n        } catch (e) {\n            console.error(e);\n        }\n    </script>\n</body>\n</html>",
