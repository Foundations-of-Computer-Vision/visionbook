  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            visibility: hidden;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 400\" preserveAspectRatio=\"xMidYMid meet\">\n        <text x=\"20\" y=\"80\" font-size=\"40\" font-family=\"sans-serif\">class:</text>\n        <text x=\"150\" y=\"80\" font-size=\"40\" font-family=\"sans-serif\">1</text>\n        <text x=\"250\" y=\"80\" font-size=\"40\" font-family=\"sans-serif\">2</text>\n        <text x=\"450\" y=\"80\" font-size=\"40\" font-family=\"sans-serif\" font-style=\"italic\">K</text>\n        \n        <rect x=\"130\" y=\"100\" width=\"40\" height=\"200\" fill=\"none\" stroke=\"#000\" stroke-width=\"2\"></rect>\n        <rect x=\"230\" y=\"100\" width=\"40\" height=\"200\" fill=\"none\" stroke=\"#000\" stroke-width=\"2\"></rect>\n        <rect x=\"430\" y=\"100\" width=\"40\" height=\"200\" fill=\"none\" stroke=\"#000\" stroke-width=\"2\"></rect>\n\n        <path d=\"M130,140 h40 v40 h-40 v-40\" fill=\"#000\"></path>\n        <path d=\"M230,180 h40 v40 h-40 v-40\" fill=\"#000\"></path>\n        <path d=\"M430,260 h40 v40 h-40 v-40\" fill=\"#000\"></path>\n\n        <text x=\"350\" y=\"200\" font-size=\"40\" font-family=\"sans-serif\">...</text>\n        \n        <!-- Dividers -->\n        <path d=\"M130,180 h40\" stroke=\"#000\" stroke-width=\"2\"></path>\n        <path d=\"M130,220 h40\" stroke=\"#000\" stroke-width=\"2\"></path>\n        <path d=\"M130,260 h40\" stroke=\"#000\" stroke-width=\"2\"></path>\n\n        <path d=\"M230,140 h40\" stroke=\"#000\" stroke-width=\"2\"></path>\n        <path d=\"M230,220 h40\" stroke=\"#000\" stroke-width=\"2\"></path>\n        <path d=\"M230,260 h40\" stroke=\"#000\" stroke-width=\"2\"></path>\n\n        <path d=\"M430,140 h40\" stroke=\"#000\" stroke-width=\"2\"></path>\n        <path d=\"M430,180 h40\" stroke=\"#000\" stroke-width=\"2\"></path>\n        <path d=\"M430,220 h40\" stroke=\"#000\" stroke-width=\"2\"></path>\n    </svg>\n\n    <div id=\"tooltip\"></div>\n\n    <script>\n        try {\n            const tooltip = document.getElementById('tooltip');\n            const svg = document.querySelector('svg');\n\n            const showTooltip = (text, event) => {\n                tooltip.textContent = text;\n                tooltip.style.left = (event.clientX + 12) + 'px';\n                tooltip.style.top = (event.clientY - 28) + 'px';\n                tooltip.style.visibility = 'visible';\n            };\n\n            const hideTooltip = () => {\n                tooltip.style.visibility = 'hidden';\n            };\n\n            const showPopup = (title, body) => {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            };\n\n            svg.addEventListener('mousemove', e => {\n                const target = e.target;\n                if (target.nodeName === 'path') {\n                    showTooltip('This section represents class distribution', e);\n                } else {\n                    hideTooltip();\n                }\n            });\n\n            svg.addEventListener('click', e => {\n                const target = e.target;\n                if (target.nodeName === 'path') {\n                    showPopup('Class Section', 'This black section shows the proportion of the specific class.');\n                }\n            });\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            });\n\n            svg.addEventListener('click', e => {\n                if (e.target === svg || e.target.tagName === 'svg') window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            });\n\n        } catch (error) {\n            console.error('Error: ', error);\n        }\n    </script>\n</body>\n</html>",
