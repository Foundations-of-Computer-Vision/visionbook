  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Graph</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0,0,0,0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 255\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <circle cx=\"60\" cy=\"127.5\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"3\"/>\n        <circle cx=\"180\" cy=\"47.5\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"3\"/>\n        <circle cx=\"180\" cy=\"207.5\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"3\"/>\n        <circle cx=\"300\" cy=\"127.5\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"3\"/>\n        <circle cx=\"420\" cy=\"47.5\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"3\"/>\n        <circle cx=\"420\" cy=\"207.5\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"3\"/>\n        <circle cx=\"540\" cy=\"127.5\" r=\"27\" fill=\"none\" stroke=\"#000\" stroke-width=\"3\"/>\n        <line x1=\"87\" y1=\"127.5\" x2=\"153\" y2=\"47.5\" stroke=\"#000\" stroke-width=\"3\" marker-end=\"url(#arr)\"/>\n        <line x1=\"87\" y1=\"127.5\" x2=\"153\" y2=\"207.5\" stroke=\"#000\" stroke-width=\"3\" marker-end=\"url(#arr)\"/>\n        <line x1=\"207\" y1=\"47.5\" x2=\"273\" y2=\"127.5\" stroke=\"#000\" stroke-width=\"3\" marker-end=\"url(#arr)\"/>\n        <line x1=\"207\" y1=\"207.5\" x2=\"273\" y2=\"127.5\" stroke=\"#000\" stroke-width=\"3\" marker-end=\"url(#arr)\"/>\n        <line x1=\"327\" y1=\"127.5\" x2=\"393\" y2=\"47.5\" stroke=\"#000\" stroke-width=\"3\" marker-end=\"url(#arr)\"/>\n        <line x1=\"327\" y1=\"127.5\" x2=\"393\" y2=\"207.5\" stroke=\"#000\" stroke-width=\"3\" marker-end=\"url(#arr)\"/>\n        <line x1=\"447\" y1=\"47.5\" x2=\"513\" y2=\"127.5\" stroke=\"#000\" stroke-width=\"3\" marker-end=\"url(#arr)\"/>\n        <line x1=\"447\" y1=\"207.5\" x2=\"513\" y2=\"127.5\" stroke=\"#000\" stroke-width=\"3\" marker-end=\"url(#arr)\"/>\n    </svg>\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n    <script>\n        try {\n            const svg = document.querySelector('svg');\n            const tooltip = document.getElementById('tooltip');\n            const nodes = svg.querySelectorAll('circle');\n            const lines = svg.querySelectorAll('line');\n            const highlightColor = '#c8e0ff';\n\n            nodes.forEach((node, index) => {\n                node.addEventListener('mouseover', () => {\n                    node.setAttribute('stroke-width', 4.5);\n                    tooltip.style.display = 'block';\n                    tooltip.textContent = `Node ${index + 1}: Hover for details.`;\n                });\n\n                node.addEventListener('mouseout', () => {\n                    node.setAttribute('stroke-width', 3);\n                    tooltip.style.display = 'none';\n                });\n\n                node.addEventListener('click', () => {\n                    showPopup(`Node ${index + 1}`, 'This node represents an important component of the system.');\n                });\n            });\n\n            lines.forEach((line, index) => {\n                line.addEventListener('mouseover', () => {\n                    line.setAttribute('stroke-width', 4.5);\n                    tooltip.style.display = 'block';\n                    tooltip.textContent = `Edge ${index + 1}: Connects nodes in the flow.`;\n                });\n\n                line.addEventListener('mouseout', () => {\n                    line.setAttribute('stroke-width', 3);\n                    tooltip.style.display = 'none';\n                });\n            });\n\n            let currentActiveIndex = -1;\n\n            function animateFlow() {\n                if (currentActiveIndex !== -1) {\n                    lines[currentActiveIndex].style.stroke = '#000';\n                }\n\n                currentActiveIndex = (currentActiveIndex + 1) % lines.length;\n                lines[currentActiveIndex].style.stroke = highlightColor;\n                setTimeout(animateFlow, 1000);\n            }\n\n            animateFlow();\n\n            document.addEventListener('mousemove', (e) => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', (e) => {\n                if (e.key === 'Escape') hidePopup();\n            });\n\n            svg.addEventListener('click', (e) => {\n                if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n            });\n        } catch (error) {\n            console.error('Error:', error);\n        }\n    </script>\n</body>\n</html>",
