  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Learning Process Diagram</title>\n    <style>\n        html, body { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #fff; }\n        #tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 150\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <text x=\"50\" y=\"75\" font-size=\"16\" font-family=\"serif\" text-anchor=\"middle\">(x<sup>i</sup>, y<sup>i</sup>)<sub>i=1</sub><sup>N</sup></text>\n        <line x1=\"135\" y1=\"75\" x2=\"180\" y2=\"75\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <rect x=\"180\" y=\"40\" width=\"240\" height=\"70\" fill=\"#ccc\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <text x=\"300\" y=\"80\" font-size=\"20\" font-family=\"serif\" text-anchor=\"middle\" font-weight=\"bold\">Learning from examples</text>\n        <line x1=\"420\" y1=\"75\" x2=\"465\" y2=\"75\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <text x=\"520\" y=\"75\" font-size=\"16\" font-family=\"serif\" text-anchor=\"middle\">f<sub>θ</sub></text>\n    </svg>\n\n    <div id=\"tooltip\"></div>\n\n    <script>\n        try {\n            const svg = document.querySelector('svg');\n            const tooltip = document.getElementById('tooltip');\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n            \n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('mousemove', e => {\n                const target = e.target;\n                if (target.closest('text')) {\n                    tooltip.style.display = 'block';\n                    tooltip.style.left = (e.clientX + 12) + 'px';\n                    tooltip.style.top = (e.clientY - 28) + 'px';\n                    tooltip.textContent = target.textContent.trim();\n                } else {\n                    tooltip.style.display = 'none';\n                }\n            });\n\n            document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n\n            // Click event to open popup when clicking on the main process box\n            svg.addEventListener('click', e => {\n                if (e.target.closest('rect')) {\n                    showPopup('Learning Process', 'This illustrates the process of learning from examples to form a hypothesis function fθ.');\n                } else {\n                    hidePopup();\n                }\n            });\n\n        } catch (e) {\n            console.error(e);\n        }\n    </script>\n</body>\n</html>",
