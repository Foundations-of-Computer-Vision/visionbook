  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body {\n            margin: 0;\n            padding: 0;\n            width: 100%;\n            height: 100%;\n            overflow: hidden;\n            background: #fff;\n        }\n        #tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 400\" preserveAspectRatio=\"xMidYMid meet\">\n        <line x1=\"0\" y1=\"300\" x2=\"600\" y2=\"300\" stroke=\"#000\" stroke-width=\"2\"/>\n        <line x1=\"150\" y1=\"300\" x2=\"150\" y2=\"200\" stroke=\"blue\" stroke-width=\"4\" class=\"spectrum-line\" data-wavelength=\"450nm\" data-description=\"Blue light spectrum\"/>\n        <line x1=\"300\" y1=\"300\" x2=\"300\" y2=\"200\" stroke=\"green\" stroke-width=\"4\" class=\"spectrum-line\" data-wavelength=\"550nm\" data-description=\"Green light spectrum\"/>\n        <line x1=\"450\" y1=\"300\" x2=\"450\" y2=\"200\" stroke=\"red\" stroke-width=\"4\" class=\"spectrum-line\" data-wavelength=\"650nm\" data-description=\"Red light spectrum\"/>\n        <text x=\"140\" y=\"320\" font-size=\"14\" font-family=\"sans-serif\">400</text>\n        <text x=\"290\" y=\"320\" font-size=\"14\" font-family=\"sans-serif\">500</text>\n        <text x=\"440\" y=\"320\" font-size=\"14\" font-family=\"sans-serif\">600</text>\n        <text x=\"590\" y=\"320\" font-size=\"14\" font-family=\"sans-serif\">700</text>\n    </svg>\n    <div id=\"tooltip\"></div>\n    <script>\n        const tooltip = document.getElementById('tooltip');\n        const lines = document.querySelectorAll('.spectrum-line');\n\n        lines.forEach(line => {\n            line.addEventListener('mouseover', function() {\n                line.style.strokeWidth = '6';\n                tooltip.style.display = 'block';\n                tooltip.textContent = `${line.dataset.wavelength}: ${line.dataset.description}`;\n            });\n\n            line.addEventListener('mouseout', function() {\n                line.style.strokeWidth = '4';\n                tooltip.style.display = 'none';\n            });\n\n            line.addEventListener('click', function() {\n                showPopup(line.dataset.wavelength, line.dataset.description);\n            });\n        });\n\n        document.addEventListener('mousemove', e => {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n        });\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.addEventListener('keydown', e => {\n            if (e.key === 'Escape') hidePopup();\n        });\n\n        document.querySelector('svg').addEventListener('click', e => {\n            if (e.target === e.currentTarget || e.target.tagName === 'svg') hidePopup();\n        });\n\n    </script>\n</body>\n</html>",
