  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .hoverable:hover { stroke-width:2.5; }\n        .tooltip { position:fixed; background:rgba(0,0,0,0.6); color:#fff; font:11px sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; }\n    </style>\n</head>\n<body>\n    <svg viewBox=\"0 0 600 169\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <line x1=\"120\" y1=\"30\" x2=\"480\" y2=\"70\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"hoverable\" data-tooltip=\"Light ray passing through lens\"/>\n        <line x1=\"120\" y1=\"130\" x2=\"480\" y2=\"70\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"hoverable\" data-tooltip=\"Light ray passing through lens\"/>\n        <line x1=\"120\" y1=\"30\" x2=\"120\" y2=\"130\" stroke=\"#000\" stroke-width=\"1\"/>\n        <line x1=\"480\" y1=\"70\" x2=\"480\" y2=\"130\" stroke=\"#000\" stroke-width=\"1\"/>\n        <line x1=\"40\" y1=\"130\" x2=\"560\" y2=\"130\" stroke=\"#f00\" stroke-width=\"1.5\"/>\n        <line x1=\"300\" y1=\"0\" x2=\"300\" y2=\"169\" stroke=\"#000\" stroke-width=\"3\"/>\n        <path d=\"M300,0 C310,70 290,100 300,169\" fill=\"none\" stroke=\"#000\" stroke-width=\"3\"/>\n        <text x=\"90\" y=\"35\" font-size=\"11\" font-family=\"sans-serif\" fill=\"#000\">P₁</text>\n        <text x=\"90\" y=\"135\" font-size=\"11\" font-family=\"sans-serif\" fill=\"#000\">P₀</text>\n        <text x=\"310\" y=\"100\" font-size=\"11\" font-family=\"sans-serif\" fill=\"#000\">θₙ</text>\n        <text x=\"170\" y=\"145\" font-size=\"11\" font-family=\"sans-serif\" fill=\"#000\">a</text>\n        <text x=\"330\" y=\"145\" font-size=\"11\" font-family=\"sans-serif\" fill=\"#000\">f</text>\n        <text x=\"450\" y=\"145\" font-size=\"11\" font-family=\"sans-serif\" fill=\"#000\">b</text>\n        <text x=\"315\" y=\"160\" font-size=\"11\" font-family=\"sans-serif\" fill=\"#000\">thin lens</text>\n    </svg>\n    <div class=\"tooltip\" style=\"display:none;\"></div>\n    <script>\n        try {\n            const tooltip = document.querySelector('.tooltip');\n\n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            document.querySelectorAll('.hoverable').forEach(el => {\n                el.addEventListener('mouseenter', function() {\n                    tooltip.textContent = this.dataset.tooltip;\n                    tooltip.style.display = 'block';\n                });\n                el.addEventListener('mouseleave', function() {\n                    tooltip.style.display = 'none';\n                });\n                el.addEventListener('click', function() {\n                    showPopup(\"Ray Diagram\", \"This ray shows how light passes through the thin lens, bending to form an image.\");\n                });\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n            document.querySelector('svg').addEventListener('click', e => { if (e.target === e.currentTarget) hidePopup(); });\n        } catch (error) {\n            console.error('Error in interactive diagram script:', error);\n        }\n    </script>\n</body>\n</html>",
