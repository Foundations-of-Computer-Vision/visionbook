  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Image Array</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .hoverable { cursor: pointer; transition: stroke-width 0.2s, opacity 0.2s; }\n        .hoverable:hover { stroke-width: 2px; opacity: 1; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.7);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n    <svg viewBox=\"0 0 600 300\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n\n        <!-- Blocks -->\n        <g class=\"hoverable\" data-label=\"Block 1\" data-info=\"This is a 0 block.\">\n            <rect x=\"10\" y=\"10\" width=\"100\" height=\"150\" fill=\"gray\"/>\n            <text x=\"60\" y=\"180\" font-size=\"18\" font-family=\"sans-serif\" text-anchor=\"middle\" font-weight=\"bold\">0</text>\n        </g>\n        <g class=\"hoverable\" data-label=\"Block 2\" data-info=\"This is a 1 block.\">\n            <rect x=\"120\" y=\"10\" width=\"100\" height=\"150\" fill=\"gray\"/>\n            <text x=\"170\" y=\"180\" font-size=\"18\" font-family=\"sans-serif\" text-anchor=\"middle\" font-weight=\"bold\">1</text>\n        </g>\n        <g class=\"hoverable\" data-label=\"Block 3\" data-info=\"This is a 1 block.\">\n            <rect x=\"230\" y=\"10\" width=\"100\" height=\"150\" fill=\"gray\"/>\n            <text x=\"280\" y=\"180\" font-size=\"18\" font-family=\"sans-serif\" text-anchor=\"middle\" font-weight=\"bold\">1</text>\n        </g>\n        <g class=\"hoverable\" data-label=\"Block 4\" data-info=\"This is a 0 block.\">\n            <rect x=\"340\" y=\"10\" width=\"100\" height=\"150\" fill=\"gray\"/>\n            <text x=\"390\" y=\"180\" font-size=\"18\" font-family=\"sans-serif\" text-anchor=\"middle\" font-weight=\"bold\">0</text>\n        </g>\n        <g class=\"hoverable\" data-label=\"Block 5\" data-info=\"This is a 1 block.\">\n            <rect x=\"450\" y=\"10\" width=\"100\" height=\"150\" fill=\"gray\"/>\n            <text x=\"500\" y=\"180\" font-size=\"18\" font-family=\"sans-serif\" text-anchor=\"middle\" font-weight=\"bold\">1</text>\n        </g>\n        <g class=\"hoverable\" data-label=\"Block 6\" data-info=\"This is a 0 block.\">\n            <rect x=\"560\" y=\"10\" width=\"100\" height=\"150\" fill=\"gray\"/>\n            <text x=\"610\" y=\"180\" font-size=\"18\" font-family=\"sans-serif\" text-anchor=\"middle\" font-weight=\"bold\">0</text>\n        </g>\n    </svg>\n    <script>\n        try {\n            const tooltip = document.getElementById('tooltip');\n            const svg = document.querySelector('svg');\n\n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            document.querySelectorAll('.hoverable').forEach(el => {\n                el.addEventListener('mouseenter', () => {\n                    const label = el.getAttribute('data-label');\n                    const info = el.getAttribute('data-info');\n                    tooltip.textContent = `${label}: ${info}`;\n                    tooltip.style.display = 'block';\n                });\n                el.addEventListener('mouseleave', () => {\n                    tooltip.style.display = 'none';\n                });\n                el.addEventListener('click', () => {\n                    const label = el.getAttribute('data-label');\n                    const info = el.getAttribute('data-info');\n                    showPopup(label, info);\n                });\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') hidePopup();\n            });\n\n            svg.addEventListener('click', e => {\n                if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n            });\n        } catch (e) {\n            console.error('Error:', e);\n        }\n    </script>\n</body>\n</html>",
