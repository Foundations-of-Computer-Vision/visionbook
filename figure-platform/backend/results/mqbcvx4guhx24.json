  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none; }\n        circle:hover { stroke-width: 3px; }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 600\" preserveAspectRatio=\"xMidYMid meet\">\n        <circle cx=\"300\" cy=\"300\" r=\"100\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"none\" />\n\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#000\"/>\n            </marker>\n        </defs>\n\n        <!-- More elements would go here with actual arrowhead if present -->\n    </svg>\n\n    <div id=\"tooltip\"></div>\n\n    <script>\n        const tooltip = document.getElementById('tooltip');\n\n        function showTooltip(e, text) {\n            tooltip.innerText = text;\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n            tooltip.style.display = 'block';\n        }\n\n        function hideTooltip() {\n            tooltip.style.display = 'none';\n        }\n\n        document.querySelector('circle').addEventListener('mouseover', (e) => {\n            showTooltip(e, 'This is a circle. Click to learn more.');\n        });\n        \n        document.querySelector('circle').addEventListener('mouseout', hideTooltip);\n\n        document.querySelector('circle').addEventListener('click', () => {\n            showPopup('Circle Element', 'This circle could represent a node or process in a diagram.');\n        });\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') hidePopup(); });\n        // Optional: Add any sequence animation logic here\n    </script>\n</body>\n</html>",
