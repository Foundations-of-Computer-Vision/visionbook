  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            visibility: hidden;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\" class=\"tooltip\"></div>\n    <svg id=\"svg\" width=\"100%\" height=\"100%\" viewBox=\"0 0 600 570\" preserveAspectRatio=\"xMidYMid meet\">\n      <defs>\n          <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n              <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n          </marker>\n      </defs>\n      <!-- Nodes -->\n      <rect x=\"230\" y=\"125\" width=\"60\" height=\"40\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\"/>\n      <text x=\"245\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" alignment-baseline=\"middle\">G<sub>k</sub></text>\n      \n      <rect x=\"230\" y=\"270\" width=\"60\" height=\"40\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\"/>\n      <text x=\"245\" y=\"295\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\" alignment-baseline=\"middle\">F<sub>k</sub></text>\n      \n      <circle cx=\"200\" cy=\"290\" r=\"20\" fill=\"none\" stroke=\"#000\" stroke-width=\"1.5\"/>\n      <text x=\"200\" y=\"292\" font-size=\"16\" font-family=\"sans-serif\" text-anchor=\"middle\" alignment-baseline=\"middle\">+</text>\n      \n      <!-- Arrows -->\n      <line x1=\"180\" y1=\"130\" x2=\"230\" y2=\"130\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n      <line x1=\"290\" y1=\"130\" x2=\"350\" y2=\"130\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n      <line x1=\"200\" y1=\"160\" x2=\"200\" y2=\"270\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n      <line x1=\"200\" y1=\"310\" x2=\"230\" y2=\"310\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n      <line x1=\"290\" y1=\"290\" x2=\"350\" y2=\"290\" stroke=\"#333\" stroke-width=\"1.5\"/>\n      <line x1=\"350\" y1=\"130\" x2=\"350\" y2=\"290\" stroke=\"#333\" stroke-width=\"1.5\"/>\n\n      <!-- Labels -->\n      <text x=\"170\" y=\"135\" font-size=\"11\" font-family=\"sans-serif\" font-weight=\"bold\" text-anchor=\"middle\" alignment-baseline=\"middle\">g<sub>k</sub></text>\n      <text x=\"370\" y=\"135\" font-size=\"11\" font-family=\"sans-serif\" font-weight=\"bold\" text-anchor=\"middle\" alignment-baseline=\"middle\">g<sub>k+1</sub></text>\n      <text x=\"170\" y=\"320\" font-size=\"11\" font-family=\"sans-serif\" font-weight=\"bold\" text-anchor=\"middle\" alignment-baseline=\"middle\">l<sub>k</sub></text>\n    </svg>\n    <script>\n        const svg = document.getElementById('svg');\n        const tooltip = document.getElementById('tooltip');\n        \n        function showTooltip(content, x, y) {\n            tooltip.innerHTML = content;\n            tooltip.style.left = (x + 12) + 'px';\n            tooltip.style.top = (y - 28) + 'px';\n            tooltip.style.visibility = 'visible';\n        }\n        \n        function hideTooltip() {\n            tooltip.style.visibility = 'hidden';\n        }\n        \n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.addEventListener('keydown', (e) => {\n            if (e.key === 'Escape') hidePopup();\n        });\n\n        svg.addEventListener('click', (e) => {\n            if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n        });\n\n        svg.addEventListener('mousemove', (e) => {\n            const x = e.clientX, y = e.clientY;\n            let target = e.target;\n            \n            if (target.tagName === 'rect' && target.x.baseVal.value === 230 && target.y.baseVal.value === 125) {\n                showTooltip('G<sub>k</sub>: Gains block', x, y);\n            } else if (target.tagName === 'rect' && target.x.baseVal.value === 230 && target.y.baseVal.value === 270) {\n                showTooltip('F<sub>k</sub>: Feedback block', x, y);\n            } else if (target.tagName === 'circle') {\n                showTooltip('+ : Summing Junction', x, y);\n            } else {\n                hideTooltip();\n            }\n        });\n\n        svg.addEventListener('click', (e) => {\n            let target = e.target;\n            \n            if (target.tagName === 'rect' && target.x.baseVal.value === 230 && target.y.baseVal.value === 125) {\n                showPopup('G<sub>k</sub> Block', 'This block represents the gain in the system.');\n            } else if (target.tagName === 'rect' && target.x.baseVal.value === 230 && target.y.baseVal.value === 270) {\n                showPopup('F<sub>k</sub> Block', 'This block represents the feedback in the system.');\n            }\n        });\n    </script>\n</body>\n</html>",
