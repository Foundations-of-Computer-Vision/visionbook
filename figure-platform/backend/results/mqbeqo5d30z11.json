font-size=\"11\" font-family=\"sans-serif\">f<sub>θ</sub>: X → Δ<sup>K-1</sup></text>\n        <line x1=\"400\" y1=\"135\" x2=\"450\" y2=\"135\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n\n        <!-- Output Function -->\n        <text x=\"460\" y=\"135\" font-size=\"11\" font-family=\"sans-serif\">f<sub>θ</sub></text>\n    </svg>\n\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n\n    <script>\n        try {\n            const svg = document.querySelector('svg');\n            const tooltip = document.getElementById('tooltip');\n\n            function showTooltip(text) {\n                tooltip.textContent = text;\n                tooltip.style.display = 'block';\n            }\n\n            function hideTooltip() {\n                tooltip.style.display = 'none';\n            }\n\n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            svg.addEventListener('mouseover', e => {\n                if (e.target.tagName === 'line') {\n                    showTooltip('Knowledge Distillation Process');\n                }\n            });\n\n            svg.addEventListener('mouseout', () => hideTooltip());\n\n            svg.addEventListener('click', e => {\n                if (e.target.tagName !== 'svg') {\n                    window.parent.postMessage({\n                        type: 'alex-popup',\n                        title: 'Knowledge Distillation',\n                        body: 'This diagram illustrates the process of knowledge distillation where a student model learns from a teacher model.'\n                    }, '*');\n                }\n            });\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') {\n                    window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n                }\n            });\n        } catch (error) {\n            console.error('Error initializing interactive diagram:', error);\n        }\n    </script>\n</body>\n</html>",
