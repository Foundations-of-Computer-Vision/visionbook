  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <style>\n    html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n    svg { width:100%; height:100%; }\n    .node:hover { stroke-width:3; }\n    .edge:hover { stroke-width:4.5; }\n    #tooltip {\n      position: fixed;\n      background: rgba(0, 0, 0, 0.55);\n      color: #fff;\n      font: 11px/1.4 sans-serif;\n      padding: 3px 8px;\n      border-radius: 4px;\n      pointer-events: none;\n      white-space: nowrap;\n      z-index: 100;\n      display: none;\n    }\n  </style>\n</head>\n<body>\n  <svg viewBox=\"0 0 600 500\" preserveAspectRatio=\"xMidYMid meet\">\n    <defs>\n      <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n        <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n      </marker>\n    </defs>\n    <circle cx=\"100\" cy=\"400\" r=\"27\" stroke=\"#333\" stroke-width=\"1.5\" fill=\"none\" class=\"node\" data-name=\"X1\" data-description=\"Initial variable or state.\"/>\n    <circle cx=\"500\" cy=\"400\" r=\"27\" stroke=\"#333\" stroke-width=\"1.5\" fill=\"none\" class=\"node\" data-name=\"X2\" data-description=\"Intermediate state or variable.\"/>\n    <circle cx=\"300\" cy=\"100\" r=\"27\" stroke=\"#333\" stroke-width=\"1.5\" fill=\"none\" class=\"node\" data-name=\"X3\" data-description=\"Final dependent variable or state.\"/>\n    \n    <line x1=\"127\" y1=\"400\" x2=\"473\" y2=\"400\" stroke=\"#333\" stroke-width=\"6\" marker-end=\"url(#arr)\" class=\"edge\" data-name=\"Edge X1-X2\" data-description=\"Transition from X1 to X2\"/>\n    <line x1=\"473\" y1=\"400\" x2=\"325\" y2=\"127\" stroke=\"#333\" stroke-width=\"6\" marker-end=\"url(#arr)\" class=\"edge\" data-name=\"Edge X2-X3\" data-description=\"Transition from X2 to X3\"/>\n    \n    <text x=\"80\" y=\"440\" font-size=\"11\" font-family=\"sans-serif\">X1</text>\n    <text x=\"480\" y=\"440\" font-size=\"11\" font-family=\"sans-serif\">X2</text>\n    <text x=\"320\" y=\"120\" font-size=\"11\" font-family=\"sans-serif\">X3</text>\n  </svg>\n\n  <div id=\"tooltip\"></div>\n\n  <script>\n    try {\n      const svg = document.querySelector('svg');\n      const tooltip = document.getElementById('tooltip');\n      \n      svg.addEventListener('mousemove', e => {\n        const target = e.target.closest('.node, .edge');\n        if (target) {\n          tooltip.style.display = 'block';\n          tooltip.style.left = (e.clientX + 12) + 'px';\n          tooltip.style.top = (e.clientY - 28) + 'px';\n          tooltip.textContent = `${target.dataset.name}: ${target.dataset.description}`;\n        } else {\n          tooltip.style.display = 'none';\n        }\n      });\n\n      svg.addEventListener('click', e => {\n        const target = e.target.closest('.node, .edge');\n        if (target) {\n          showPopup(target.dataset.name, target.dataset.description);\n        } else if (e.target === svg || e.target.tagName === 'svg') {\n          hidePopup();\n        }\n      });\n\n      function showPopup(title, body) {\n        window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n      }\n\n      function hidePopup() {\n        window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n      }\n\n      document.addEventListener('keydown', e => {\n        if (e.key === 'Escape') hidePopup();\n      });\n\n    } catch (error) {\n      console.error('Error:', error);\n    }\n  </script>\n</body>\n</html>",
