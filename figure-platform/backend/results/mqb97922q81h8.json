  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive SVG</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; \n                   padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; }\n    </style>\n</head>\n<body>\n    <svg id=\"svg\" width=\"100%\" height=\"100%\" viewBox=\"0 0 600 600\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <radialGradient id=\"grad\" cx=\"50%\" cy=\"50%\" r=\"50%\" fx=\"50%\" fy=\"50%\">\n                <stop offset=\"0%\" style=\"stop-color:white;stop-opacity:1\" />\n                <stop offset=\"100%\" style=\"stop-color:black;stop-opacity:1\" />\n            </radialGradient>\n        </defs>\n        <rect x=\"0\" y=\"0\" width=\"100%\" height=\"100%\" fill=\"url(#grad)\" />\n        <line x1=\"0\" y1=\"300\" x2=\"600\" y2=\"300\" stroke=\"white\" stroke-width=\"1.5\" opacity=\"0.9\" />\n        <line x1=\"300\" y1=\"0\" x2=\"300\" y2=\"600\" stroke=\"white\" stroke-width=\"1.5\" opacity=\"0.9\" />\n        <line x1=\"0\" y1=\"0\" x2=\"600\" y2=\"600\" stroke=\"white\" stroke-width=\"1.5\" opacity=\"0.5\" />\n        <line x1=\"600\" y1=\"0\" x2=\"0\" y2=\"600\" stroke=\"white\" stroke-width=\"1.5\" opacity=\"0.5\" />\n    </svg>\n    <div id=\"tooltip\" style=\"display:none;\"></div>\n    <script>\n        try {\n            const svg = document.getElementById('svg');\n            const tooltip = document.getElementById('tooltip');\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n            \n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') hidePopup();\n            });\n\n            svg.addEventListener('click', e => {\n                if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n                else showPopup('Gradient Highlight', 'This interactive gradient demonstrates how light disperses in different directions.');\n            });\n\n            svg.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            svg.querySelectorAll('line').forEach(line => {\n                line.addEventListener('mouseenter', () => {\n                    tooltip.textContent = 'This is a line demonstrating light reflection.';\n                    tooltip.style.display = 'block';\n                    line.style.strokeWidth = '3';\n                });\n                line.addEventListener('mouseleave', () => {\n                    tooltip.style.display = 'none';\n                    line.style.strokeWidth = '1.5';\n                });\n            });\n        } catch (e) {\n            console.error('Error in script:', e);\n        }\n    </script>\n</body>\n</html>",
