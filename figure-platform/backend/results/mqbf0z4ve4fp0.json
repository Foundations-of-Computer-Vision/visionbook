  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Interactive Diagram</title>\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none; }\n</style>\n</head>\n<body>\n<div id=\"tooltip\"></div>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 200\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n    </marker>\n  </defs>\n\n  <!-- Linear combination of neurons -->\n  <text x=\"100\" y=\"30\" font-size=\"14\" font-family=\"sans-serif\" font-weight=\"bold\">Linear combination of neurons</text>\n  <line x1=\"100\" y1=\"80\" x2=\"150\" y2=\"130\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"w1\"/>\n  <line x1=\"100\" y1=\"80\" x2=\"200\" y2=\"130\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"w2\"/>\n  <line x1=\"100\" y1=\"80\" x2=\"250\" y2=\"130\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"w3\"/>\n  <circle cx=\"150\" cy=\"130\" r=\"15\" fill=\"#ccc\"/>\n  <circle cx=\"200\" cy=\"130\" r=\"15\" fill=\"#666\"/>\n  <circle cx=\"250\" cy=\"130\" r=\"15\" fill=\"#ccc\"/>\n  <circle cx=\"100\" cy=\"80\" r=\"15\" fill=\"none\" stroke=\"black\"/>\n  <text x=\"120\" y=\"80\" font-size=\"11\" font-family=\"sans-serif\">x<sub>out</sub></text>\n  <text x=\"160\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\">x<sub>1</sub></text>\n  <text x=\"210\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\">x<sub>2</sub></text>\n  <text x=\"260\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\">x<sub>3</sub></text>\n  <text x=\"115\" y=\"185\" font-size=\"13\" font-family=\"sans-serif\">x<sub>out</sub> = w<sub>1</sub>x<sub>1</sub> + w<sub>2</sub>x<sub>2</sub> + w<sub>3</sub>x<sub>3</sub></text>\n\n  <!-- Linear combination of tokens -->\n  <text x=\"380\" y=\"30\" font-size=\"14\" font-family=\"sans-serif\" font-weight=\"bold\">Linear combination of tokens</text>\n  <line x1=\"400\" y1=\"80\" x2=\"460\" y2=\"130\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"w1_token\"/>\n  <line x1=\"400\" y1=\"80\" x2=\"510\" y2=\"130\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"w2_token\"/>\n  <line x1=\"400\" y1=\"80\" x2=\"560\" y2=\"130\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" id=\"w3_token\"/>\n  <rect x=\"445\" y=\"115\" width=\"30\" height=\"30\" fill=\"#ccc\"/>\n  <rect x=\"495\" y=\"115\" width=\"30\" height=\"30\" fill=\"#666\"/>\n  <rect x=\"545\" y=\"115\" width=\"30\" height=\"30\" fill=\"#ccc\"/>\n  <rect x=\"400\" y=\"65\" width=\"30\" height=\"30\" fill=\"none\" stroke=\"black\"/>\n  <text x=\"430\" y=\"80\" font-size=\"11\" font-family=\"sans-serif\">t<sub>out</sub></text>\n  <text x=\"460\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\">t<sub>1</sub></text>\n  <text x=\"510\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\">t<sub>2</sub></text>\n  <text x=\"560\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\">t<sub>3</sub></text>\n  <text x=\"420\" y=\"185\" font-size=\"13\" font-family=\"sans-serif\">t<sub>out</sub> = w<sub>1</sub>t<sub>1</sub> + w<sub>2</sub>t<sub>2</sub> + w<sub>3</sub>t<sub>3</sub></text>\n</svg>\n<script>\n  try {\n    const tooltip = document.getElementById('tooltip');\n    const svg = document.querySelector('svg');\n\n    function showTooltip(text) {\n      tooltip.textContent = text;\n      tooltip.style.display = 'block';\n    }\n\n    function hideTooltip() {\n      tooltip.style.display = 'none';\n    }\n\n    function showPopup(title, body) {\n      window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n    }\n\n    function hidePopup() {\n      window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n    }\n\n    document.addEventListener('mousemove', e => {\n      tooltip.style.left = (e.clientX + 12) + 'px';\n      tooltip.style.top = (e.clientY - 28) + 'px';\n    });\n\n    svg.addEventListener('click', e => {\n      if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n    });\n\n    const neurons = [\n      { id: 'w1', text: 'w1', description: 'Weight contributing to x_out from x1.' },\n      { id: 'w2', text: 'w2', description: 'Weight contributing to x_out from x2.' },\n      { id: 'w3', text: 'w3', description: 'Weight contributing to x_out from x3.' },\n    ];\n\n    const tokens = [\n      { id: 'w1_token', text: 'w1', description: 'Weight contributing to t_out from t1.' },\n      { id: 'w2_token', text: 'w2', description: 'Weight contributing to t_out from t2.' },\n      { id: 'w3_token', text: 'w3', description: 'Weight contributing to t_out from t3.' },\n    ];\n\n    function addInteractivity(elements) {\n      elements.forEach(({ id, text, description }) => {\n        const element = document.getElementById(id);\n        if (element) {\n          element.addEventListener('mousemove', () => showTooltip(text + ': ' + description));\n          element.addEventListener('mouseleave', hideTooltip);\n          element.addEventListener('click', () => showPopup(text, description));\n        }\n      });\n    }\n\n    addInteractivity(neurons);\n    addInteractivity(tokens);\n  } catch (error) {\n    console.error('Error in script:', error);\n  }\n</script>\n</body>\n</html>",
