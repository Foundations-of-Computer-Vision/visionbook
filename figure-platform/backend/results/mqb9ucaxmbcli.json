  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 540\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"blue\"/>\n            </marker>\n        </defs>\n        <circle cx=\"150\" cy=\"50\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"white\"/>\n        <circle cx=\"300\" cy=\"50\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"white\"/>\n        <circle cx=\"450\" cy=\"50\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"white\"/>\n        <circle cx=\"300\" cy=\"190\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"white\"/>\n        <circle cx=\"200\" cy=\"330\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"white\"/>\n        <circle cx=\"400\" cy=\"330\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"white\"/>\n        \n        <line x1=\"300\" y1=\"77\" x2=\"300\" y2=\"163\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <line x1=\"150\" y1=\"50\" x2=\"273\" y2=\"50\" stroke=\"blue\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"450\" y1=\"50\" x2=\"327\" y2=\"50\" stroke=\"blue\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"228\" y1=\"317\" x2=\"300\" y2=\"217\" stroke=\"blue\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"372\" y1=\"317\" x2=\"300\" y2=\"217\" stroke=\"blue\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n\n    </svg>\n    <div id=\"tooltip\"></div>\n    <script>\n        const svg = document.querySelector('svg');\n        const tooltip = document.getElementById('tooltip');\n\n        const elements = Array.from(svg.querySelectorAll('circle, line'));\n\n        elements.forEach(element => {\n            element.addEventListener('mouseover', function() {\n                element.style.strokeWidth = '3';\n                tooltip.textContent = 'Element details: Click for more info';\n                tooltip.style.display = 'block';\n            });\n\n            element.addEventListener('mouseout', function() {\n                element.style.strokeWidth = '1.5';\n                tooltip.style.display = 'none';\n            });\n\n            element.addEventListener('click', function() {\n                showPopup('Element Details', 'This element represents a node or connection in the network.');\n            });\n        });\n\n        document.addEventListener('mousemove', function(e) {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n        });\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.addEventListener('keydown', function(e) {\n            if (e.key === 'Escape') hidePopup();\n        });\n\n        svg.addEventListener('click', function(e) {\n            if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n        });\n    </script>\n</body>\n</html>",
