  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  .tooltip {\n    position: fixed;\n    background: rgba(0, 0, 0, 0.55);\n    color: #fff;\n    font: 11px/1.4 sans-serif;\n    padding: 3px 8px;\n    border-radius: 4px;\n    pointer-events: none;\n    z-index: 100;\n    white-space: nowrap;\n    display: none;\n  }\n</style>\n</head>\n<body>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 350\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n    </marker>\n  </defs>\n  <text x=\"50\" y=\"60\" font-size=\"11\" font-family=\"sans-serif\">tokens</text>\n  <text x=\"50\" y=\"80\" font-size=\"11\" font-family=\"sans-serif\">(d-dimensional)</text>\n  <text x=\"50\" y=\"200\" font-size=\"11\" font-family=\"sans-serif\">one-hots</text>\n  <text x=\"50\" y=\"220\" font-size=\"11\" font-family=\"sans-serif\">(K-dimensional)</text>\n  <text x=\"475\" y=\"160\" font-size=\"11\" font-family=\"sans-serif\" transform=\"rotate(90 475,160)\">W<sub>tokenize</sub></text>\n  <line x1=\"100\" y1=\"180\" x2=\"100\" y2=\"140\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  <line x1=\"200\" y1=\"180\" x2=\"200\" y2=\"140\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  <line x1=\"300\" y1=\"180\" x2=\"300\" y2=\"140\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n  <rect x=\"90\" y=\"140\" width=\"20\" height=\"40\" stroke=\"#333\" fill=\"none\" />\n  <rect x=\"190\" y=\"140\" width=\"20\" height=\"40\" stroke=\"#333\" fill=\"none\" />\n  <rect x=\"290\" y=\"140\" width=\"20\" height=\"40\" stroke=\"#333\" fill=\"none\" />\n  <rect x=\"90\" y=\"180\" width=\"20\" height=\"40\" stroke=\"#333\" fill=\"none\" />\n  <rect x=\"190\" y=\"180\" width=\"20\" height=\"40\" stroke=\"#333\" fill=\"none\" />\n  <rect x=\"290\" y=\"180\" width=\"20\" height=\"40\" stroke=\"#333\" fill=\"none\" />\n  <text x=\"98\" y=\"250\" font-size=\"11\" font-family=\"sans-serif\" transform=\"rotate(-45 98,250)\">A</text>\n  <text x=\"198\" y=\"250\" font-size=\"11\" font-family=\"sans-serif\" transform=\"rotate(-45 198,250)\">yellow</text>\n  <text x=\"298\" y=\"250\" font-size=\"11\" font-family=\"sans-serif\" transform=\"rotate(-45 298,250)\">bird</text>\n  <text x=\"398\" y=\"250\" font-size=\"11\" font-family=\"sans-serif\" transform=\"rotate(-45 398,250)\">...</text>\n</svg>\n<div class=\"tooltip\" id=\"tooltip\"></div>\n<script>\n  try {\n    const svg = document.querySelector('svg');\n    const tooltip = document.getElementById('tooltip');\n    const elements = svg.querySelectorAll('rect, line');\n\n    function showPopup(title, body) {\n      window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n    }\n\n    function hidePopup() {\n      window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n    }\n\n    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') hidePopup(); });\n    svg.addEventListener('click', (e) => { if (e.target === svg || e.target.tagName === 'svg') hidePopup(); });\n\n    elements.forEach((element) => {\n      element.addEventListener('mouseenter', (e) => {\n        e.target.setAttribute('stroke-width', '3');\n        tooltip.style.display = 'block';\n        tooltip.textContent = 'Matrix transformation step';\n      });\n\n      element.addEventListener('mouseleave', (e) => {\n        e.target.setAttribute('stroke-width', '1.5');\n        tooltip.style.display = 'none';\n      });\n\n      element.addEventListener('click', () => {\n        showPopup('Matrix Multiplication', 'This step involves a matrix-vector multiplication, transforming one-hot vectors into tokens.');\n      });\n    });\n\n    document.addEventListener('mousemove', (e) => {\n      tooltip.style.left = (e.clientX + 12) + 'px';\n      tooltip.style.top = (e.clientY - 28) + 'px';\n    });\n  } catch (err) {\n    console.error(err);\n  }\n</script>\n</body>\n</html>",
