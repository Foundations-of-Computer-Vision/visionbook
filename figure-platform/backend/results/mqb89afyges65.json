  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Diagram</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n<div id=\"tooltip\"></div>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 487\" preserveAspectRatio=\"xMidYMid meet\">\n    <defs>\n        <marker id=\"arrow\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n            <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n        </marker>\n    </defs>\n    <circle cx=\"0.15*600\" cy=\"0.2*487\" r=\"0.085*600\" fill=\"#ddd\" stroke=\"#000\" stroke-width=\"5\" />\n    <circle cx=\"0.55*600\" cy=\"0.2*487\" r=\"0.085*600\" fill=\"#fff\" stroke=\"#000\" stroke-width=\"5\" />\n    <circle cx=\"0.35*600\" cy=\"0.7*487\" r=\"0.085*600\" fill=\"#ddd\" stroke=\"#000\" stroke-width=\"5\" />\n    <line x1=\"0.15*600\" y1=\"0.2*487\" x2=\"0.35*600\" y2=\"0.7*487\" stroke=\"#333\" stroke-width=\"5\" marker-end=\"url(#arrow)\" />\n    <line x1=\"0.55*600\" y1=\"0.2*487\" x2=\"0.35*600\" y2=\"0.7*487\" stroke=\"#333\" stroke-width=\"5\" marker-end=\"url(#arrow)\" />\n    <text x=\"0.15*600\" y=\"0.2*487\" font-size=\"30\" font-family=\"sans-serif\" text-anchor=\"middle\" alignment-baseline=\"middle\">X</text>\n    <text x=\"0.55*600\" y=\"0.2*487\" font-size=\"30\" font-family=\"sans-serif\" text-anchor=\"middle\" alignment-baseline=\"middle\">Z</text>\n    <text x=\"0.35*600\" y=\"0.7*487\" font-size=\"30\" font-family=\"sans-serif\" text-anchor=\"middle\" alignment-baseline=\"middle\">Y</text>\n</svg>\n<script>\n    try {\n        const svg = document.querySelector('svg');\n        const tooltip = document.getElementById('tooltip');\n\n        const nodes = {\n            X: { cx: 0.15*600, cy: 0.2*487, label: 'X', info: 'X is a starting element.' },\n            Z: { cx: 0.55*600, cy: 0.2*487, label: 'Z', info: 'Z affects Y as well.' },\n            Y: { cx: 0.35*600, cy: 0.7*487, label: 'Y', info: 'Y is influenced by X and Z.' }\n        };\n\n        svg.addEventListener('mousemove', e => {\n            let hoverElement = null;\n            for(let key in nodes) {\n                const node = nodes[key];\n                const dx = e.clientX - node.cx;\n                const dy = e.clientY - node.cy;\n                if(dx**2 + dy**2 < (0.085*600)**2) {\n                    hoverElement = node;\n                    break;\n                }\n            }\n            if(hoverElement) {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n                tooltip.style.display = 'block';\n                tooltip.textContent = hoverElement.label;\n            } else {\n                tooltip.style.display = 'none';\n            }\n        });\n\n        svg.addEventListener('click', e => {\n            for(let key in nodes) {\n                const node = nodes[key];\n                const dx = e.clientX - node.cx;\n                const dy = e.clientY - node.cy;\n                if(dx**2 + dy**2 < (0.085*600)**2) {\n                    showPopup(node.label, node.info);\n                    return;\n                }\n            }\n        });\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.addEventListener('keydown', e => {\n            if(e.key === 'Escape') hidePopup();\n        });\n\n        svg.addEventListener('click', e => {\n            if(e.target === svg || e.target.tagName === 'svg') hidePopup();\n        });\n\n    } catch (e) {\n        console.error(e);\n    }\n</script>\n</body>\n</html>",
