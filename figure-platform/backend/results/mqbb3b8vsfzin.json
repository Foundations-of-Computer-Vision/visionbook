  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Interactive Lens Diagram</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n<div id=\"tooltip\" class=\"tooltip\"></div>\n<svg viewBox=\"0 0 600 300\" preserveAspectRatio=\"xMidYMid meet\" xmlns=\"http://www.w3.org/2000/svg\">\n    <defs>\n        <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n            <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n        </marker>\n    </defs>\n    <line x1=\"50\" y1=\"150\" x2=\"550\" y2=\"150\" stroke=\"blue\" stroke-width=\"2\"/>\n    <line x1=\"160\" y1=\"150\" x2=\"300\" y2=\"85\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n    <line x1=\"440\" y1=\"150\" x2=\"300\" y2=\"215\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n    \n    <ellipse cx=\"300\" cy=\"150\" rx=\"3\" ry=\"75\" fill=\"none\" stroke=\"black\" stroke-width=\"2\"/>\n\n    <circle cx=\"200\" cy=\"150\" r=\"7\" fill=\"#4169E1\" />\n    <circle cx=\"400\" cy=\"150\" r=\"7\" fill=\"#4169E1\" />\n</svg>\n<script>\n    const tooltip = document.getElementById('tooltip');\n    const svg = document.querySelector('svg');\n\n    svg.addEventListener('mousemove', e => {\n        if (e.target.tagName === 'circle') {\n            tooltip.style.display = 'block';\n            tooltip.textContent = 'Focus Point: Converges light rays';\n        } else if (e.target.tagName === 'ellipse') {\n            tooltip.style.display = 'block';\n            tooltip.textContent = 'Lens: Converges light rays';\n        } else {\n            tooltip.style.display = 'none';\n        }\n        tooltip.style.left = (e.clientX + 12) + 'px';\n        tooltip.style.top = (e.clientY - 28) + 'px';\n    });\n\n    svg.addEventListener('click', e => {\n        if (e.target.tagName === 'circle') {\n            showPopup('Focus Point', 'This point is where parallel rays converge after passing through the lens.');\n        } else if (e.target.tagName === 'ellipse') {\n            showPopup('Lens', 'The lens bends incoming light rays to converge them at a focus point.');\n        }\n    });\n\n    function showPopup(title, body) { \n        window.parent.postMessage({ type:'alex-popup', title, body }, '*'); \n    }\n    function hidePopup() { \n        window.parent.postMessage({ type:'alex-popup', title:null  }, '*'); \n    }\n    document.addEventListener('keydown', e => { if(e.key==='Escape') hidePopup(); });\n    svg.addEventListener('click', e => { if(e.target===svg||e.target.tagName==='svg') hidePopup(); });\n\n    // Animation effect (optional)\n    const lines = Array.from(svg.querySelectorAll('line'));\n    lines.forEach(line => line.style.transition = 'stroke 0.35s ease');\n\n    let currentIndex = 0;\n    function animateLines() {\n        if (currentIndex < lines.length) {\n            lines[currentIndex].style.stroke = '#c8e0ff';\n            currentIndex++;\n            setTimeout(animateLines, 500);\n        } else {\n            lines.forEach(line => line.style.stroke = 'blue');\n            currentIndex = 0;\n        }\n    }\n\n    document.addEventListener('click', animateLines);\n</script>\n</body>\n</html>",
