  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none; }\n  svg { display:block; }\n</style>\n</head>\n<body>\n<div id=\"tooltip\"></div>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 222\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n    </marker>\n  </defs>\n\n  <!-- XOR Circle -->\n  <circle cx=\"144\" cy=\"110\" r=\"21\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"none\" />\n  <line x1=\"123\" y1=\"110\" x2=\"165\" y2=\"110\" stroke=\"#000\" stroke-width=\"1.5\" />\n  <line x1=\"144\" y1=\"89\" x2=\"144\" y2=\"131\" stroke=\"#000\" stroke-width=\"1.5\" />\n\n  <!-- Block f -->\n  <rect x=\"200\" y=\"21\" width=\"222\" height=\"180\" fill=\"#f9d49c\" stroke=\"#000\" stroke-width=\"3\" />\n  <text x=\"306\" y=\"132\" font-size=\"38\" font-family=\"serif\" text-anchor=\"middle\" fill=\"#000\">f</text>\n\n  <!-- Lock Icon -->\n  <circle cx=\"360\" cy=\"169\" r=\"14\" fill=\"#000\" />\n  <circle cx=\"360\" cy=\"169\" r=\"10\" fill=\"#f9d49c\" />\n  <path d=\"M349,169 a11,11 0 0,1 22,0\" fill=\"none\" stroke=\"#000\" stroke-width=\"3\" />\n\n  <!-- Letters -->\n  <text x=\"90\" y=\"120\" font-size=\"38\" font-family=\"serif\" fill=\"#000\">p</text>\n  <text x=\"170\" y=\"120\" font-size=\"38\" font-family=\"serif\" fill=\"#000\">x</text>\n  <text x=\"460\" y=\"120\" font-size=\"38\" font-family=\"serif\" fill=\"#000\">y</text>\n\n  <!-- Flame Icon -->\n  <path d=\"M97,150 q-10,-20 0,-30 q-8,8 -5,20 q10,-15 5,-20 q0,8 -5,16 q5,-2 5,-10 q5,12 0,24\" fill=\"#000\" />\n\n  <!-- Arrows -->\n  <line x1=\"186\" y1=\"110\" x2=\"200\" y2=\"110\" stroke=\"#000\" stroke-width=\"9\" marker-end=\"url(#arr)\" />\n  <line x1=\"423\" y1=\"110\" x2=\"450\" y2=\"110\" stroke=\"#000\" stroke-width=\"9\" marker-end=\"url(#arr)\" />\n</svg>\n\n<script>\n  const tooltip = document.getElementById('tooltip');\n\n  document.addEventListener('mousemove', e => {\n    const targetType = e.target.tagName.toLowerCase();\n    if (targetType === 'circle' || targetType === 'line' || targetType === 'text') {\n      tooltip.style.display = 'block';\n      tooltip.style.left = (e.clientX + 12) + 'px';\n      tooltip.style.top = (e.clientY - 28) + 'px';\n      tooltip.textContent = `Element: ${targetType}`;\n    } else {\n      tooltip.style.display = 'none';\n    }\n  });\n\n  function showPopup(title, body) { window.parent.postMessage({ type: 'alex-popup', title, body }, '*'); }\n  function hidePopup() { window.parent.postMessage({ type: 'alex-popup', title: null }, '*'); }\n  document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n  document.querySelector('svg').addEventListener('click', e => {\n    if (e.target.tagName.toLowerCase() !== 'svg') {\n      showPopup('Element Clicked', 'This diagram shows a cryptographic function.');\n    } else {\n      hidePopup();\n    }\n  });\n</script>\n</body>\n</html>",
