  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; display:block; }\n        .node { fill:#fff; stroke:#333; cursor:pointer; transition:stroke 0.3s ease; }\n        .node:hover { stroke-width:3; }\n        .edge { stroke:#333; stroke-width:1.5; }\n        #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none; }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\"></div>\n    <svg viewBox=\"0 0 600 300\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n\n        <!-- Vertical Line -->\n        <line x1=\"0\" y1=\"0\" x2=\"0\" y2=\"300\" class=\"edge\"/>\n\n        <!-- Nodes -->\n        <circle cx=\"300\" cy=\"150\" r=\"30\" class=\"node\" data-info=\"Center Node\" />\n    </svg>\n\n    <script>\n        document.addEventListener('mousemove', function(e) {\n            const tooltip = document.getElementById('tooltip');\n            if (e.target.classList.contains('node')) {\n                tooltip.style.display = 'block';\n                tooltip.textContent = e.target.getAttribute('data-info');\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            } else {\n                tooltip.style.display = 'none';\n            }\n        });\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.querySelector('svg').addEventListener('click', function(e) {\n            if (e.target.classList.contains('node')) {\n                showPopup('Node Information', 'This is a central node within the diagram.');\n            } else {\n                hidePopup();\n            }\n        });\n\n        document.addEventListener('keydown', function(e) {\n            if (e.key === 'Escape') hidePopup();\n        });\n    </script>\n</body>\n</html>",
