  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 170\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n            </marker>\n        </defs>\n        <line x1=\"100\" y1=\"80\" x2=\"230\" y2=\"80\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n        <line x1=\"370\" y1=\"80\" x2=\"500\" y2=\"80\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" />\n        <rect x=\"230\" y=\"50\" width=\"140\" height=\"60\" stroke=\"#333\" fill=\"none\" />\n        <text x=\"75\" y=\"85\" font-size=\"16\" font-family=\"sans-serif\" fill=\"#333\" text-anchor=\"middle\">ℓ<sub>in</sub></text>\n        <text x=\"525\" y=\"85\" font-size=\"16\" font-family=\"sans-serif\" fill=\"#333\" text-anchor=\"middle\">ℓ<sub>out</sub></text>\n        <text x=\"300\" y=\"85\" font-size=\"16\" font-family=\"sans-serif\" fill=\"#333\" text-anchor=\"middle\">f</text>\n    </svg>\n    <div class=\"tooltip\" style=\"display:none;\"></div>\n    <script>\n        (function() {\n            const svg = document.querySelector('svg');\n            const tooltip = document.querySelector('.tooltip');\n\n            function showTooltip(event, text) {\n                tooltip.textContent = text;\n                tooltip.style.left = (event.clientX + 12) + 'px';\n                tooltip.style.top = (event.clientY - 28) + 'px';\n                tooltip.style.display = 'block';\n            }\n\n            function hideTooltip() {\n                tooltip.style.display = 'none';\n            }\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n            svg.addEventListener('click', e => {\n                if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n            });\n\n            // Elements Interactivity\n            const elements = [\n                { selector: 'line:nth-of-type(1)', name: 'Input Line', desc: 'Represents input to function f.' },\n                { selector: 'line:nth-of-type(2)', name: 'Output Line', desc: 'Represents output from function f.' },\n                { selector: 'rect', name: 'Function Box', desc: 'Function f processes input to produce output.' }\n            ];\n\n            elements.forEach(({ selector, name, desc }) => {\n                const el = svg.querySelector(selector);\n                el.style.transition = 'stroke 0.35s ease';\n                el.addEventListener('mouseover', e => {\n                    el.style.strokeWidth = '3';\n                    showTooltip(e, `${name}: ${desc}`);\n                });\n                el.addEventListener('mouseout', () => {\n                    el.style.strokeWidth = '1.5';\n                    hideTooltip();\n                });\n                el.addEventListener('click', () => {\n                    showPopup(name, desc);\n                });\n            });\n            \n        })();\n    </script>\n</body>\n</html>",
