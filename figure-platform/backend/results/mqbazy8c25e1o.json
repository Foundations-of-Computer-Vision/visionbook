  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <style>\n    html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n    svg { width:100%; height:100%; }\n    #tooltip {\n      position: fixed;\n      background: rgba(0,0,0,0.55);\n      color: #fff;\n      font: 11px/1.4 sans-serif;\n      padding: 3px 8px;\n      border-radius: 4px;\n      pointer-events: none;\n      z-index: 100;\n      white-space: nowrap;\n      display: none;\n    }\n  </style>\n</head>\n<body>\n  <div id=\"tooltip\"></div>\n  <svg viewBox=\"0 0 600 300\" preserveAspectRatio=\"xMidYMid meet\"\n       xmlns=\"http://www.w3.org/2000/svg\">\n    <defs>\n      <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n        <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#000\"/>\n      </marker>\n    </defs>\n    <!-- Lens -->\n    <path d=\"M300,50 C310,150 310,150 300,250 \n             M300,50 C290,150 290,150 300,250\" stroke=\"black\" stroke-width=\"2\" fill=\"none\"/>\n\n    <!-- Rays -->\n    <line x1=\"0\"   y1=\"100\" x2=\"300\" y2=\"100\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n    <line x1=\"300\" y1=\"100\" x2=\"370\" y2=\"150\" stroke=\"blue\" stroke-width=\"2\"/>\n    <line x1=\"0\"   y1=\"150\" x2=\"370\" y2=\"150\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n    <line x1=\"0\"   y1=\"200\" x2=\"300\" y2=\"200\" stroke=\"blue\" stroke-width=\"2\" marker-end=\"url(#arr)\"/>\n    <line x1=\"300\" y1=\"200\" x2=\"370\" y2=\"150\" stroke=\"blue\" stroke-width=\"2\"/>\n    \n    <!-- Focal Point -->\n    <circle cx=\"370\" cy=\"150\" r=\"4\" fill=\"steelblue\"/>\n  </svg>\n  <script>\n    const svg = document.querySelector('svg');\n    const tooltip = document.getElementById('tooltip');\n\n    document.querySelectorAll('line, circle').forEach(element => {\n      element.addEventListener('mouseenter', function() {\n        tooltip.style.display = 'block';\n        tooltip.textContent = 'This represents a ray of light.';\n        element.style.strokeWidth = '3';\n      });\n      \n      element.addEventListener('mouseleave', function() {\n        tooltip.style.display = 'none';\n        element.style.strokeWidth = '2';\n      });\n      \n      element.addEventListener('click', function() {\n        showPopup('Ray of Light', 'This shows how light refracts through a convex lens.');\n      });\n    });\n\n    svg.addEventListener('mousemove', e => {\n      tooltip.style.left = (e.clientX + 12) + 'px';\n      tooltip.style.top = (e.clientY - 28) + 'px';\n    });\n\n    function showPopup(title, body) {\n      window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n    }\n\n    function hidePopup() {\n      window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n    }\n\n    document.addEventListener('keydown', e => {\n      if (e.key === 'Escape') hidePopup();\n    });\n\n    svg.addEventListener('click', e => {\n      if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n    });\n  </script>\n</body>\n</html>",
