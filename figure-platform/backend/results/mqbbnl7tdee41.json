  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none; }\n    </style>\n</head>\n<body>\n<div id=\"tooltip\"></div>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 150\" preserveAspectRatio=\"xMidYMid meet\">\n    <defs>\n        <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n            <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n        </marker>\n    </defs>\n    <text x=\"300\" y=\"20\" font-size=\"11\" font-family=\"serif\" text-anchor=\"middle\" font-weight=\"bold\">render<sub>θ</sub></text>\n\n    <!-- Nodes -->\n    <g>\n        <rect x=\"80\" y=\"40\" width=\"80\" height=\"40\" fill=\"#e0c080\" stroke=\"#000\" stroke-width=\"1.5\" rx=\"5\" ry=\"5\"/>\n        <text x=\"120\" y=\"65\" font-size=\"11\" font-family=\"monospace\" text-anchor=\"middle\">pixel2ray</text>\n    </g>\n    <g>\n        <rect x=\"200\" y=\"40\" width=\"80\" height=\"40\" fill=\"#e0c080\" stroke=\"#000\" stroke-width=\"1.5\" rx=\"5\" ry=\"5\"/>\n        <text x=\"240\" y=\"65\" font-size=\"11\" font-family=\"monospace\" text-anchor=\"middle\">ray2coords</text>\n    </g>\n    <g>\n        <rect x=\"320\" y=\"40\" width=\"80\" height=\"40\" fill=\"#e0c080\" stroke=\"#000\" stroke-width=\"1.5\" rx=\"5\" ry=\"5\"/>\n        <text x=\"360\" y=\"65\" font-size=\"11\" font-family=\"serif\" text-anchor=\"middle\">L<sub>θ</sub></text>\n    </g>\n    <g>\n        <rect x=\"440\" y=\"40\" width=\"80\" height=\"40\" fill=\"#e0c080\" stroke=\"#000\" stroke-width=\"1.5\" rx=\"5\" ry=\"5\"/>\n        <text x=\"480\" y=\"65\" font-size=\"11\" font-family=\"monospace\" text-anchor=\"middle\">vrender</text>\n    </g>\n\n    <!-- Arrows -->\n    <line x1=\"50\" y1=\"60\" x2=\"80\" y2=\"60\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    <text x=\"65\" y=\"55\" font-size=\"11\" font-family=\"serif\" text-anchor=\"middle\" font-style=\"italic\">n,m</text>\n\n    <line x1=\"160\" y1=\"60\" x2=\"200\" y2=\"60\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    \n    <line x1=\"280\" y1=\"60\" x2=\"320\" y2=\"60\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    \n    <line x1=\"400\" y1=\"60\" x2=\"440\" y2=\"60\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    \n    <line x1=\"520\" y1=\"60\" x2=\"550\" y2=\"60\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n    <text x=\"535\" y=\"55\" font-size=\"11\" font-family=\"serif\" text-anchor=\"middle\" font-style=\"italic\">ℓ</text>\n\n</svg>\n\n<script>\n    try {\n        const tooltip = document.getElementById('tooltip');\n        document.addEventListener('mousemove', e => {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n        });\n\n        document.querySelectorAll('rect').forEach((rect, i) => {\n            rect.addEventListener('mouseenter', () => {\n                tooltip.style.display = 'block';\n                switch(i) {\n                    case 0:\n                        tooltip.textContent = 'pixel2ray: Converts pixel to ray';\n                        break;\n                    case 1:\n                        tooltip.textContent = 'ray2coords: Converts ray to coordinates';\n                        break;\n                    case 2:\n                        tooltip.textContent = 'Lθ: Imaging model';\n                        break;\n                    case 3:\n                        tooltip.textContent = 'vrender: Final rendering function';\n                        break;\n                }\n                rect.style.strokeWidth = '3';\n            });\n            rect.addEventListener('mouseleave', () => {\n                tooltip.style.display = 'none';\n                rect.style.strokeWidth = '1.5';\n            });\n            rect.addEventListener('click', () => {\n                showPopup('Process Step', tooltip.textContent);\n            });\n        });\n\n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n        document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n        document.querySelector('svg').addEventListener('click', e => {\n            if (e.target === e.currentTarget) hidePopup();\n        });\n    } catch (e) {\n        console.error(e);\n    }\n</script>\n</body>\n</html>",
