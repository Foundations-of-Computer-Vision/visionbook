  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Reconstructed Figure</title>\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none; }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 600\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <!-- Axes -->\n        <line x1=\"90\" y1=\"510\" x2=\"510\" y2=\"510\" stroke=\"#000\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"90\" y1=\"510\" x2=\"90\" y2=\"90\" stroke=\"#000\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <!-- Diagonal Line -->\n        <line x1=\"90\" y1=\"510\" x2=\"510\" y2=\"90\" stroke=\"#000\" stroke-width=\"1.5\"/>\n        <!-- Labels -->\n        <text x=\"505\" y=\"550\" font-size=\"14\" font-family=\"sans-serif\" text-anchor=\"middle\">1</text>\n        <text x=\"300\" y=\"550\" font-size=\"14\" font-family=\"sans-serif\" text-anchor=\"middle\">0.5</text>\n        <text x=\"60\" y=\"100\" font-size=\"14\" font-family=\"sans-serif\" text-anchor=\"middle\">1</text>\n        <text x=\"60\" y=\"310\" font-size=\"14\" font-family=\"sans-serif\" text-anchor=\"middle\">0.5</text>\n        <text x=\"530\" y=\"520\" font-size=\"16\" font-family=\"sans-serif\" text-anchor=\"middle\" font-weight=\"bold\">x<sub>in</sub></text>\n        <text x=\"70\" y=\"70\" font-size=\"16\" font-family=\"sans-serif\" text-anchor=\"middle\" font-weight=\"bold\" transform=\"rotate(-90, 70, 70)\">x<sub>out</sub></text>\n    </svg>\n    <div id=\"tooltip\"></div>\n    <script>\n        (function() {\n            const svg = document.querySelector('svg');\n            const tooltip = document.getElementById('tooltip');\n\n            function showTooltip(evt, text) {\n                tooltip.style.left = (evt.clientX + 12) + 'px';\n                tooltip.style.top = (evt.clientY - 28) + 'px';\n                tooltip.textContent = text;\n                tooltip.style.display = 'block';\n            }\n\n            function hideTooltip() {\n                tooltip.style.display = 'none';\n            }\n\n            svg.addEventListener('mousemove', evt => {\n                let target = evt.target;\n                while (target && target.tagName !== 'line') target = target.parentNode;\n                if (target) {\n                    showTooltip(evt, 'Diagonal Line: x_in = x_out');\n                } else {\n                    hideTooltip();\n                }\n            });\n\n            svg.addEventListener('mouseleave', hideTooltip);\n\n            document.addEventListener('click', evt => {\n                if (evt.target === svg || evt.target.tagName === 'svg') {\n                    window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n                }\n            });\n\n            svg.querySelectorAll('line').forEach(line => {\n                line.addEventListener('click', () => {\n                    window.parent.postMessage({\n                        type: 'alex-popup',\n                        title: 'Diagonal Line',\n                        body: 'This line represents the function where the input equals the output.'\n                    }, '*');\n                });\n            });\n            \n        })();\n    </script>\n</body>\n</html>",
