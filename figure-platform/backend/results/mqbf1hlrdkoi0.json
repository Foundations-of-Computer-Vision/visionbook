'*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.addEventListener('mousemove', e => {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n        });\n\n        svg.addEventListener('mouseover', e => {\n            if (e.target.tagName === 'rect' || e.target.tagName === 'line') {\n                tooltip.style.display = 'block';\n                if (e.target.tagName === 'rect') {\n                    tooltip.textContent = 'State Container';\n                } else if (e.target.tagName === 'line') {\n                    tooltip.textContent = 'Flow Arrow';\n                }\n                e.target.style.stroke = '#0073e6';\n            }\n        });\n\n        svg.addEventListener('mouseout', e => {\n            tooltip.style.display = 'none';\n            if (e.target.tagName === 'rect' || e.target.tagName === 'line') {\n                e.target.style.stroke = '#000';\n            }\n        });\n\n        svg.addEventListener('click', e => {\n            if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n        });\n\n        svg.addEventListener('click', e => {\n            if (e.target.tagName === 'rect') {\n                showPopup('State Container', 'This is a part of a sequence indicating state changes over time.');\n            }\n        });\n    </script>\n</body>\n</html>",
