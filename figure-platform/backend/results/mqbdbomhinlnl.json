  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; \n            padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none; }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\"></div>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 100\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arrow\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#000\"/>\n            </marker>\n        </defs>\n        <line x1=\"0\" y1=\"50\" x2=\"600\" y2=\"50\" stroke=\"#000\" stroke-width=\"1\"/>\n\n        <!-- Sine wave path -->\n        <path d=\"M0,50 Q30,0 60,50 T 120,50 T 180,50 T 240,50 T 300,50 T 360,50 T 420,50 T 480,50 T 540,50 T 600,50\"\n              fill=\"none\" stroke=\"#000\" stroke-width=\"1\"/>\n\n        <!-- Axes -->\n        <line x1=\"300\" y1=\"0\" x2=\"300\" y2=\"100\" stroke=\"none\" stroke-width=\"1\"/>\n        <line x1=\"0\" y1=\"50\" x2=\"600\" y2=\"50\" stroke=\"none\" stroke-width=\"1\" marker-end=\"url(#arrow)\"/>\n        <text x=\"590\" y=\"40\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"end\">t</text>\n\n        <!-- Labels -->\n        <text x=\"295\" y=\"15\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"end\" transform=\"rotate(-90 295,15)\">ℓ(t)</text>\n        <text x=\"15\" y=\"13\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\">1</text>\n        <text x=\"15\" y=\"87\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\">-1</text>\n        <text x=\"300\" y=\"55\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\">0.5</text>\n        <text x=\"600\" y=\"55\" font-size=\"11\" font-family=\"sans-serif\" text-anchor=\"middle\">1</text>\n        \n    </svg>\n    <script>\n        const tooltip = document.getElementById('tooltip');\n        const svg = document.querySelector('svg');\n\n        svg.addEventListener('mousemove', (e) => {\n            const target = e.target;\n            if (target.nodeName === 'text') {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n                tooltip.style.display = 'block';\n                tooltip.textContent = target.textContent;\n            } else {\n                tooltip.style.display = 'none';\n            }\n        });\n\n        document.addEventListener('click', () => {\n            window.parent.postMessage({ type: 'alex-popup', title: 'Sine Wave', body: 'This is a sine wave, a mathematical curve that describes a smooth periodic oscillation.' }, '*');\n        });\n\n        document.addEventListener('keydown', e => {\n            if (e.key === 'Escape') window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        });\n        \n        svg.addEventListener('click', e => {\n            if (e.target === svg || e.target.tagName === 'svg')\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        });\n    </script>\n</body>\n</html>",
