  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 533\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#0000ff\"/>\n            </marker>\n        </defs>\n        <!-- Nodes -->\n        <circle cx=\"150\" cy=\"100\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"none\" class=\"node\" data-name=\"Node 1\" />\n        <circle cx=\"300\" cy=\"100\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"none\" class=\"node\" data-name=\"Node 2\" />\n        <circle cx=\"450\" cy=\"100\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"none\" class=\"node\" data-name=\"Node 3\" />\n        <circle cx=\"300\" cy=\"250\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"none\" class=\"node\" data-name=\"Node 4\" />\n        <circle cx=\"225\" cy=\"400\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"none\" class=\"node\" data-name=\"Node 5\" />\n        <circle cx=\"375\" cy=\"400\" r=\"27\" stroke=\"#000\" stroke-width=\"1.5\" fill=\"none\" class=\"node\" data-name=\"Node 6\" />\n        \n        <!-- Edges -->\n        <line x1=\"177\" y1=\"100\" x2=\"273\" y2=\"100\" stroke=\"#000\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"edge\" data-name=\"Edge A\" />\n        <line x1=\"327\" y1=\"100\" x2=\"423\" y2=\"100\" stroke=\"#000\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"edge\" data-name=\"Edge B\" />\n        <line x1=\"300\" y1=\"127\" x2=\"300\" y2=\"223\" stroke=\"#000\" stroke-width=\"1.5\" class=\"edge\" data-name=\"Edge C\" />\n        <line x1=\"273\" y1=\"277\" x2=\"247.5\" y2=\"373\" stroke=\"#000\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"edge\" data-name=\"Edge D\" />\n        <line x1=\"327\" y1=\"277\" x2=\"352.5\" y2=\"373\" stroke=\"#000\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"edge\" data-name=\"Edge E\" />\n    </svg>\n    <div id=\"tooltip\" class=\"tooltip\"></div>\n    <script>\n        (function() {\n            const tooltip = document.getElementById('tooltip');\n            const edges = document.querySelectorAll('.edge');\n\n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            document.querySelectorAll('.node, .edge').forEach(element => {\n                element.addEventListener('mouseenter', function() {\n                    this.style.strokeWidth = '3';\n                    tooltip.textContent = this.getAttribute('data-name');\n                    tooltip.style.display = 'block';\n                });\n\n                element.addEventListener('mouseleave', function() {\n                    this.style.strokeWidth = '1.5';\n                    tooltip.style.display = 'none';\n                });\n\n                element.addEventListener('click', function() {\n                    const name = this.getAttribute('data-name');\n                    let body = '';\n                    switch (name) {\n                        case 'Node 1':\n                            body = 'This node is the starting point of the network.';\n                            break;\n                        case 'Node 4':\n                            body = 'This node is a central point connecting multiple paths.';\n                            break;\n                        case 'Edge A':\n                            body = 'This edge directs flow from Node 1 to Node 2.';\n                            break;\n                        // Add cases for other nodes/edges if needed\n                        default:\n                            body = 'This is part of the network structure.';\n                    }\n                    showPopup(name, body);\n                });\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n\n            document.addEventListener('keydown', e => {\n                if (e.key === 'Escape') hidePopup();\n            });\n\n            document.querySelector('svg').addEventListener('click', e => {\n                if (e.target === e.currentTarget) hidePopup();\n            });\n\n            // Signal flow animation\n            let currentEdge = 0;\n            function animateFlow() {\n                if (currentEdge < edges.length) {\n                    edges[currentEdge].style.stroke = \"#c8e0ff\";\n                    edges[currentEdge].style.transition = 'stroke 0.35s ease';\n                    currentEdge += 1;\n                    setTimeout(animateFlow, 700);\n                } else {\n                    setTimeout(resetFlow, 700);\n                }\n            }\n\n            function resetFlow() {\n                edges.forEach(edge => edge.style.stroke = \"#000\");\n                currentEdge = 0;\n                setTimeout(animateFlow, 1000);\n            }\n\n            setTimeout(animateFlow, 1000);\n\n        })();\n    </script>\n</body>\n</html>",
