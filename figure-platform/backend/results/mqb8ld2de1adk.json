  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<title>Interactive Matrix Multiplication</title>\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  .tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none; }\n</style>\n</head>\n<body>\n<svg width=\"100%\" height=\"100%\" viewBox=\"0 0 600 250\" preserveAspectRatio=\"xMidYMid meet\">\n\n  <!-- Matrix 1 -->\n  <rect x=\"30\" y=\"80\" width=\"60\" height=\"60\" fill=\"lightblue\" stroke=\"#333\" stroke-width=\"1\"/>\n  <rect x=\"50\" y=\"80\" width=\"10\" height=\"60\" fill=\"none\" stroke=\"#333\" stroke-width=\"1\"/>\n  <rect x=\"30\" y=\"100\" width=\"60\" height=\"10\" fill=\"none\" stroke=\"#333\" stroke-width=\"1\"/>\n\n  <!-- Matrix 2 -->\n  <rect x=\"160\" y=\"40\" width=\"100\" height=\"100\" fill=\"#333\" stroke=\"#333\" stroke-width=\"1\"/>\n  <rect x=\"180\" y=\"40\" width=\"20\" height=\"100\" fill=\"lightblue\" stroke=\"none\"/>\n  <rect x=\"160\" y=\"60\" width=\"100\" height=\"20\" fill=\"lightblue\" stroke=\"none\"/>\n  <rect x=\"200\" y=\"80\" width=\"20\" height=\"20\" fill=\"lightblue\" stroke=\"none\"/>\n  <rect x=\"180\" y=\"100\" width=\"20\" height=\"20\" fill=\"lightblue\" stroke=\"none\"/>\n  <rect x=\"200\" y=\"120\" width=\"20\" height=\"20\" fill=\"lightblue\" stroke=\"none\"/>\n\n  <!-- Result Matrix -->\n  <rect x=\"340\" y=\"20\" width=\"180\" height=\"180\" fill=\"#333\" stroke=\"#333\" stroke-width=\"1\"/>\n  <rect x=\"360\" y=\"20\" width=\"20\" height=\"180\" fill=\"lightblue\" stroke=\"none\"/>\n  <rect x=\"340\" y=\"40\" width=\"180\" height=\"20\" fill=\"lightblue\" stroke=\"none\"/>\n  <rect x=\"360\" y=\"100\" width=\"20\" height=\"20\" fill=\"lightblue\" stroke=\"none\"/>\n  <rect x=\"360\" y=\"140\" width=\"20\" height=\"20\" fill=\"lightblue\" stroke=\"none\"/>\n  <rect x=\"440\" y=\"60\" width=\"20\" height=\"20\" fill=\"lightblue\" stroke=\"none\"/>\n  <rect x=\"520\" y=\"160\" width=\"20\" height=\"20\" fill=\"lightblue\" stroke=\"none\"/>\n\n  <!-- Multiplication symbols -->\n  <text x=\"110\" y=\"115\" font-family=\"sans-serif\" font-size=\"24\">*</text>\n  <text x=\"290\" y=\"115\" font-family=\"sans-serif\" font-size=\"24\">*</text>\n\n</svg>\n<div class=\"tooltip\" id=\"tooltip\"></div>\n<script>\ntry {\n  const tooltip = document.getElementById('tooltip');\n  const svg = document.querySelector('svg');\n\n  svg.addEventListener('mousemove', function(e) {\n    tooltip.style.left = (e.clientX + 12) + 'px';\n    tooltip.style.top = (e.clientY - 28) + 'px';\n  });\n\n  svg.addEventListener('mouseover', function(e) {\n    if (e.target.tagName === 'rect' && e.target.getAttribute('fill') === 'lightblue') {\n      tooltip.style.display = 'block';\n      tooltip.textContent = 'Matrix cell involved in multiplication';\n      e.target.setAttribute('stroke-width', 2.5);\n    }\n  });\n\n  svg.addEventListener('mouseout', function(e) {\n    if (e.target.tagName === 'rect') {\n      tooltip.style.display = 'none';\n      e.target.setAttribute('stroke-width', 1);\n    }\n  });\n\n  function showPopup(title, body) { window.parent.postMessage({ type: 'alex-popup', title, body }, '*'); }\n  function hidePopup() { window.parent.postMessage({ type: 'alex-popup', title: null }, '*'); }\n\n  svg.addEventListener('click', function(e) {\n    if (e.target === svg || e.target.tagName === 'svg') hidePopup();\n    else if (e.target.tagName === 'rect' && e.target.getAttribute('fill') === 'lightblue') {\n      showPopup('Matrix Multiplication', 'This cell is part of the multiplication process resulting in the final matrix.');\n    }\n  });\n\n  document.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') hidePopup();\n  });\n\n} catch (e) {\n  console.error('Error:', e);\n}\n</script>\n</body>\n</html>",
