  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        svg { width:100%; height:100%; }\n        .tooltip {\n            position: fixed;\n            background: rgba(0, 0, 0, 0.55);\n            color: #fff;\n            font: 11px/1.4 sans-serif;\n            padding: 3px 8px;\n            border-radius: 4px;\n            pointer-events: none;\n            z-index: 100;\n            white-space: nowrap;\n            display: none;\n        }\n    </style>\n</head>\n<body>\n    <svg viewBox=\"0 0 600 300\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n        <circle cx=\"100\" cy=\"200\" r=\"27\" fill=\"#fff\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <circle cx=\"300\" cy=\"200\" r=\"27\" fill=\"#fff\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <circle cx=\"500\" cy=\"200\" r=\"27\" fill=\"#fff\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <circle cx=\"100\" cy=\"100\" r=\"27\" fill=\"#666\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <circle cx=\"300\" cy=\"100\" r=\"27\" fill=\"#666\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <circle cx=\"500\" cy=\"100\" r=\"27\" fill=\"#666\" stroke=\"#333\" stroke-width=\"1.5\"/>\n        <line x1=\"127\" y1=\"200\" x2=\"273\" y2=\"200\" stroke=\"#333\" stroke-width=\"1.5\" />\n        <line x1=\"327\" y1=\"200\" x2=\"473\" y2=\"200\" stroke=\"#333\" stroke-width=\"1.5\" />\n        <line x1=\"100\" y1=\"173\" x2=\"100\" y2=\"127\" stroke=\"#333\" stroke-width=\"1.5\" />\n        <line x1=\"300\" y1=\"173\" x2=\"300\" y2=\"127\" stroke=\"#333\" stroke-width=\"1.5\" />\n        <line x1=\"500\" y1=\"173\" x2=\"500\" y2=\"127\" stroke=\"#333\" stroke-width=\"1.5\" />\n        <text x=\"85\" y=\"230\" font-size=\"11\" font-family=\"sans-serif\">X₁</text>\n        <text x=\"285\" y=\"230\" font-size=\"11\" font-family=\"sans-serif\">X₂</text>\n        <text x=\"485\" y=\"230\" font-size=\"11\" font-family=\"sans-serif\">X₃</text>\n        <text x=\"85\" y=\"95\" font-size=\"11\" font-family=\"sans-serif\">Y₁</text>\n        <text x=\"285\" y=\"95\" font-size=\"11\" font-family=\"sans-serif\">Y₂</text>\n        <text x=\"485\" y=\"95\" font-size=\"11\" font-family=\"sans-serif\">Y₃</text>\n    </svg>\n    <div class=\"tooltip\" id=\"tooltip\"></div>\n    <script>\n        const tooltip = document.getElementById('tooltip');\n        const svg = document.querySelector('svg');\n        \n        function showPopup(title, body) {\n            window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n        }\n\n        function hidePopup() {\n            window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n        }\n\n        document.addEventListener('mousemove', e => {\n            tooltip.style.left = (e.clientX + 12) + 'px';\n            tooltip.style.top = (e.clientY - 28) + 'px';\n        });\n\n        svg.addEventListener('mouseover', e => {\n            if (e.target.tagName === 'circle') {\n                tooltip.style.display = 'block';\n                tooltip.textContent = e.target.nextElementSibling.textContent;\n            }\n        });\n\n        svg.addEventListener('mouseout', e => {\n            tooltip.style.display = 'none';\n        });\n\n        svg.addEventListener('click', e => {\n            if (e.target.tagName === 'circle') {\n                showPopup('Node Information', 'This node represents ' + e.target.nextElementSibling.textContent + '.');\n            } else if (e.target === svg || e.target.tagName === 'svg') {\n                hidePopup();\n            }\n        });\n    </script>\n</body>\n</html>",
