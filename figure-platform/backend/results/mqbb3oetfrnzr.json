  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<style>\n  html, body { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #fff; }\n  #tooltip { position: fixed; background: rgba(0, 0, 0, 0.55); color: #fff; font: 11px/1.4 sans-serif; padding: 3px 8px; border-radius: 4px; pointer-events: none; z-index: 100; white-space: nowrap; display: none; }\n  svg { width: 100%; height: 100%; }\n  .hoverable:hover { stroke-width: 3px; }\n</style>\n</head>\n<body>\n<div id=\"tooltip\"></div>\n<svg viewBox=\"0 0 600 250\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\" />\n    </marker>\n  </defs>\n  <path d=\"M300,50 Q320,125 300,200\" stroke=\"#000\" stroke-width=\"2\" fill=\"none\" />\n  <path d=\"M300,50 Q280,125 300,200\" stroke=\"#000\" stroke-width=\"2\" fill=\"none\" />\n  <line x1=\"0\" y1=\"125\" x2=\"220\" y2=\"125\" stroke=\"#00f\" stroke-width=\"1.5\" class=\"hoverable\" />\n  <line x1=\"380\" y1=\"125\" x2=\"600\" y2=\"125\" stroke=\"#00f\" stroke-width=\"1.5\" class=\"hoverable\" />\n  <circle cx=\"220\" cy=\"125\" r=\"6\" fill=\"#1e90ff\" class=\"hoverable\" />\n  <circle cx=\"380\" cy=\"125\" r=\"6\" fill=\"#1e90ff\" class=\"hoverable\" />\n  <line x1=\"220\" y1=\"125\" x2=\"300\" y2=\"70\" stroke=\"#00f\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"hoverable\" />\n  <line x1=\"220\" y1=\"125\" x2=\"300\" y2=\"180\" stroke=\"#00f\" stroke-width=\"1.5\" marker-end=\"url(#arr)\" class=\"hoverable\" />\n</svg>\n<script>\n  const tooltip = document.getElementById('tooltip');\n  document.addEventListener('mousemove', e => {\n    tooltip.style.left = (e.clientX + 12) + 'px';\n    tooltip.style.top = (e.clientY - 28) + 'px';\n  });\n  const showTooltip = (text) => {\n    tooltip.textContent = text;\n    tooltip.style.display = 'block';\n  };\n  const hideTooltip = () => {\n    tooltip.style.display = 'none';\n  };\n  document.querySelectorAll('.hoverable').forEach(el => {\n    el.addEventListener('mouseenter', () => showTooltip('Lens element or light ray'));\n    el.addEventListener('mouseleave', hideTooltip);\n    el.addEventListener('click', () => showPopup('Lens Interaction', 'This shows how light rays converge through the lens to focus at a point.'));\n  });\n  function showPopup(title, body) {\n    window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n  }\n  function hidePopup() {\n    window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n  }\n  document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n  document.querySelector('svg').addEventListener('click', e => {\n    if (e.target.tagName === 'svg') hidePopup();\n  });\n</script>\n</body>\n</html>",
