  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <style>\n        html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n        #tooltip { position:fixed; background:rgba(0,0,0,0.55); color:#fff; font:11px/1.4 sans-serif; padding:3px 8px; border-radius:4px; pointer-events:none; z-index:100; white-space:nowrap; display:none; }\n    </style>\n</head>\n<body>\n    <div id=\"tooltip\"></div>\n    <svg id=\"svg\" width=\"100%\" height=\"100%\" viewBox=\"0 0 600 315\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n            <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n                <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n            </marker>\n        </defs>\n\n        <!-- Axes -->\n        <line x1=\"0\" y1=\"157.5\" x2=\"600\" y2=\"157.5\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n        <line x1=\"300\" y1=\"315\" x2=\"300\" y2=\"0\" stroke=\"#333\" stroke-width=\"1.5\" marker-end=\"url(#arr)\"/>\n\n        <!-- Frequency Marks -->\n        <line x1=\"100\" y1=\"157.5\" x2=\"100\" y2=\"100\" stroke=\"blue\" stroke-width=\"1.5\"/>\n        <polygon points=\"100,95 95,105 105,105\" fill=\"none\" stroke=\"blue\" stroke-width=\"1.5\"/>\n\n        <line x1=\"200\" y1=\"157.5\" x2=\"200\" y2=\"50\" stroke=\"blue\" stroke-width=\"1.5\"/>\n        <polygon points=\"200,45 195,55 205,55\" fill=\"none\" stroke=\"blue\" stroke-width=\"1.5\"/>\n\n        <line x1=\"300\" y1=\"157.5\" x2=\"300\" y2=\"100\" stroke=\"blue\" stroke-width=\"1.5\"/>\n        <polygon points=\"300,95 295,105 305,105\" fill=\"none\" stroke=\"blue\" stroke-width=\"1.5\"/>\n\n        <line x1=\"400\" y1=\"157.5\" x2=\"400\" y2=\"150\" stroke=\"blue\" stroke-width=\"1.5\"/>\n        <polygon points=\"400,145 395,155 405,155\" fill=\"none\" stroke=\"blue\" stroke-width=\"1.5\"/>\n\n        <line x1=\"500\" y1=\"157.5\" x2=\"500\" y2=\"100\" stroke=\"blue\" stroke-width=\"1.5\"/>\n        <polygon points=\"500,95 495,105 505,105\" fill=\"none\" stroke=\"blue\" stroke-width=\"1.5\"/>\n\n        <!-- Labels -->\n        <text x=\"290\" y=\"30\" font-size=\"11\" font-family=\"sans-serif\" fill=\"black\">Δ<sub>T<sub>S</sub></sub>(w)</text>\n        <text x=\"215\" y=\"82\" font-size=\"11\" font-family=\"sans-serif\" fill=\"black\">2π/T<sub>S</sub></text>\n        <text x=\"390\" y=\"172.5\" font-size=\"11\" font-family=\"sans-serif\" fill=\"black\">2π/T<sub>S</sub></text>\n        <text x=\"490\" y=\"172.5\" font-size=\"11\" font-family=\"sans-serif\" fill=\"black\">4π/T<sub>S</sub></text>\n        <text x=\"580\" y=\"150\" font-size=\"11\" font-family=\"sans-serif\" fill=\"black\">w</text>\n    </svg>\n\n    <script>\n        try {\n            const svg = document.getElementById('svg');\n            const tooltip = document.getElementById('tooltip');\n\n            const markers = [\n                { x: 100, y: 100, label: 'Frequency mark at π/Tₛ' },\n                { x: 200, y: 50, label: 'Main frequency π/Tₛ' },\n                { x: 300, y: 100, label: 'Frequency repetition' },\n                { x: 400, y: 150, label: 'Frequency mark at 3π/Tₛ' },\n                { x: 500, y: 100, label: 'Frequency repetition' }\n            ];\n\n            markers.forEach(marker => {\n                const line = svg.querySelector(`line[x1=\"${marker.x}\"]`);\n                const triangle = svg.querySelector(`polygon[points^=\"${marker.x}\"]`);\n\n                [line, triangle].forEach(element => {\n                    element.addEventListener('mouseenter', () => {\n                        element.style.strokeWidth = '3';\n                        tooltip.textContent = marker.label;\n                        tooltip.style.display = 'block';\n                    });\n\n                    element.addEventListener('mouseleave', () => {\n                        element.style.strokeWidth = '1.5';\n                        tooltip.style.display = 'none';\n                    });\n\n                    element.addEventListener('click', () => {\n                        showPopup(\"Frequency Analysis\", \"This frequency marker illustrates discrete sampling and frequency repetition in signal processing.\");\n                    });\n                });\n            });\n\n            document.addEventListener('mousemove', e => {\n                tooltip.style.left = (e.clientX + 12) + 'px';\n                tooltip.style.top = (e.clientY - 28) + 'px';\n            });\n\n            function showPopup(title, body) {\n                window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n            }\n            function hidePopup() {\n                window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n            }\n            document.addEventListener('keydown', e => { if (e.key === 'Escape') hidePopup(); });\n            svg.addEventListener('click', e => { if (e.target === svg || e.target.tagName === 'svg') hidePopup(); });\n\n        } catch (err) {\n            console.error(err);\n        }\n    </script>\n</body>\n</html>",
