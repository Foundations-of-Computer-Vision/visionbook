  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Interactive Diagram</title>\n<style>\n  html, body { margin:0; padding:0; width:100%; height:100%; overflow:hidden; background:#fff; }\n  svg { width:100%; height:100%; }\n  .tooltip {\n    position: fixed;\n    background: rgba(0, 0, 0, 0.55);\n    color: #fff;\n    font: 11px/1.4 sans-serif;\n    padding: 3px 8px;\n    border-radius: 4px;\n    pointer-events: none;\n    z-index: 100;\n    white-space: nowrap;\n    display: none;\n  }\n</style>\n</head>\n<body>\n<svg viewBox=\"0 0 600 200\" preserveAspectRatio=\"xMidYMid meet\">\n  <defs>\n    <marker id=\"arr\" markerWidth=\"6\" markerHeight=\"6\" refX=\"5\" refY=\"3\" orient=\"auto\">\n      <path d=\"M0,0 L0,6 L6,3 z\" fill=\"#333\"/>\n    </marker>\n  </defs>\n  <circle cx=\"150\" cy=\"70\" r=\"27\" stroke=\"#000\" stroke-width=\"2\" fill=\"none\" class=\"node\" id=\"node1\"/>\n  <text x=\"150\" y=\"135\" font-size=\"14\" text-anchor=\"middle\" font-family=\"sans-serif\">X₁</text>\n  <circle cx=\"450\" cy=\"70\" r=\"27\" stroke=\"#000\" stroke-width=\"2\" fill=\"none\" class=\"node\" id=\"node2\"/>\n  <text x=\"450\" y=\"135\" font-size=\"14\" text-anchor=\"middle\" font-family=\"sans-serif\">X₂</text>\n</svg>\n\n<div class=\"tooltip\" id=\"tooltip\"></div>\n\n<script>\n  const tooltip = document.getElementById('tooltip');\n  const nodes = document.querySelectorAll('.node');\n\n  function showPopup(title, body) {\n    window.parent.postMessage({ type: 'alex-popup', title, body }, '*');\n  }\n\n  function hidePopup() {\n    window.parent.postMessage({ type: 'alex-popup', title: null }, '*');\n  }\n\n  document.addEventListener('mousemove', e => {\n    tooltip.style.left = (e.clientX + 12) + 'px';\n    tooltip.style.top = (e.clientY - 28) + 'px';\n  });\n\n  nodes.forEach(node => {\n    node.addEventListener('mouseenter', () => {\n      tooltip.textContent = node.id === 'node1' ? 'Node X₁: Represents first variable' : 'Node X₂: Represents second variable';\n      tooltip.style.display = 'block';\n    });\n\n    node.addEventListener('mouseleave', () => {\n      tooltip.style.display = 'none';\n    });\n\n    node.addEventListener('click', () => {\n      const title = node.id === 'node1' ? 'Variable X₁' : 'Variable X₂';\n      const body = node.id === 'node1' ? 'This is the first variable in the diagram.' : 'This is the second variable in the diagram.';\n      showPopup(title, body);\n    });\n  });\n\n  document.addEventListener('keydown', e => {\n    if (e.key === 'Escape') hidePopup();\n  });\n\n  document.querySelector('svg').addEventListener('click', e => {\n    if (e.target.tagName === 'svg') hidePopup();\n  });\n</script>\n</body>\n</html>",
